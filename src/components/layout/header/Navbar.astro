    <!-- Enlaces + pie (scroll conjunto; el pie no queda fijo abajo) -->
    <div class="flex flex-1 min-h-0 flex-col px-4 py-6 md:px-8 md:py-6 xl:px-10 xl:py-8 gap-6 overflow-y-auto touch-pan-y" id="mobileMenuLinks">
      <div class="bg-white rounded-lg">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
          <div class="mb-4 md:mb-0">
            <div class="font-bold text-base leading-6 tracking-[0.5px]" style="font-weight: 700;">
              Hablemos de innovación médica
            </div>
            <div class="font-normal text-base leading-6 tracking-[0.5px]" style="font-weight: 200; font-size: 13px;">
              Estamos listos para asesorarte en equipo de alta especialidad.
            </div>
          </div>
          <a href={localizePath("/contacto", currentPathname)} class="w-full md:w-auto bg-[var(--color-primary)] text-white text-center px-4 py-2 rounded font-semibold">
            Contáctanos
          </a>
        </div>
      </div>

      <!-- MARCAS MOBILE -->
      <div x-data="{ marcasMobileOpen: false }">
        <button
          type="button"
          @click="marcasMobileOpen = !marcasMobileOpen"
          :class="marcasMobileOpen ? 'py-6 border-b border-[var(--color-primary)] flex items-center justify-between cursor-pointer text-[var(--color-primary)] w-full' : 'py-6 border-b border-[var(--color-gray-dark)] flex items-center justify-between cursor-pointer text-[#261819] w-full'"
          :aria-expanded="marcasMobileOpen.toString()"
          aria-controls="mobileMarcasPanel"
        >
          <span>Marcas</span>
          <svg class="w-4 h-4 ml-2" :class="{ 'rotate-180': marcasMobileOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div
          id="mobileMarcasPanel"
          x-cloak
          x-show="marcasMobileOpen"
          x-transition:enter="motion-enter motion-duration motion-ease-standard"
          x-transition:enter-start="motion-accordion-enter-start"
          x-transition:enter-end="motion-accordion-enter-end"
          x-transition:leave="motion-leave motion-duration motion-ease-standard"
          x-transition:leave-start="motion-accordion-leave-start"
          x-transition:leave-end="motion-accordion-leave-end"
          class="flex flex-wrap gap-4 w-full"
        >
          <div class="flex flex-wrap  justify-around  items-center gap-6 py-4">
            {marcasNavData.length > 0 ? (
              marcasNavData.map((marca) => (
                <a 
                  href={isUsableBrandSlug(marca.slug) ? `/nuestras-marcas/${marca.slug}` : "/productos"}
                  class="min-w-[140px] marcaLink flex items-center  justify-center gap-6  text-gray-700 transition-colors gap-6 p-6 md:py-8 md:px-6 hover:bg-[var(--color-secondary-light)] rounded-lg"
                  style={`order: ${Number.isFinite(Number(marca.displayOrder)) ? Number(marca.displayOrder) : 998};`} 
                >
                  <div class="flex items-center gap-3">
                    {/* Logo de la marca */}
                    {marca.logo?.url ? (
                      <img 
                        src={marca.logo.url} 
                        alt={`Logo de ${marca.name}`}
                        class="w-auto  max-w-[100px] max-h-[45px]  h-auto  object-contain"
                        loading="lazy"
                      />
                    ) : (
                      /* Fallback: ícono o placeholder si no hay logo */
                      <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                        </svg>
                      </div>
                    )}
                  </div>
                </a>
              ))
            ) : (
              <p class="text-center text-gray-500 p-4">Cargando marcas...</p>
            )} 
            <a href={`/nuestras-marcas`} style="order:999" class="marcaLink flex items-center justify-between gap-2 text-gray-700 transition-colors p-4 mt-2 hover:bg-[var(--color-secondary-light)] rounded-lg">
              <div class="flex items-center gap-3">
                <span class="cursor-pointer text-gray-700 font-medium">Ver más marcas</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
              </svg>
            </a>
          </div>
        </div>
      </div> 

      <!-- ESPECIALIDADES MOBILE -->
      <div class="especialidades-container" x-data="{ 
        especialidadesMobileOpen: false,
        vistaActual: 'lista-especialidades',
        activeAplicacion: null,
        activeItem: null,
        especialidadesData: [] 
      }" 
        x-effect="document.querySelectorAll('#mobileMenuLinks > *:not(.especialidades-container)').forEach(el => el.style.display = (vistaActual === 'catalogo-aplicaciones') ? 'none' : '')"
      
        data-especialidades={JSON.stringify(categoriesData || [])}
        x-init="(() => {
            try {
              especialidadesData = JSON.parse($el.dataset.especialidades || '[]');
            } catch (e) {
              console.error('Error parsing especialidades data:', e);
              especialidadesData = [];
            }
            <!-- console.log('Datos cargados (mobile):', especialidadesData); -->
          })()">
        
          <button type="button" x-show="vistaActual !== 'catalogo-aplicaciones'" @click="especialidadesMobileOpen = !especialidadesMobileOpen" 
              :class="especialidadesMobileOpen ? 'py-6 border-b flex items-center justify-between cursor-pointer text-[var(--color-primary)] w-full' : 'py-6 border-b border-[var(--color-gray-dark)] flex items-center justify-between cursor-pointer text-[#261819] w-full'"
              :aria-expanded="especialidadesMobileOpen.toString()"
              aria-controls="mobileEspecialidadesPanel">
              <span>Productos</span>
              <svg class="w-4 h-4 ml-2" :class="{ 'rotate-180': especialidadesMobileOpen && vistaActual === 'lista-especialidades' }" 
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
          </button>
        
        <div
          id="mobileEspecialidadesPanel"
          x-cloak
          x-show="especialidadesMobileOpen"
          x-transition:enter="motion-enter motion-duration motion-ease-standard"
          x-transition:enter-start="motion-accordion-enter-start"
          x-transition:enter-end="motion-accordion-enter-end"
          x-transition:leave="motion-leave motion-duration motion-ease-standard"
          x-transition:leave-start="motion-accordion-leave-start"
          x-transition:leave-end="motion-accordion-leave-end"
          class="w-full"
        >
          
          <!-- Vista de lista de especialidades -->
          <div x-show="vistaActual === 'lista-especialidades'" 
              x-transition:enter="motion-enter motion-duration motion-ease-emphasized"
              x-transition:enter-start="motion-list-enter-start"
              x-transition:enter-end="motion-list-enter-end"
              x-transition:leave="motion-leave motion-duration motion-ease-emphasized"
              x-transition:leave-start="motion-list-leave-start"
              x-transition:leave-end="motion-list-leave-end"
              class="grid grid-cols-1 gap-4 w-full pt-4">
            
            <!-- Template de especialidades -->
            <template x-for="especialidad in especialidadesData" :key="especialidad.id">
              <a href="#"
                @click.prevent="activeItem = especialidad.id; vistaActual = 'catalogo-aplicaciones'"
                :aria-label="`Abrir aplicaciones de ${especialidad.name}`"
                :class="activeItem === especialidad.id ? 'rounded-[4px]' : 'text-gray-700'"
                class="especialidadLink flex flex-row items-center justify-between gap-2 rounded text-[#261819] transition-colors min-w-[140px] group min-h-[80px] md:min-h-[120px] w-full px-4">
                
                <div class="flex items-center gap-2">
                  <img :src="especialidad.figure?.url" 
                      :alt="especialidad.name"
                      class="w-6 h-6 object-contain"
                  >
                  
                  <span class="bg-white bg-opacity-80 px-2 py-1 rounded cursor-pointer" 
                    x-text="especialidad.name">
                  </span>
                </div>
                
                <svg xmlns="http://www.w3.org/2000/svg" 
                    width="24" 
                    height="24" 
                    viewBox="0 0 24 24" 
                    fill="none">
                  <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                </svg>
              </a>
            </template>
            
            <!-- Ver más link -->
            <a href={localizePath("/especialidades", currentPathname)} 
              class="especialidadLink flex items-center gap-2 p-4 text-gray-700 transition-colors min-w-[140px] justify-between" 
              style="text-decoration: none!important;">
              <span class="cursor-pointer" style="text-decoration: none!important; color:oklch(37.3% 0.034 259.733);">Ver más</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
              </svg>
            </a>
          </div>
          
          <!-- Vista de catálogo de aplicaciones -->
                <div x-show="vistaActual === 'catalogo-aplicaciones'" 
                x-transition:enter="motion-enter motion-duration motion-ease-emphasized"
                x-transition:enter-start="motion-catalog-enter-start"
                x-transition:enter-end="motion-catalog-enter-end"
                x-transition:leave="motion-leave motion-duration motion-ease-emphasized"
                x-transition:leave-start="motion-catalog-leave-start"
                x-transition:leave-end="motion-catalog-leave-end"
                class="w-full bg-white pt-4">
            
            <!-- Botón Regresar -->
            <div :class="vistaActual !== 'catalogo-aplicaciones' ? 'mb-4 px-4' : ''">
              <button @click="
                vistaActual = 'lista-especialidades';
                activeItem = null;
                activeAplicacion = null;
              " 
                class="flex items-center gap-2 text-[#261819] transition-colors mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="transform rotate-180">
                  <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                </svg>
                <span class="font-medium">Regresar</span>
              </button>
              
              <!-- Contenedor dinámico para aplicaciones -->
              <div>
                <!-- Mostrar si hay aplicaciones -->
                <div x-show="activeItem && especialidadesData.find(e => e.id == activeItem)?.subcategories?.length > 0">
                  <div class="space-y-3">
                    <template x-for="aplicacion in especialidadesData.find(e => e.id == activeItem)?.subcategories || []" :key="aplicacion.id">
                      <a :href="especialidadesData.find(e => e.id == activeItem)?.slug && aplicacion?.slug ? `/especialidades/${especialidadesData.find(e => e.id == activeItem)?.slug}/${aplicacion.slug}` : '#'"
                          @click="activeAplicacion = aplicacion.id"
                          :aria-label="`Ver aplicación ${aplicacion.name || aplicacion.AplicacionClinica || 'clínica'}`"
                          :class="
                          activeAplicacion == aplicacion.id 
                            ? 'flex items-center justify-between p-3 bg-[var(--color-secondary-light)] rounded-lg' 
                            : 'flex items-center justify-between p-3 rounded-lg text-[#261819]'
                          ">
                        <div x-text="aplicacion.name || aplicacion.AplicacionClinica || 'Aplicación'"></div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                          <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                        </svg>
                      </a>
                    </template>
                  </div>
                  
                  <!-- Enlace para ver más -->
                  <a :href="especialidadesData.find(e => e.id == activeItem)?.slug ? `/especialidades/${especialidadesData.find(e => e.id == activeItem)?.slug}` : '#'" 
                      class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 text-[#261819] mt-4">
                    <div class="font-medium">Ver todas las aplicaciones</div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                      <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
                    </svg>
                  </a>
                </div>
                
                <!-- Mostrar si NO hay aplicaciones -->
                <div x-show="activeItem && (!especialidadesData.find(e => e.id == activeItem)?.subcategories || especialidadesData.find(e => e.id == activeItem)?.subcategories?.length === 0)">
                  <div class="text-center py-8 text-gray-500">
                    <p>No hay aplicaciones disponibles para esta especialidad.</p>
                      <a :href="especialidadesData.find(e => e.id == activeItem)?.slug ? `/especialidades/${especialidadesData.find(e => e.id == activeItem)?.slug}` : '#'" 
                        class="inline-block mt-4 text-[var(--color-primary)] font-medium hover:underline">
                      Ver especialidad
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      

      <!-- <a href="/especialidades" class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Especialidades</a> -->
      <!-- <a href={localizePath("/acerca-de-nosotros", currentPathname)} class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Acerca de nosotros</a> -->
      <!-- <a href={localizePath("/productos", currentPathname)} class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Productos</a> -->
      <a href={localizePath("/financiamiento", currentPathname)} class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Financiamiento</a>
      <!-- <a href="/servicio-tecnico" class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Servicio Técnico</a> -->
      <!-- <a href={localizePath("/blog", currentPathname)} class="py-6 text-[#261819] border-b border-[var(--color-gray-dark)] ">Blog</a> -->
      <a href={localizePath("/eventos", currentPathname)} class="py-6 text-[#261819]">Eventos</a>

      <!-- Pie del menú: al final del scroll (no sticky); token superficie oscura -->
      <div class="mobile-menu-footer">
        <a 
            href={`https://wa.me/${siteConfig?.whatsappNumber}`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="mobile-menu-footer__contact hover:opacity-90 flex flex-wrap items-center justify-center gap-1"
        >
            <img src="/temp/whatsIcon.png" alt="WhatsApp">
            <span>
              Servicio al cliente: 
              <span class="underline">
                  {siteConfig?.whatsappNumber ? `+${siteConfig.whatsappNumber.slice(0, 2)} ${siteConfig.whatsappNumber.slice(2, 4)} ${siteConfig.whatsappNumber.slice(4, 6)} ${siteConfig.whatsappNumber.slice(6, 8)} ${siteConfig.whatsappNumber.slice(8)}` : ''}
              </span>
            </span>
        </a>
        <a
          href={`mailto:${siteConfig?.email}`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="mobile-menu-footer__contact underline hover:opacity-90 mt-2 block text-center"
        >
            Correo electrónico: {siteConfig?.email}
        </a>
        {siteConfig?.businessHours  && (
          <p class="mobile-menu-footer__contact mt-2 text-center">
              {siteConfig?.businessHours}
          </p>
        )}
        <p class="mobile-menu-footer__social-head">Síguenos en todas nuestras redes:</p>
        <div class="mobile-menu-footer__icons">
          {siteConfig?.socialLink?.map((social) => (
            social.isActive && social.url ? (
              <a 
                key={social.id}
                href={social.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                aria-label={`MedRent en ${social.name}`}
                class="hover:opacity-80 transition-opacity duration-300"
              >
                <div set:html={getSocialIcon(social.icon, 'navbar')}></div>
              </a>
            ) : null
          ))}
        </div>
      </div>
    </div>
  </div>
  </div>
</nav>


<style>
  [x-cloak] {
    display: none !important;
  }

  :root {
    --motion-duration-short: 280ms;
    --motion-distance-sm: 12px;
    --motion-ease-standard: cubic-bezier(0.2, 0, 0, 1);
    --motion-ease-emphasized: cubic-bezier(0.2, 0, 0, 1);
  }

  .motion-enter,
  .motion-leave {
    transition-property: opacity, transform;
    will-change: opacity, transform;
  }

  .motion-duration {
    transition-duration: var(--motion-duration-short);
  }

  .motion-ease-standard {
    transition-timing-function: var(--motion-ease-standard);
  }

  .motion-ease-emphasized {
    transition-timing-function: var(--motion-ease-emphasized);
  }

  .motion-overlay-enter-start,
  .motion-overlay-leave-end {
    opacity: 0;
    transform: translateY(calc(-1 * var(--motion-distance-sm)));
  }

  .motion-overlay-enter-end,
  .motion-overlay-leave-start {
    opacity: 1;
    transform: translateY(0);
  }

  .motion-panel-enter-start,
  .motion-panel-leave-end {
    opacity: 1;
    transform: translateX(-28px);
  }

  .motion-panel-enter-end,
  .motion-panel-leave-start {
    opacity: 1;
    transform: translateX(0);
  }

  .motion-accordion-enter-start,
  .motion-accordion-leave-end {
    opacity: 0;
    transform: translateY(calc(-1 * var(--motion-distance-sm)));
  }

  .motion-accordion-enter-end,
  .motion-accordion-leave-start {
    opacity: 1;
    transform: translateY(0);
  }

  .motion-list-enter-start,
  .motion-list-leave-end {
    opacity: 0;
    transform: translateX(calc(-1 * var(--motion-distance-sm)));
  }

  .motion-list-enter-end,
  .motion-list-leave-start {
    opacity: 1;
    transform: translateX(0);
  }

  .motion-catalog-enter-start,
  .motion-catalog-leave-end {
    opacity: 0;
    transform: translateX(var(--motion-distance-sm));
  }

  .motion-catalog-enter-end,
  .motion-catalog-leave-start {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-enter,
    .motion-leave,
    #mobileMenuLinks {
      transition-duration: 1ms !important;
      animation-duration: 1ms !important;
      transition-delay: 0ms !important;
      animation-delay: 0ms !important;
    }
  }

  /* Pie menú móvil — Figma: 236px alto, 16px padding, superficie oscura sistema */
  .mobile-menu-footer {
    box-sizing: border-box;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 236px;
    /* Bleed al ancho del scroll: debe coincidir con px-4 / md:px-8 / xl:px-10 del contenedor */
    width: calc(100% + 2rem);
    max-width: none;
    margin-left: -1rem;
    margin-right: -1rem;
    margin-top: 1.5rem;
    padding: 16px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    background: var(--gradient-surface-dark);
    color: var(--color-white);
  }

  @media (min-width: 768px) {
    .mobile-menu-footer {
      width: calc(100% + 4rem);
      margin-left: -2rem;
      margin-right: -2rem;
    }
  }

  @media (min-width: 1280px) {
    .mobile-menu-footer {
      width: calc(100% + 5rem);
      margin-left: -2.5rem;
      margin-right: -2.5rem;
    }
  }

  .mobile-menu-footer__contact {
    font-size: 11px;
    letter-spacing: 0.5px;
    font-weight: 300;
    line-height: 1.45;
    color: var(--color-white);
    text-decoration: none;
  }

  .mobile-menu-footer__social-head {
    margin: 0;
    margin-top: 1rem;
    font-size: 11px;
    letter-spacing: 0.5px;
    font-weight: 700;
    text-align: center;
    line-height: 1.4;
  }

  .mobile-menu-footer__icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.15s ease-out;
  }
  #mobileMenuLinks {
    min-height: 0;
    max-height: calc(100dvh - 56px);
    overflow-y: auto !important;
    overflow-x: hidden;
    overscroll-behavior-y: contain;
    touch-action: pan-y;
    transform: translateZ(0);
    -webkit-overflow-scrolling: touch;
  }

  :global(html.mobile-menu-open),
  :global(body.mobile-menu-open) {
    overflow: hidden !important;
    overscroll-behavior: none;
  }
  .overflow-y-auto::-webkit-scrollbar {
    width: 4px;
  }
  .overflow-y-auto::-webkit-scrollbar-track {
    background: var(--color-secondary);
    border-radius: 2px;
  }
  .overflow-y-auto::-webkit-scrollbar-thumb {
    background: var(--color-secondary);
    border-radius: 2px;
  }
  .overflow-y-auto::-webkit-scrollbar-thumb:hover {
    background: var(--color-secondary) !important;
  }
  .marcasContainer {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) rgba(0, 103, 100, 0.18) !important;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .marcasContainer::-webkit-scrollbar {
    width: 8px;
  }
  .marcasContainer::-webkit-scrollbar-track {
    background: rgba(0, 103, 100, 0.18);
    border-radius: 999px;
  }
  .marcasContainer::-webkit-scrollbar-thumb {
    background-color: var(--color-primary);
    border-radius: 999px;
  }
  .marcaLink.active,
  .marcaLink:active,
  .marcaLink:focus {
    background: #edf2f0 !important;
    border-radius: 4px !important;
    color: var(--color-primary) !important;
  }
</style>
