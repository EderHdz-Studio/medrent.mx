            <!-- Botón cerrar -->
            <button @click="open = false" class="bg-white rounded-[4px] p-1">
              <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
           
          <!-- Enlaces -->
          <div class="flex-1 px-4 py-6 flex flex-col gap-6 overflow-auto" id="mobileMenuLinks">

            <div class="bg-white rounded-lg">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <div class="mb-4 md:mb-0">
                  <div class="font-bold text-base leading-6 tracking-[0.5px]" style="font-weight: 700;">
                    Hablemos de innovación médica
                  </div>
                  <div class="font-normal text-base leading-6 tracking-[0.5px]" style="font-weight: 200; font-size: 13px;">
                    Estamos listos para asesorarte en equipo de alta especialidad.
                  </div>
                </div>
                <a href="/contacto" class="w-full md:w-auto bg-[#B60D45] text-white text-center px-4 py-2 rounded font-semibold">
                  Contáctanos
                </a>
              </div>
            </div>

            <a href="/acerca-de-nosotros" class="py-6 text-[#261819] border-b border-[#8E6F73]">Acerca de nosotros</a>
            
            <!-- Especialidades -->
            <div class="especialidades-container" x-data="{ 
              especialidadesMobileOpen: false,
              vistaActual: 'lista-especialidades',
              activeAplicacion: null,
              activeItem: null,
              especialidadesData: [] 
            }" 
              x-effect="document.querySelectorAll('#mobileMenuLinks > *:not(.especialidades-container)').forEach(el => el.style.display = (vistaActual === 'catalogo-aplicaciones') ? 'none' : '')"
            
              data-especialidades={JSON.stringify(especialidades || [])}
              x-init="(() => {
                  try {
                    especialidadesData = JSON.parse($el.dataset.especialidades || '[]');
                  } catch (e) {
                    console.error('Error parsing especialidades data:', e);
                    especialidadesData = [];
                  }
                  <!-- console.log('Datos cargados (mobile):', especialidadesData); -->
                })()">

              
                <a x-show="vistaActual !== 'catalogo-aplicaciones'" @click="especialidadesMobileOpen = !especialidadesMobileOpen" 
                    :class="especialidadesMobileOpen ? 'py-6 border-b border-[var(--color-primary)] flex items-center justify-between cursor-pointer text-[var(--color-primary)]' : 'py-6 border-b border-[#8E6F73] flex items-center justify-between cursor-pointer text-[#261819]'">
                    <span>Especialidades</span>
                    <svg class="w-4 h-4 ml-2" :class="{ 'rotate-180': especialidadesMobileOpen && vistaActual === 'lista-especialidades' }" 
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </a>
              
              <div x-show="especialidadesMobileOpen" x-transition class="relative w-full" style="position: relative; min-height: 300px;">
                
                <!-- Vista de lista de especialidades -->
                <div x-show="vistaActual === 'lista-especialidades'" 
                      x-transition:enter="transition ease-out duration-300"
                      x-transition:enter-start="opacity-100 transform translate-x-0"
                      x-transition:enter-end="opacity-100 transform translate-x-0"
                      x-transition:leave="transition ease-in duration-200"
                      x-transition:leave-start="opacity-100 transform translate-x-0"
                      x-transition:leave-end="opacity-0 transform -translate-x-full"
                      class="grid grid-cols-1 gap-4 w-full pt-4">

                  
                  {especialidades?.map((especialidad) => (
                     <a
                      href="#"
                      @click.prevent={`activeItem = ${especialidad.id}; vistaActual = 'catalogo-aplicaciones';`}
                      :class={`activeItem === ${especialidad.id} 
                      ? 'bg-[#FFF8F7] text-[var(--color-primary)] rounded-[4px]' 
                      : 'bg-[#FFF] text-gray-700'`}
                      class="especialidadLink flex flex-row items-center hover:text-[var(--color-primary)] justify-between gap-2 rounded hover:bg-[#FFF8F7] text-[#261819] transition-colors min-w-[140px] group min-h-[80px] md:min-h-[120px] w-full px-4">
                        <!-- SVG + Texto juntos -->
                        <div class="flex items-center gap-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M12 2C6.5 2 2 6.5 2 12C2 17.5 6.5 22 12 22C17.5 22 22 17.5 22 12C22 6.5 17.5 2 12 2ZM17 12C17 14.8 14.8 17 12 17C9.2 17 7 14.8 7 12C7 9.2 9.2 7 12 7C14.8 7 17 9.2 17 12Z" fill="currentColor"/>
                          </svg>

                          <label class="bg-white bg-opacity-80 px-2 py-1 rounded group-hover:text-[var(--color-primary)] cursor-pointer">{especialidad.Nombre}</label>
                        </div>

                        <!-- SVG derecho -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                          <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                        </svg>
                    </a>
                  ))}
                  
                  <a href="/especialidades" 
                     class="especialidadLink flex items-center gap-2 p-4 text-gray-700 transition-colors min-w-[140px] justify-between" 
                     style="text-decoration: none!important;">
                    <label class="cursor-pointer" style="text-decoration: none!important; color:oklch(37.3% 0.034 259.733);">Ver más</label>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
                    </svg>
                  </a>
                </div>
                
                <!-- Vista de catálogo de aplicaciones - SIMPLIFICADA -->
                     <div x-show="vistaActual === 'catalogo-aplicaciones'" 
                     x-transition:enter="transition ease-out duration-300"
                     x-transition:enter-start="opacity-0 transform translate-x-full"
                     x-transition:enter-end="opacity-100 transform translate-x-0"
                     x-transition:leave="transition ease-in duration-200"
                     x-transition:leave-start="opacity-100 transform translate-x-0"
                     x-transition:leave-end="opacity-0 transform translate-x-full"
                     class="absolute top-0 left-0 w-full bg-white pt-4" 
                     style="position: absolute; top: 0; left: 0; height: 100%;">
                  
                  <!-- Botón Regresar -->
                  <div :class="vistaActual !== 'catalogo-aplicaciones' ? 'mb-4 px-4' : ''">
                    <button @click="
                      vistaActual = 'lista-especialidades';
                      document.getElementById('mobileMenuLinks').style.transform = 'translateX(0)';
                      activeItem = null;
                      activeAplicacion = null;
                    " 
                      class="flex items-center gap-2 text-[#261819] transition-colors mb-3">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="transform rotate-180">
                        <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                      </svg>
                      <span class="font-medium">Regresar</span>
                    </button>
                    
                    <!-- Contenedor dinámico para aplicaciones -->
                    <div>
                      <!-- Mostrar si hay aplicaciones -->
                      <div x-show="activeItem && especialidadesData.find(e => e.id == activeItem)?.CatalogoAplicaciones?.length > 0">
                        <div class="space-y-3">
                          <template x-for="aplicacion in especialidadesData.find(e => e.id == activeItem)?.CatalogoAplicaciones || []" :key="aplicacion.id">
                            <a :href="`/especialidades/${especialidadesData.find(e => e.id == activeItem)?.Path || ''}/${aplicacion.Slug}`"
                               @click="activeAplicacion = aplicacion.id"
                               :class="
                                activeAplicacion == aplicacion.id 
                                  ? 'flex items-center justify-between p-3 rounded-lg bg-[#FFF8F7] text-[var(--color-primary)]' 
                                  : 'flex items-center justify-between p-3 rounded-lg text-[#261819]'
                                ">
                              <div x-text="aplicacion.AplicacionClinica || 'Aplicación'"></div>
                              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <path d="M8 19V5L19 12L8 19Z" fill="currentColor"/>
                              </svg>
                            </a>
                          </template>
                        </div>
                        
                        <!-- Enlace para ver más -->
                        <a :href="`/especialidades/${especialidadesData.find(e => e.id == activeItem)?.Path || ''}`" 
                           class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 text-[#261819] mt-4">
                          <div class="font-medium">Ver todas las aplicaciones</div>
                          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
                          </svg>
                        </a>
                      </div>
                      
                      <!-- Mostrar si NO hay aplicaciones -->
                      <div x-show="activeItem && (!especialidadesData.find(e => e.id == activeItem)?.CatalogoAplicaciones || especialidadesData.find(e => e.id == activeItem)?.CatalogoAplicaciones?.length === 0)">
                        <div class="text-center py-8 text-gray-500">
                          <p>No hay aplicaciones disponibles para esta especialidad.</p>
                            <a :href="`/especialidades/${especialidadesData.find(e => e.id == activeItem)?.Path || ''}`" 
                              class="inline-block mt-4 text-[var(--color-primary)] font-medium hover:underline">
                            Ver especialidad
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            

            <!-- Marcas diseño anterior con imágenes - no borrar para usarlo en otras implementaciones -->
