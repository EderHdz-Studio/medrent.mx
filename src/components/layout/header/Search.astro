---
const marcas = Astro.props.marcas || [];
const categorias = Astro.props.categorias || [];
const subcategorias = Astro.props.subcategorias || [];
const products = Astro.props.products || [];
const articles = Astro.props.articles || [];
const currentPathname = Astro.originPathname ?? Astro.url.pathname;
const localePrefix = currentPathname === "/co" || currentPathname.startsWith("/co/") ? "/co" : "";

---

<div class="inline flex" style="display: flex;">
  <button id="searchButtonDesktop" type="button" class="cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M21.707 20.293L17.168 15.754C18.5148 14.0465 19.1584 11.8888 18.9669 9.72244C18.7755 7.55607 17.7635 5.54473 16.138 4.09988C14.5125 2.65502 12.3964 1.88587 10.2225 1.94976C8.04868 2.01365 5.98137 2.90576 4.44355 4.44358C2.90573 5.9814 2.01362 8.04871 1.94973 10.2226C1.88584 12.3964 2.65499 14.5126 4.09984 16.1381C5.5447 17.7635 7.55604 18.7755 9.72241 18.967C11.8888 19.1584 14.0464 18.5149 15.754 17.168L20.293 21.707L21.707 20.293ZM10.5 17C9.21438 17 7.95767 16.6188 6.88875 15.9045C5.81983 15.1903 4.98671 14.1751 4.49474 12.9874C4.00277 11.7997 3.87405 10.4928 4.12485 9.2319C4.37565 7.97102 4.99472 6.81283 5.90376 5.90379C6.8128 4.99475 7.97099 4.37568 9.23187 4.12488C10.4927 3.87408 11.7997 4.0028 12.9874 4.49477C14.1751 4.98674 15.1903 5.81986 15.9045 6.88878C16.6187 7.9577 17 9.21441 17 10.5C16.9978 12.2232 16.3123 13.8753 15.0938 15.0938C13.8753 16.3124 12.2232 16.9979 10.5 17Z" fill="#171D1C"/>
    </svg>
  </button>

  <div
    id="searchOverlay"
    class="fixed inset-0 z-[200] flex items-start justify-center bg-black/50 backdrop-blur-sm transition-all duration-300 hidden p-2 rounded px-4 py-2 lg:px-2 lg:py-2"
    tabindex="-1"
    aria-hidden="true"
  >
    <div id="searchContainer" class="search-container relative w-full  flex flex-col items-center bg-white border border-gray-200 rounded-lg z-[210] p-0 max-h-[90vh] " 
    >
      <input
        id="searchInput"
        type="text"
        autocomplete="off"
        placeholder="Buscar en Medrent"
        class="w-full px-6 py-2 rounded-sm border border-gray-300  focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)] text-lg bg-white"
      />
      <button
        id="searchClose"
        class="absolute right-[19px] text-gray-500 hover:text-gray-800 text-4xl cursor-pointer"
        style="top: 0;"
        tabindex="0"
      >
        &times;
      </button>
      <div
        id="searchResults"
        data-lenis-prevent
        class="w-full overflow-y-auto flex-1 max-h-[60vh] hidden p-2"
        style=""
      ></div>
    </div>
  </div>
</div>

<style>
    #searchInput{ font-size: 16px; }
    #searchContainer{ 
        max-width: 925px; 
        font-size: 16px; 
    }
    @media (min-width: 1300px) {
        #searchContainer{ width: 71%; }
    }
    @media (min-width: 1250px) and  (max-width: 1299px) {
        #searchContainer{ width: 74%; }
    }
    @media (min-width: 1100px) and (max-width: 1249px) {
        #searchContainer{ width: 72%; }
    }
    @media (min-width: 1000px) and (max-width: 1099px) {
        #searchContainer{ width: 70%; left: 5px!important; }
    }
    /* Desktop */
    @media (min-width: 1024px) {
        #searchContainer{
            top: 45px;
            left: 13px;
            max-height: 420px;  
        }
    }
    /* Mobile */
    @media (max-width: 1023px) {
        #searchContainer{
            top: 58px;
            left: 0;
            max-height: 620px;  
        }
    }
</style>

<script define:vars={{ marcas, categorias, subcategorias, products, articles, localePrefix }}>

const searchBtn = document.getElementById('searchButtonDesktop');
const overlay = document.getElementById('searchOverlay');
const input = document.getElementById('searchInput');
const closeBtn = document.getElementById('searchClose');
const results = document.getElementById('searchResults');

function openSearch() {
  overlay.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  if (window.lenis && typeof window.lenis.stop === 'function') window.lenis.stop();
  if (window.showBlurOverlay) window.showBlurOverlay();
  setTimeout(() => input.focus(), 50);
}

function closeSearch() {
  overlay.classList.add('hidden');
  document.body.style.overflow = '';
  if (window.lenis && typeof window.lenis.start === 'function') window.lenis.start();
  input.value = '';
  results.innerHTML = '';
  results.classList.add('hidden');
  if (window.hideBlurOverlay) window.hideBlurOverlay();
  // Restaurar estado visual inicial
  const searchContainer = document.getElementById('searchContainer');
  if (searchContainer) {
    searchContainer.style.borderRadius = '4px';
    searchContainer.style.border = '0';
    searchContainer.style.boxShadow = '';
  }
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.style.border = '';
    searchInput.style.outline = '';
    searchInput.style.boxShadow = '';
    searchInput.classList.add('focus:outline-none', 'focus:ring-1', 'focus:ring-[var(--color-primary)]');
  }
}


searchBtn?.addEventListener('click', openSearch);
closeBtn?.addEventListener('click', closeSearch);

// Cerrar buscador al hacer click fuera del panel
overlay?.addEventListener('mousedown', (e) => {
  if (e.target === overlay) closeSearch();
});

// Cerrar buscador con tecla ESC
document.addEventListener('keydown', (e) => {
  if (!overlay.classList.contains('hidden') && e.key === 'Escape') {
    closeSearch();
  }
});


input?.addEventListener('input', () => {
  const q = input.value.trim().toLowerCase();
  let html = '';
    const sub = subcategorias.filter(e =>
    e.name.toLowerCase().includes(q)
  );
  const esp = categorias.filter(e =>
    e.name.toLowerCase().includes(q)
  );
  const mar = marcas.filter(m =>
    m.name.toLowerCase().includes(q)
  );
const prod = products.filter(p =>
    p.name.toLowerCase().includes(q)
  );
const art = articles.filter(a =>
    a.title.toLowerCase().includes(q)
  );
  const mainContent = document.getElementById('contenido-principal');
  const searchContainer = document.getElementById('searchContainer');
  const searchInput = document.getElementById('searchInput');

  // Si el input está vacío, restaurar estado inicial
  if (!q) {
    results.classList.add('hidden');
    if (mainContent) mainContent.classList.remove('backdrop-blur-sm');
    if (searchContainer) {
      searchContainer.style.borderRadius = '4px';
      searchContainer.style.border = '0';
      searchContainer.style.boxShadow = '';
    }
    if (searchInput) {
      searchInput.style.border = '';
      searchInput.style.outline = '';
      searchInput.style.boxShadow = '';
      searchInput.classList.add('focus:outline-none', 'focus:ring-1', 'focus:ring-[var(--color-primary)]');
    }
    return;
  }
    const icon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
    <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="#171D1C"/>
    </svg>`;

  if (esp.length || mar.length || sub.length || prod.length || art.length) {
    if (prod.length) {
      html += `
        <div>
          <div class=" text-[11px] text-[var(--color-primary)] font-semibold uppercase ">
            Productos
          </div>
          ${prod.map(p => `
            <a
              href="${localePrefix}/productos/${p.slug}"
              class="block px-6 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] transition-colors text-[14px] flex flex-row justify-between items-center mt-2"
            >
              ${p.name}
              ${icon}
            </a>
          `).join('')}
        </div>
      `;
    }

    if (esp.length) {
      html += `
        <div>
          <div class=" text-[11px] text-[var(--color-primary)] font-semibold uppercase mt-2">
            Especialidades
          </div>
          ${esp.map(e => `
            <a
              href="${localePrefix}/especialidades/${e.slug}"
              class="block px-6 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] transition-colors text-[14px] flex flex-row justify-between items-center mt-2"
            >
              ${e.name}
              ${icon}
            </a>
          `).join('')}
        </div>
      `;
    }
     if (sub.length) {
      html += `
        <div>
          <div class=" text-[11px] text-[var(--color-primary)]  font-semibold uppercase mt-2">
            Aplicaciones
          </div>
          ${sub.map(s => `
            <a
              href="${localePrefix}/especialidades/${s.category.slug}/${s.slug}"
              class="block px-6 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] transition-colors text-[14px] flex flex-row justify-between items-center mt-2"
            >
              ${s.name}
                ${icon}
            </a>
          `).join('')}
        </div>
      `;
    }
    if (mar.length) {
      html += `
        <div>
          <div class=" text-[11px] text-[var(--color-primary)]  font-semibold uppercase mt-2">
            Marcas
          </div>
          ${mar.map(m => `
            <a
              href="${m.slug && m.slug !== 'undefined' && m.slug !== 'null' ? `${localePrefix}/nuestras-marcas/${m.slug}` : `${localePrefix}/productos`}"
              class="block px-6 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] transition-colors text-[14px] flex flex-row justify-between items-center mt-2"
            >
              ${m.name}
                ${icon}
            </a>
          `).join('')}
        </div>
      `;
    }
    if (art.length) {
      html += `
        <div>
          <div class=" text-[11px] text-[var(--color-primary)]  font-semibold uppercase mt-2">
            Artículos
          </div>
          ${art.map(a => `
            <a
              href="${localePrefix}/blog/${a.slug}"
              class="block px-6 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] transition-colors text-[14px] flex flex-row justify-between items-center mt-2"
            >
              ${a.title}
                ${icon}
            </a>
          `).join('')}
        </div>
      `;
    }


    results.innerHTML = html;
    results.classList.remove('hidden');
    if (mainContent) mainContent.classList.add('backdrop-blur-sm');
    if (searchContainer) {
      searchContainer.style.borderRadius = '4px';
      searchContainer.style.border = '2px solid var(--color-primary)';
      searchContainer.style.boxShadow = 'rgba(0, 0, 0, 0.35) 0px 5px 15px';
    }
    if (searchInput) {
      searchInput.style.border = '0';
      searchInput.style.outline = 'unset';
      searchInput.style.boxShadow = 'unset';
      searchInput.classList.remove('focus:outline-none', 'focus:ring-1', 'focus:ring-[var(--color-primary)]');
    }
  } else {
    // Blur ya se activa al abrir
    results.innerHTML =
      '<div class="px-4 py-3 text-gray-400 text-sm">Sin resultados</div>';
    results.classList.remove('hidden');
    if (mainContent) mainContent.classList.add('backdrop-blur-sm');
    if (searchContainer) {
      searchContainer.style.borderRadius = '4px';
      searchContainer.style.border = '2px solid var(--color-primary)';
      searchContainer.style.boxShadow = 'rgba(0, 0, 0, 0.35) 0px 5px 15px';
    }
    if (searchInput) {
      searchInput.style.border = '0';
      searchInput.style.outline = 'unset';
      searchInput.style.boxShadow = 'unset';
      searchInput.classList.remove('focus:outline-none', 'focus:ring-1', 'focus:ring-[var(--color-primary)]');
    }
  }
  

});

</script>
