---
const { site } = Astro.props;
import { getSiteConfig } from "@server/siteConfig";
const siteConfig = await getSiteConfig();

const getSocialIcon = (icon, scope = "") => {
    const key = (icon ?? '').toString().trim().toLowerCase();
    const svg = site.socialMediaIcons[key] ?? '';

    if (key !== 'instagram' || !svg || !scope) return svg;

    const suffix = `_${scope}`;
    return svg
        .replaceAll('paint0_radial_2940_10993', `paint0_radial_2940_10993${suffix}`)
        .replaceAll('paint1_radial_2940_10993', `paint1_radial_2940_10993${suffix}`)
        .replaceAll('url(#paint0_radial_2940_10993)', `url(#paint0_radial_2940_10993${suffix})`)
        .replaceAll('url(#paint1_radial_2940_10993)', `url(#paint1_radial_2940_10993${suffix})`);
};

---
<!-- Upperbar -->
<div class="sticky hidden lg:block text-white text-[11px] tracking-[0.5px] font-light" style="background: var(--gradient-surface-dark);">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-8 py-2">

        <div class="flex items-center gap-2">
            <div set:html={site.socialMediaIcons.whatsapp ?? ''} ></div>
            <a 
                href={`https://wa.me/${siteConfig?.whatsappNumber || ''}`.replace(/\s/g, '')} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:text-white text-white text-[11px] tracking-[0.5px] font-light"
            >
                Servicio al cliente: <span class="underline">+{siteConfig?.whatsappNumber || ''}</span>
            </a> |
            <a href="mailto:{siteConfig?.email || ''}" target="_blank" rel="noopener noreferrer" class="hover:text-white text-white text-[11px] tracking-[0.5px] font-light underline">
                {siteConfig?.email || ""}
            </a>
            {siteConfig?.businessHours  && (
                <>
                    |
                    <span class="hover:text-white text-white text-[11px] tracking-[0.5px] font-light">
                        Horario de atención:
                    </span>
                </>
            )}
        </div>
        
        <div class="flex items-center gap-2">
            <span class="font-lato text-xs">Síguenos en todas nuestras redes:</span>
            
            {siteConfig?.socialLink?.map((social) => (
                social.isActive && social.url ? (
                    <a 
                        href={social.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        aria-label={`MedRent en ${social.name}`}
                        class="hover:opacity-80 transition-opacity duration-300"
                    >
                        <div set:html={getSocialIcon(social.icon, 'upperbar')}></div>
                    </a>
                ) : null
            ))}
        </div>
    </div>
</div>
