---
// src/components/forms/BaseForm.astro
const {
  id,
  class: className = "",
  successTitle = "Gracias por tu interés.",
  successText = "Hemos recibido tu solicitud y uno de nuestros especialistas se pondrá en contacto contigo en breve para orientarte según tus necesidades clínicas.",
  errorTitle = "No fue posible enviar la solicitud",
  errorText = "Estamos teniendo un inconveniente temporal.",
  type = "default"
} = Astro.props;
---

<div id={`${id}-wrapper`} class="form-wrapper relative">

  <input type="hidden" name="formType" value={type} />



  <!-- FORM -->
  <div class="form-container">

    
 {type === "newsletter" && (
   <div class="flex flex-col items-start gap-4 flex-1 self-stretch mb-10" >
      <h2 id="event-popup-newsletter" class="text-[#261819] text-[28px] font-bold text-center w-full">
          ¡Suscríbete al newsletter de Medrent!
      </h2>
      
      <p id="event-popup-description-newsletter" class="text-[#261819] text-[16px] text-base text-center font-normal leading-6 tracking-[0.5px]">
          Recibe en tu correo las últimas novedades en tecnología médica, consejos especializados y actualizaciones exclusivas sobre nuestras soluciones.
      </p>
  </div>
  )}

    <form id={id} class={className}>
      <slot />
    </form>
  </div>

  <!-- SUCCESS -->
  <div class="form-success hidden">
    <div class="bg-[var(--color-secondary-light)] rounded-3xl pt-8 pr-6 pb-8 pl-6 text-center flex flex-col items-center gap-4">
      {type !== "newsletter" && type !== "blog" ? (
        <svg xmlns="http://www.w3.org/2000/svg" width="104" height="104" viewBox="0 0 104 104" fill="none">
          <path d="M91 52C91 73.541 73.541 91 52 91C30.459 91 13 73.541 13 52C13 30.459 30.459 13 52 13C73.541 13 91 30.459 91 52Z" stroke="var(--color-primary)" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M39 55.25L48.75 65L65 42.25" stroke="var(--color-primary)" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
       ):(
        <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">
          <path d="M57.015 30.4849C57.3404 30.813 57.7275 31.0733 58.154 31.251C58.5805 31.4287 59.038 31.5202 59.5 31.5202C59.962 31.5202 60.4195 31.4287 60.846 31.251C61.2725 31.0733 61.6596 30.813 61.985 30.4849L75.985 16.4849C76.6441 15.8259 77.0143 14.932 77.0143 13.9999C77.0143 13.0679 76.6441 12.174 75.985 11.5149C75.3259 10.8559 74.4321 10.4856 73.5 10.4856C72.5679 10.4856 71.6741 10.8559 71.015 11.5149L59.5 23.0649L54.985 18.5149C54.6587 18.1886 54.2713 17.9297 53.8449 17.7531C53.4185 17.5765 52.9615 17.4856 52.5 17.4856C51.5679 17.4856 50.6741 17.8559 50.015 18.5149C49.6887 18.8413 49.4298 19.2287 49.2532 19.655C49.0766 20.0814 48.9857 20.5384 48.9857 20.9999C48.9857 21.932 49.3559 22.8259 50.015 23.4849L57.015 30.4849ZM73.5 27.9999C72.5717 27.9999 71.6815 28.3687 71.0251 29.025C70.3687 29.6814 70 30.5717 70 31.4999V62.9999C70 63.9282 69.6313 64.8184 68.9749 65.4748C68.3185 66.1312 67.4283 66.4999 66.5 66.4999H17.5C16.5717 66.4999 15.6815 66.1312 15.0251 65.4748C14.3687 64.8184 14 63.9282 14 62.9999V29.4349L34.58 50.0499C36.5444 51.9982 39.1983 53.0925 41.965 53.0949C44.8013 53.0803 47.5175 51.9486 49.525 49.9449L55.545 43.9249C56.2041 43.2659 56.5743 42.372 56.5743 41.4399C56.5743 40.5079 56.2041 39.614 55.545 38.9549C54.8859 38.2959 53.9921 37.9256 53.06 37.9256C52.1279 37.9256 51.2341 38.2959 50.575 38.9549L44.45 45.0799C43.7957 45.7212 42.9161 46.0804 42 46.0804C41.0839 46.0804 40.2043 45.7212 39.55 45.0799L18.935 24.4999H38.5C39.4283 24.4999 40.3185 24.1312 40.9749 23.4748C41.6312 22.8184 42 21.9282 42 20.9999C42 20.0717 41.6312 19.1814 40.9749 18.525C40.3185 17.8687 39.4283 17.4999 38.5 17.4999H17.5C14.7152 17.4999 12.0445 18.6062 10.0754 20.5753C8.10625 22.5444 7 25.2151 7 27.9999V62.9999C7 65.7847 8.10625 68.4554 10.0754 70.4245C12.0445 72.3937 14.7152 73.4999 17.5 73.4999H66.5C69.2848 73.4999 71.9555 72.3937 73.9246 70.4245C75.8938 68.4554 77 65.7847 77 62.9999V31.4999C77 30.5717 76.6313 29.6814 75.9749 29.025C75.3185 28.3687 74.4283 27.9999 73.5 27.9999Z" fill="#006764"/>
        </svg>
       )}

      <div class="flex flex-col items-center gap-2">
        {!["newsletter", "blog"].includes(type) && (
          <h3 class="uppercase text-base font-medium text-[var(--color-primary)]">SOLICITUD ENVIADA</h3>
        )}
        <h2 class="text-xl font-semibold text-[24px] font-bold successTitle">{successTitle}</h2>
        <p class="successText">{successText}</p>
        {!["newsletter", "blog"].includes(type) && (
          <p class="text-gray-600 mt-2">
            Mientras tanto, puedes explorar más productos o especialidades en <a href="/productos" class="text-[var(--color-primary)] underline cursor-pointer">nuestro catálogo.</a>
          </p>
         )}
      </div>
    </div>
  </div>

  <!-- ERROR -->
  <div class="form-error hidden">
    <div class="bg-[#FFF8F7] rounded-3xl pt-12 pr-6 pb-8 pl-6 text-center flex flex-col items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">
        <path d="M61.25 46.41C65.3036 46.4434 69.243 45.0686 72.3956 42.5202C75.5481 39.9719 77.7182 36.4082 78.5352 32.4377C79.3522 28.4671 78.7655 24.3361 76.8752 20.7502C74.9849 17.1642 71.9083 14.3456 68.1709 12.7759C64.4334 11.2062 60.267 10.9826 56.383 12.1434C52.4991 13.3043 49.1386 15.7774 46.8755 19.1406C44.6123 22.5037 43.587 26.5482 43.9744 30.5834C44.3619 34.6185 46.1382 38.394 49 41.265C52.2482 44.5237 56.6491 46.3721 61.25 46.41ZM68.67 36.33C67.1363 37.8515 65.1705 38.8628 63.0409 39.2261C60.9113 39.5894 58.7214 39.287 56.77 38.36L70.77 24.36C71.7042 26.3267 72.004 28.5351 71.6277 30.6797C71.2515 32.8242 70.2179 34.7988 68.67 36.33ZM53.83 21.49C55.7972 19.5203 58.4662 18.4124 61.25 18.41C62.8026 18.4245 64.3327 18.7831 65.73 19.46L51.73 33.46C50.7958 31.4933 50.496 29.2848 50.8723 27.1403C51.2485 24.9958 52.2821 23.0212 53.83 21.49ZM71.75 49.91C70.8217 49.91 69.9315 50.2787 69.2751 50.9351C68.6188 51.5915 68.25 52.4817 68.25 53.41V67.41C68.25 68.3383 67.8813 69.2285 67.2249 69.8849C66.5685 70.5412 65.6783 70.91 64.75 70.91H15.75C14.8217 70.91 13.9315 70.5412 13.2751 69.8849C12.6187 69.2285 12.25 68.3383 12.25 67.41V33.845L32.83 54.425C34.7887 56.3861 37.4433 57.4933 40.215 57.505C41.6244 57.5087 43.0201 57.2286 44.3189 56.6814C45.6178 56.1342 46.7931 55.3311 47.775 54.32C48.4058 53.6674 48.7585 52.7952 48.7585 51.8875C48.7585 50.9798 48.4058 50.1076 47.775 49.455C47.449 49.1216 47.0598 48.8568 46.63 48.6759C46.2003 48.4951 45.7387 48.4019 45.2725 48.4019C44.8063 48.4019 44.3447 48.4951 43.915 48.6759C43.4852 48.8568 43.096 49.1216 42.77 49.455C42.1158 50.0963 41.2361 50.4555 40.32 50.4555C39.4039 50.4555 38.5243 50.0963 37.87 49.455L17.185 28.91H33.25C34.1783 28.91 35.0685 28.5412 35.7249 27.8849C36.3813 27.2285 36.75 26.3383 36.75 25.41C36.75 24.4817 36.3813 23.5915 35.7249 22.9351C35.0685 22.2787 34.1783 21.91 33.25 21.91H15.75C12.9652 21.91 10.2945 23.0162 8.32538 24.9854C6.35625 26.9545 5.25 29.6252 5.25 32.41V67.41C5.25 70.1948 6.35625 72.8655 8.32538 74.8346C10.2945 76.8037 12.9652 77.91 15.75 77.91H64.75C67.5348 77.91 70.2055 76.8037 72.1746 74.8346C74.1438 72.8655 75.25 70.1948 75.25 67.41V53.41C75.25 52.4817 74.8813 51.5915 74.2249 50.9351C73.5685 50.2787 72.6783 49.91 71.75 49.91Z" fill="#BA1A1A"/>
      </svg>

      <div class="flex flex-col items-center gap-2">
        <h2 class=" text-2xl font-bold m-0">
          {errorTitle}
        </h2>
        <p class=" text-sm font-normal">
          <strong>{errorText}</strong> <br>
          <i>Por favor, intenta nuevamente en unos momentos o vuelve a enviar el formulario.</i>
        </p>
      </div>

      <button
        type="button"
        class="retry-btn  bg-[#4A0D0D] text-white px-6 py-3 rounded cursor-pointer transition hover:bg-[#BA1A1A]"
      >
        Intentar nuevamente
      </button>
    </div>
  </div>

</div>
