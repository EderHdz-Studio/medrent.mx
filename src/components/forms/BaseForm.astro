      </svg>

      <div class="flex flex-col items-center gap-2">
        <h2 class=" text-2xl font-bold m-0">
          {errorTitle}
        </h2>
        <p class=" text-sm font-normal">
          <strong>{errorText}</strong> <br>
          <i>Por favor, intenta nuevamente en unos momentos o vuelve a enviar el formulario.</i>
        </p>
      </div>

      <button
        type="button"
        class="retry-btn  bg-[#4A0D0D] text-white px-6 py-3 rounded cursor-pointer transition hover:bg-[#BA1A1A]"
      >
        Intentar nuevamente
      </button>
    </div>
  </div>

</div>