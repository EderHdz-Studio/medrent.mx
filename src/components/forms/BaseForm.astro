---
// src/components/forms/BaseForm.astro
const {
  id,
  class: className = "",
  successTitle = "Gracias por tu interés.",
  successText = "Hemos recibido tu solicitud y uno de nuestros especialistas se pondrá en contacto contigo en breve para orientarte según tus necesidades clínicas.",
  errorTitle = "No fue posible enviar la solicitud",
  errorText = "Estamos teniendo un inconveniente temporal.",
  type = "default"
} = Astro.props;
---

<div id={`${id}-wrapper`} class="form-wrapper relative">

  <input type="hidden" name="formType" value={type} />

  <!-- FORM -->
  <div class="form-container">
    <form id={id} class={className}>
      <slot />
    </form>
  </div>

  <!-- SUCCESS -->
  <div class="form-success hidden">
    <div class="bg-[#F5FAF9] rounded-3xl pt-12 pr-6 pb-8 pl-6 text-center flex flex-col items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="104" height="104" viewBox="0 0 104 104" fill="none">
        <path d="M91 52C91 73.541 73.541 91 52 91C30.459 91 13 73.541 13 52C13 30.459 30.459 13 52 13C73.541 13 91 30.459 91 52Z" stroke="#006764" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M39 55.25L48.75 65L65 42.25" stroke="#006764" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

      <div class="flex flex-col items-center gap-2">
        <h3 class="uppercase text-base font-medium text-[var(--color-primary)]">SOLICITUD ENVIADA</h3>
        <h2 class="text-xl font-semibold text-[24px] font-bold successTitle">{successTitle}</h2>
        <p class="successText">{successText}</p>
        <p class="text-gray-600 mt-2">
          Mientras tanto, puedes explorar más productos o especialidades en <a href="/productos" class="text-[var(--color-primary)] underline cursor-pointer">nuestro catálogo.</a>
        </p>
      </div>

