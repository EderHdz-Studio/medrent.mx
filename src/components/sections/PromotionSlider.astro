---
import { strapiFetch } from "@server/strapiClient";

// Usando la misma sintaxis que en tu otro código
const response = await strapiFetch(
  "/promo-sliders?" + new URLSearchParams({
    "populate[desktopImage]": "*",
    "populate[mobileImage]": "*",
    "sort[0]": "displayOrder:asc",
    "filters[isActive][$eq]": "true"
  }).toString()
);

// Mapeo para Strapi v5
const promotions = (response.data || [])
  .filter((item: any) => item.isActive === true)
  .map((item: any) => ({
    id: item.id,
    title: item.title,
    url: item.url,
    utmParams: item.utmParams,
    displayOrder: item.displayOrder,
    desktopImage: item.desktopImage,
    mobileImage: item.mobileImage,
  }));

// Props del componente
const { disableHorizontalPadding = false, pdpSectionTitle = false } = Astro.props;

// Función para construir URL con parámetros UTM
function buildPromotionHref(item: any) {
  const base = (item?.url || "#").trim();
  const utm = (item?.utmParams || "").trim();

  if (!utm) return base;

  const separator = base.includes("?") ? "&" : "?";
  return `${base}${separator}${utm.replace(/^\?/, "")}`;
}
---

<!-- Sección slider de promociones -->
{promotions.length > 0 && (
  <section
    class:list={[
      "py-6 max-w-7xl mx-auto flex flex-col gap-6",
      disableHorizontalPadding ? "px-0" : "px-4 md:px-6 lg:px-8",
    ]}
  >
    <div class="text-center">
      <h2
        class:list={[
          pdpSectionTitle
            ? "pdp-section-title"
            : "type-h3 font-bold text-[var(--color-text-default)] tracking-tight text-left",
        ]}
      >
        Nuestras promociones
      </h2>
    </div>

    <div class="glide" id="PromotionSlider">
      <div class="glide__track" data-glide-el="track">
        <ul class="glide__slides">
          {promotions.map((promo) => (
            <li class="glide__slide">
              <a
                href={buildPromotionHref(promo)}
                class="block rounded overflow-hidden"
                target={promo.url?.startsWith("http") ? "_self" : undefined}
              >
                {/* Mobile image - visible en móvil */}
                {promo.mobileImage?.url && (
                  <img
                    src={promo.mobileImage.url}
                    alt={promo.mobileImage.alternativeText || promo.title || "Promoción"}
                    class="block w-full h-auto object-cover md:hidden"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                
                {/* Desktop image - visible en desktop */}
                {promo.desktopImage?.url && (
                  <img
                    src={promo.desktopImage.url}
                    alt={promo.desktopImage.alternativeText || promo.title || "Promoción"}
                    class="hidden w-full h-auto object-cover md:block"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                
                {/* Fallback si no hay imágenes */}
                {!promo.mobileImage?.url && !promo.desktopImage?.url && (
                  <div class="bg-gray-200 w-full h-48 flex items-center justify-center">
                    <span class="text-gray-500">{promo.title || "Promoción"}</span>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
)}

<script type="module">
  const slider = document.querySelector('#PromotionSlider');
  if (!slider || slider.dataset.mounted === 'true') {
    // noop
  } else {
    const mount = async () => {
      if (slider.dataset.mounted === 'true') return;
      const { default: Glide } = await import('@glidejs/glide');
      new Glide(slider, {
        type: 'slider',
        perView: 1,
        gap: 0,
        hoverpause: true,
        breakpoints: {
          1024: {
            perView: 1
          },
          640: {
            perView: 1
          }
        }
      }).mount();
      slider.dataset.mounted = 'true';
    };

    const scheduleMount = () => {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(() => mount().catch(() => {}));
      } else {
        setTimeout(() => mount().catch(() => {}), 0);
      }
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const isVisible = entries.some((entry) => entry.isIntersecting);
        if (isVisible) {
          observer.disconnect();
          scheduleMount();
        }
      }, { rootMargin: '300px 0px' });
      observer.observe(slider);
    } else {
      scheduleMount();
    }
  }
</script>