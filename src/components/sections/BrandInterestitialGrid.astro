---
import { localizePath } from "@lib/locale";

const {
  cards = [],
  brand,
  brandName = "",
  brandLogo,
  fallbackColor = "#00827F",
  currentPathname,
} = Astro.props;

const validCards = Array.isArray(cards)
  ? cards.filter((card) => card?.slug && card?.name)
  : [];

const maxVisibleProducts = 7;
---

{validCards.length > 0 && (
  <section class="bg-[var(--color-secondary-light)] px-4 pb-16 pt-4 sm:px-6 lg:px-8">
    <div class="mx-auto grid w-full max-w-[1280px] grid-cols-1 gap-6 md:grid-cols-2">
      {validCards.map((card) => (
        <article class="flex min-h-[784px] flex-col overflow-hidden rounded-[24px] bg-white">
          <div
            class="relative flex aspect-[16/10] w-full items-center justify-center overflow-hidden bg-[#FFF]"
          >
            {card.image ? (
              <img
                src={card.image}
                alt={card.name}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : brandLogo ? (
              <img
                src={brandLogo}
                alt={brandName}
                class="max-h-[45%] max-w-[55%] object-contain"
                loading="lazy"
                decoding="async"
              />
            ) : null}
          </div>

          <div class="flex flex-1 flex-col justify-between gap-8 px-6 pb-6 pt-6 md:px-8 md:pb-8">
            <div class="flex flex-col gap-4">
              <h3 class="m-0 text-[24px] font-bold leading-tight text-[#171D1C]">
                {card.name}
              </h3>

              <p class="m-0 text-[14px] leading-[1.55] text-[var(--color-text-default)]">
                {card.description ?? ""}
              </p>

              {Array.isArray(card.products) && card.products.length > 0 && (
                <div class="text-[14px] leading-relaxed">
                  <span class="font-semibold text-[#171D1C]">Equipos: </span>
                  {card.products.slice(0, maxVisibleProducts).map((product, productIndex) => (
                    <span class="inline">
                      <a
                        href={localizePath(`/productos/${product.slug}`, currentPathname)}
                        class="text-[var(--color-primary)] italic underline decoration-1 underline-offset-2 transition-colors hover:text-[var(--color-accent)]"
                      >
                        {product.name}
                      </a>
                      {productIndex < Math.min(card.products.length, maxVisibleProducts) - 1 && (
                        <span class="text-[var(--color-primary)]">, </span>
                      )}
                    </span>
                  ))}
                  {card.products.length > maxVisibleProducts && (
                    <>
                      <span class="text-[var(--color-primary)]"> </span>
                      <a
                        href={localizePath(`/nuestras-marcas/${brand}/${card.slug}`, currentPathname)}
                        class="text-[var(--color-primary)] italic underline decoration-1 underline-offset-2 transition-colors hover:text-[var(--color-accent)]"
                      >
                        ... +{card.products.length - maxVisibleProducts}
                      </a>
                    </>
                  )}
                </div>
              )}
            </div>

            <a
              href={localizePath(`/nuestras-marcas/${brand}/${card.slug}`, currentPathname)}
              class="inline-flex w-fit items-center justify-center gap-2 rounded-[4px] bg-[var(--color-primary)] px-4 py-3 text-[14px] font-bold leading-none text-white transition-colors hover:bg-[var(--color-accent)]"
            >
              Ver productos
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7M17 7h-6M17 7v6" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
)}
