---
import ImageResponsive from "@components/media/ImageResponsive.astro";
import { isUsableBrandSlug } from "@lib/brandSlug";
type BrandItem = {
  slug?: string;
  name?: string;
  logo?: any;
};
const { marcasData = [] } = Astro.props as { marcasData?: BrandItem[] };
---

<section class="max-w-7xl mx-auto px-4 py-4 md:py-6 md:px-">
  <div class="flex justify-between items-center gap-5 flex-wrap">
  
  <!-- Texto del lado izquierdo -->
  <div class="flex flex-col md:flex-row justify-between items-center gap-5">
  
  <!-- Texto arriba en mobile, izquierda en desktop -->
  <div class="w-full">
    <h3 class="text-center md:text-left text-[#006764] font-bold text-sm uppercase">
      NUESTRAS MARCAS
    </h3>
    <h2 class="text-center md:text-left text-2xl font-bold text-gray-900 tracking-tight mt-1">
      Tecnología confiable para tu práctica
    </h2>
    <p class="text-center md:text-left text-gray-700 text-base tracking-[0.5px] mt-1">
      Trabajamos con fabricantes líderes que garantizan precisión clínica, innovación y resultados reales.
    </p>
  </div>

  <!-- Btb "Ver todas las marcas" -->
  <div class="w-full md:w-auto flex-shrink-0">
    <a 
      href="/nuestras-marcas"
      class="flex items-center justify-center gap-2 px-4 py-3 rounded border-2 border-[#006764] bg-white text-[#006764] text-base font-bold leading-6 tracking-[0.5px] hover:bg-[#006764] hover:text-white transition-all duration-200 w-full md:w-auto"
    >
      Ver todas las marcas
    </a>
  </div>

</div>

  {marcasData.length > 0 ? (
    <div>
      <!-- Grid de marcas -->
      <div class="brands-grid" id="brandsGrid" style="gap: 6px 24px;">
        {marcasData.map((brand: BrandItem, index: number) => (
          <a
            href={isUsableBrandSlug(brand.slug) ? `/nuestras-marcas/${brand.slug}` : "/productos"}
            class="brand-item hover-scale-img"
            key={brand.slug}
            data-brand-index={index}
          >
            <div class="brand-logo-wrapper">
              {brand.logo?.url ? (
                <img 
                  src={brand.logo.url} 
                  alt={brand.name}
                  class="brand-logo"
                  loading="lazy"
                />
              ) : (
                <div class="brand-placeholder">
                  <span>{brand.name?.charAt(0)}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      <!-- Botón Ver más/Ver menos (solo visible en mobile Y si hay más de 3 marcas) -->
      {marcasData.length > 3 && (
        <div class="brands-button-container mobile-only">
          <button id="toggleBrandsBtn" class="brands-toggle-btn">
            <span id="btnText">Ver más marcas</span>
            <svg id="btnIcon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M18 11H13V6H11V11H6V13H11V18H13V13H18V11Z" fill="#171D1C"/>
            </svg>
          </button>
        </div>
      )}
    </div>
  ) : (
    <p class="text-center text-gray-500">No hay marcas disponibles</p>
  )}
</section>

<style is:global>
  .brands-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 24px;
    padding: 20px 0;
  }

  .brand-item {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 !important;
    padding: 0 !important;
    transition: all 0.3s ease;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }

  .brand-logo-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    padding: 16px;
  }

  .brand-logo {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .brand-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    border-radius: 12px;
    font-size: 32px;
    font-weight: bold;
    color: #ccc;
  }

  .brand-item:hover {
    transform: scale(1.05);
  }

  .brands-button-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 24px;
  }

  .brands-toggle-btn {
    display: flex;
    padding: 8px 12px 8px 18px;
    justify-content: center;
    align-items: center;
    gap: 8px;
    border-radius: 1000px;
    border: 1px solid var(--Schemes-On-Surface, #171D1C);
    background: var(--Schemes-On-Primary, #FFF);
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 14px;
    font-weight: 500;
    color: #171D1C;
  }

  @media (min-width: 768px) {
    .brands-grid {
      justify-content: space-around;
    }
    .brands-grid .brand-item {
      display: flex !important;
    }
    .mobile-only {
      display: none !important;
    }
  }

  @media (max-width: 767px) {
    .brands-grid {
      justify-content: space-around;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px !important;
    }
    .brands-grid .brand-item {
      width: 100px;
      height: 100px;
      display: none;
    }
    .brands-button-container {
      margin-top: 0 !important;
    }
    .brands-grid .brand-item:nth-child(1),
    .brands-grid .brand-item:nth-child(2),
    .brands-grid .brand-item:nth-child(3),
    .brands-grid .brand-item:nth-child(4),
    .brands-grid .brand-item:nth-child(5),
    .brands-grid .brand-item:nth-child(6),
    .brands-grid .brand-item:nth-child(7),
    .brands-grid .brand-item:nth-child(8),
    .brands-grid .brand-item:nth-child(9) {
      display: flex !important;
    }
    
    .brands-grid.show-all .brand-item {
      display: flex !important;
    }
    
    .mobile-only {
      display: flex;
    }
  }
</style>

<script>
  (function() {
    const toggleBtn = document.getElementById('toggleBrandsBtn');
    const brandsGrid = document.getElementById('brandsGrid');
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    
    if (toggleBtn && brandsGrid) {
      let isExpanded = false;
      
      toggleBtn.addEventListener('click', () => {
        isExpanded = !isExpanded;
        
        if (isExpanded) {
          brandsGrid.classList.add('show-all');
          btnText.textContent = 'Ver menos';
          btnIcon.innerHTML = '<path d="M4 12H20" stroke="#171D1C" stroke-width="2" stroke-linecap="round"/>';
        } else {
          brandsGrid.classList.remove('show-all');
          btnText.textContent = 'Ver más marcas';
          btnIcon.innerHTML = '<path d="M18 11H13V6H11V11H6V13H11V18H13V13H18V11Z" fill="#171D1C"/>';
        }
      });
    }
  })();
</script>