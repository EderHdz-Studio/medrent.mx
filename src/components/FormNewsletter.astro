---
/**
 * Organismo: newsletter (punto de entrada único).
 * Estilos: `src/styles/newsletter-module.css` · Átomos/moléculas: `src/components/newsletter/`
 */
import NewsletterHeading from "./newsletter/NewsletterHeading.astro";
import NewsletterLead from "./newsletter/NewsletterLead.astro";
import NewsletterSubscribeForm from "./newsletter/NewsletterSubscribeForm.astro";
import NewsletterSuccessBanner from "./newsletter/NewsletterSuccessBanner.astro";
---

<style>
  input[type="email"]:-webkit-autofill,
  input[type="email"]:-webkit-autofill:focus,
  input[type="email"]:-webkit-autofill:hover,
  input[type="email"]:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px var(--color-white) inset !important;
    box-shadow: 0 0 0 1000px var(--color-white) inset !important;
    background-color: var(--color-white) !important;
    color: #261819 !important;
    transition: background-color 5000s ease-in-out 0s;
    outline: none !important;
  }

  input[type="email"]:focus {
    outline: none !important;
  }
</style>

<section id="newsletter-section" class="newsletter-module">
  <div class="newsletter-module__inner">
    <!-- Contenedor relativo para que ambos ocupen el mismo espacio -->
    <div style="position: relative; min-height: 300px;">
      <div id="newsletter-default" class="newsletter-module__default transition-opacity duration-400 ease-in-out" style="transition: opacity 0.4s ease-in-out;">
        <NewsletterHeading>¡Suscríbete al newsletter de Medrent!</NewsletterHeading>
        <NewsletterLead>
          Recibe en tu correo las últimas novedades en tecnología médica, consejos especializados y actualizaciones
          exclusivas sobre nuestras soluciones.
        </NewsletterLead>
        <NewsletterSubscribeForm />
      </div>
      <NewsletterSuccessBanner />
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const input = document.getElementById("email");
    const label = document.getElementById("email-label");
    const form = document.getElementById("newsletter-form");
    const defaultContent = document.getElementById("newsletter-default");
    const successContent = document.getElementById("newsletter-success");
    const errorMessage = document.getElementById("newsletter-error");
    const privacyCheckbox = document.getElementById("privacy");

    if (input) {
      function updateBorder() {
        const value = input.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (emailRegex.test(value)) {
          input.style.setProperty("border", "3px solid var(--color-primary)", "important");
          input.style.setProperty("outline", "none", "important");
          if (label) label.style.background = "var(--color-primary)";
        } else if (document.activeElement === input) {
          input.style.setProperty("border", "3px solid var(--color-primary)", "important");
          input.style.setProperty("outline", "none", "important");
          if (label) label.style.background = "";
        } else {
          input.style.setProperty("border", "1px solid var(--color-primary)", "important");
          input.style.setProperty("outline", "none", "important");
          if (label) label.style.background = "";
        }
      }

      function forceWhiteBg() {
        input.style.setProperty("background-color", "var(--color-white)", "important");
        input.style.setProperty("outline", "none", "important");
      }

      input.addEventListener("change", updateBorder);
      input.addEventListener("blur", updateBorder);
      input.addEventListener("focus", updateBorder);
      input.addEventListener("input", forceWhiteBg);
      input.addEventListener("change", forceWhiteBg);
    }

    
    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      const email = input.value.trim();
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      errorMessage.classList.add("hidden");
      errorMessage.textContent = "";

      if (!email) {
        errorMessage.textContent = "Por favor, ingresa tu correo electrónico.";
        errorMessage.classList.remove("hidden");
        return;
      }

      if (!emailRegex.test(email)) {
        errorMessage.textContent = "Por favor, ingresa un correo electrónico válido.";
        errorMessage.classList.remove("hidden");
        return;
      }

      if (!privacyCheckbox.checked) {
        errorMessage.textContent = "Debes aceptar el Aviso de Privacidad para continuar.";
        errorMessage.classList.remove("hidden");
        return;
      }

      await newsletterRegister();
      
    });
    

    function showSuccessMessage() {
      // Ocultar default con opacidad
      defaultContent.style.opacity = "0";
      defaultContent.style.pointerEvents = "none";
      
      // Mostrar success en la misma posición con flex
      successContent.style.position = "absolute";
      successContent.style.top = "0";
      successContent.style.left = "0";
      successContent.style.right = "0";
      successContent.style.opacity = "0";
      successContent.classList.remove("hidden");
      successContent.style.display = "flex"; // Asegurar flex
      
      setTimeout(function () {
        successContent.style.opacity = "1";
      }, 50);
      
      // Después de 10 segundos, volver al formulario
      setTimeout(function () {
        // Ocultar success
        successContent.style.opacity = "0";
        
        setTimeout(function () {
          successContent.classList.add("hidden");
          successContent.style.display = "";
          successContent.style.position = "";
          
          // Resetear formulario
          if (form) form.reset();
          if (input) {
            input.style.setProperty("border", "1px solid var(--color-primary)", "important");
          }
          if (label) label.style.background = "var(--color-primary)";
          
          // Mostrar default nuevamente
          defaultContent.style.opacity = "1";
          defaultContent.style.pointerEvents = "auto";
          defaultContent.style.position = "";
        }, 400);
      }, 10000); // 10 segundos
    }



    
  async function newsletterRegister(){
    
    const form = document.getElementById("newsletter-form");
    const formId = 'form-newsletter'
    const minWait = (ms) => new Promise((res) => setTimeout(res, ms));
    const tracking = window.getTrackingData(); 

    const email = document.getElementById("email");

    const data =   {
      "name": "",
      "email":  email.value.trim(),
      "phone": "5643050221",
      "specialty": "",
      "otras_especialidades": "",
      "utm_term": tracking.utm_term || "",
      "utm_medium": tracking.utm_medium || "",
      "utm_source": tracking.utm_source || "",
      "utm_content": tracking.utm_content || "",
      "utm_campaign": tracking.utm_campaign || "",
      "unidades_de_negocios": "MEDRENT",
      "hs_all_assigned_business_unit_ids": "0",
      "definicion_de_necesidad": "Compra Equipo Médico"
    }

  
  // console.log("Data to send:", data);
   try {
    const fetchPromise = fetch("/api/contact", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    })
    .then(async (response) => {
      // Manejo de status específicos
      if (response.status === 400) {
        
        console.log("Response 400:", response);
      } else if (response.status === 409) {
        // console.log("Response 409:", response);
        // form.reset();
      } else if (response.ok) {
        console.log("Response 200:", response);
        showSuccessMessage();
        // form.reset();
        
      } else {
        console.log("Response error:", response);
      }

      sentEvent(email.value.trim(), response.status)

      // sendFormEvent({ formId: formId, status: response.status });
      return response;
    })
    .catch((error) => {

      console.error("Fetch error:", error);
    });

        await Promise.all([fetchPromise, minWait(1200)]); // 1.2 segundos mínimo
    } catch (error) {
      console.error(error);
      
    }
  }
  });



  function sentEvent(email, estatus){
  const tracking = window.getTrackingData();
  const pageTitle = document.title;
  // Construir objeto de evento
  const dataEventForm = {
    event: "generate_lead",
    event_data: {
      category: "Form Interaction",
      action: "Lead Generation",
      label: "Submit - Newsletter suscription" ,
      page: pageTitle,
    },
    form_submission: {
      form_id: 'form-newsletter',
      form_data: {
        full_name: '',
        email: email,
        phone: '',
        institution: '',
        medical_specialty: '',
        state: '',
        discovery_channel: '',
        product_interest: '',
        message: '',
        eventName: '',
        statusResponseHubspot: estatus || "error",
      },
    },
    tracking: tracking,
  };

  // Enviar al dataLayer
  window.dataLayer.push(dataEventForm);
  }
</script>
