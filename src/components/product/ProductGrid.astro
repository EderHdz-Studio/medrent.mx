---
import ProductCard from "./ProductCard.astro";
import type { Product } from "@lib/domain/product/types";

interface Props {
  products: Product[];
  totalCount?: number;
}

const { products, totalCount = products.length } = Astro.props;
const productsPerPage = 25;
---

<div 
  class="product-filters-container"
  data-products-per-page={productsPerPage}
  data-total-products={totalCount}
>
  <!-- Contadores -->
  <div class="flex items-center justify-between mb-6">
    <span class="text-[16px] font-normal text-[var(--color-text-default)]">
      Mostrando <b class="font-bold" id="shown-count-top">{Math.min(productsPerPage, totalCount)}</b> de 
      <b class="font-bold">{totalCount}</b>
    </span>
    <button
      class="flex lg:hidden items-center gap-2 px-3 py-2 rounded border border-[var(--color-primary)] text-[var(--color-text-default)] font-medium bg-white shadow-sm"
      id="mobile-filter-button"
      aria-label="Show filters"
    >
      <span>Filters (<span id="active-filters-count">0</span>)</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M12.816 2.00095C12.6124 1.4164 12.2318 0.909717 11.7273 0.551174C11.2227 0.192631 10.619 0 10 0C9.381 0 8.77734 0.192631 8.27275 0.551174C7.76815 0.909717 7.38765 1.4164 7.184 2.00095H0V4.00095H7.184C7.38765 4.58549 7.76815 5.09217 8.27275 5.45072C8.77734 5.80926 9.381 6.00189 10 6.00189C10.619 6.00189 11.2227 5.80926 11.7273 5.45072C12.2318 5.09217 12.6124 4.58549 12.816 4.00095H18V2.00095H12.816ZM10 4.00095C9.80222 4.00095 9.60888 3.9423 9.44443 3.83242C9.27998 3.72253 9.15181 3.56635 9.07612 3.38363C9.00043 3.2009 8.98063 2.99984 9.01921 2.80586C9.0578 2.61187 9.15304 2.43369 9.29289 2.29384C9.43275 2.15399 9.61093 2.05875 9.80491 2.02016C9.99889 1.98158 10.2 2.00138 10.3827 2.07707C10.5654 2.15275 10.7216 2.28093 10.8315 2.44538C10.9414 2.60982 11 2.80316 11 3.00095C11 3.26616 10.8946 3.52052 10.7071 3.70805C10.5196 3.89559 10.2652 4.00095 10 4.00095Z" fill="#212121"/>
        <path d="M4 6.00095C3.38174 6.00351 2.77937 6.19703 2.2753 6.55503C1.77123 6.91304 1.39008 7.41804 1.184 8.00095H0V10.0009H1.184C1.38765 10.5855 1.76815 11.0922 2.27275 11.4507C2.77734 11.8093 3.381 12.0019 4 12.0019C4.619 12.0019 5.22266 11.8093 5.72725 11.4507C6.23185 11.0922 6.61235 10.5855 6.816 10.0009H18V8.00095H6.816C6.60992 7.41804 6.22877 6.91304 5.7247 6.55503C5.22063 6.19703 4.61826 6.00351 4 6.00095ZM4 10.0009C3.80222 10.0009 3.60888 9.9423 3.44443 9.83242C3.27998 9.72253 3.15181 9.56636 3.07612 9.38363C3.00043 9.2009 2.98063 8.99984 3.01921 8.80586C3.0578 8.61187 3.15304 8.43369 3.29289 8.29384C3.43275 8.15399 3.61093 8.05875 3.80491 8.02016C3.99889 7.98158 4.19996 8.00138 4.38268 8.07707C4.56541 8.15275 4.72159 8.28093 4.83147 8.44538C4.94135 8.60982 5 8.80316 5 9.00095C5 9.26616 4.89464 9.52052 4.70711 9.70805C4.51957 9.89559 4.26522 10.0009 4 10.0009Z" fill="#212121"/>
        <path d="M13 12.0009C12.3817 12.0035 11.7794 12.197 11.2753 12.555C10.7712 12.913 10.3901 13.418 10.184 14.0009H0V16.0009H10.184C10.3876 16.5855 10.7682 17.0922 11.2727 17.4507C11.7773 17.8093 12.381 18.0019 13 18.0019C13.619 18.0019 14.2227 17.8093 14.7273 17.4507C15.2318 17.0922 15.6124 16.5855 15.816 16.0009H18V14.0009H15.816C15.6099 13.418 15.2288 12.913 14.7247 12.555C14.2206 12.197 13.6183 12.0035 13 12.0009ZM13 16.0009C13.8022 16.0009 13.6089 15.9423 13.4444 15.8324C13.28 15.7225 13.1518 15.5664 13.0761 15.3836C13.0004 15.2009 12.9806 14.9998 13.0192 14.8059C13.0578 14.6119 13.153 14.4337 13.2929 14.2938C13.4327 14.154 13.6109 14.0587 13.8049 14.0202C13.9989 13.9816 14.2 14.0014 14.3827 14.0771C14.5654 14.1528 14.7216 14.2809 14.8315 14.4454C14.9414 14.6098 15 14.8032 15 15.0009C15 15.2662 14.8946 15.5205 14.7071 15.7081C14.5196 15.8956 14.2652 16.0009 14 16.0009Z" fill="#212121"/>
      </svg>
    </button>
  </div>

  <!-- Grid de productos - TODOS los productos están renderizados -->
  <div
    id="productos-list"
    class="grid gap-6 grid-cols-1 [@media(min-width:520px)]:grid-cols-2 [@media(min-width:800px)]:grid-cols-3"
  >
    {products.map((product, index) => (
      <div 
        class="product-item" 
        data-index={index}
        style={index >= productsPerPage ? 'display: none;' : ''}
      >
        <ProductCard product={product} />
      </div>
    ))}
  </div>

  <!-- Botón Ver más productos -->
  {products.length > productsPerPage && (
    <div id="load-more-container" class="flex flex-col justify-center items-center mt-6 gap-6">
      <button
        id="ver-mas-productos"
        class="w-[274px] p-4 rounded-[4px] border border-[var(--color-primary)] bg-white text-[14px] text-[var(--color-primary)] font-light cursor-pointer hover:bg-[var(--color-primary)] hover:text-[#FFFFFF] transition-colors"
      >
        Ver más productos +
      </button>
      <span class="text-[16px] font-normal text-[var(--color-text-default)]">
        Mostrando <b class="font-bold" id="shown-count-bottom">{productsPerPage}</b> de 
        <b class="font-bold">{products.length}</b>
      </span>
    </div>
  )}
</div>

<script>
  class ProductLoader {
    constructor() {
      this.productItems = document.querySelectorAll('.product-item');
      this.productsPerPage = parseInt(document.querySelector('.product-filters-container')?.dataset.productsPerPage || '25');
      this.currentPage = 1;
      this.loadMoreBtn = document.getElementById('ver-mas-productos');
      this.shownCountTop = document.getElementById('shown-count-top');
      this.shownCountBottom = document.getElementById('shown-count-bottom');
      this.loadMoreContainer = document.getElementById('load-more-container');
      this.totalProducts = this.productItems.length;
      
      this.init();
    }
    
    init() {
      if (this.loadMoreBtn) {
        this.loadMoreBtn.addEventListener('click', () => this.loadMoreProducts());
      }
    }
    
    loadMoreProducts() {
      const nextPage = this.currentPage + 1;
      const startIndex = this.currentPage * this.productsPerPage;
      const endIndex = nextPage * this.productsPerPage;
      
      // Mostrar los siguientes productos
      for (let i = startIndex; i < Math.min(endIndex, this.totalProducts); i++) {
        if (this.productItems[i]) {
          this.productItems[i].style.display = '';
          // Añadir animación suave
          this.productItems[i].style.opacity = '0';
          this.productItems[i].style.transform = 'translateY(20px)';
          setTimeout(() => {
            if (this.productItems[i]) {
              this.productItems[i].style.opacity = '1';
              this.productItems[i].style.transform = 'translateY(0)';
            }
          }, 50 * (i - startIndex));
        }
      }
      
      this.currentPage = nextPage;
      
      // Actualizar ambos contadores
      const shownCount = Math.min(this.currentPage * this.productsPerPage, this.totalProducts);
      if (this.shownCountTop) {
        this.shownCountTop.textContent = shownCount;
      }
      if (this.shownCountBottom) {
        this.shownCountBottom.textContent = shownCount;
      }
      
      // Ocultar botón si ya no hay más productos
      if (shownCount >= this.totalProducts && this.loadMoreContainer) {
        this.loadMoreContainer.style.display = 'none';
      }
    }
  }
  
  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new ProductLoader();
    });
  } else {
    new ProductLoader();
  }
</script>

<style>
  .product-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .product-item {
    opacity: 1;
    transform: translateY(0);
  }
  
  #ver-mas-productos:active {
    transform: scale(0.98);
  }
</style>