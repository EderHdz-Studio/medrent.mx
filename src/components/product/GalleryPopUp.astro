---
import ShareButtons from '@components/product/ShareButtons.astro';
---
<!-- Popup Galería de Imágenes y Videos tipo newsletter -->
<div id="gallery-popup-overlay" class="fixed inset-0 z-[9999] hidden">
  <!-- Fondo con blur y gradiente -->
  <div 
    id="gallery-blurred-background" 
    class="absolute inset-0 transition-all duration-300"
    style="background: rgba(23, 29, 28, 0.80); backdrop-filter: blur(7px);">
  </div>
  <!-- Popup Content -->
  <div class="relative z-[10000] flex items-center justify-center min-h-screen p-4 h-[85%] md:h-[85%] lg:h-auto md:mt-12 overflow-y-auto">
    <button id="gallery-prev" class="cursor-pointer group relative left-0 -translate-y-1/2 h-14 px-4 py-2 rounded-full bg-[#212121] text-white flex items-center justify-center z-[10001] mr-8 hover:bg-[#333]" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="transition-transform duration-200 ease-in-out group-hover:scale-110">
            <path d="M16.9999 11H9.4099L12.7099 7.71C12.8982 7.5217 13.004 7.2663 13.004 7C13.004 6.7337 12.8982 6.47831 12.7099 6.29C12.5216 6.1017 12.2662 5.99591 11.9999 5.99591C11.7336 5.99591 11.4782 6.1017 11.2899 6.29L6.2899 11.29C6.19886 11.3851 6.12749 11.4973 6.0799 11.62C5.97988 11.8635 5.97988 12.1365 6.0799 12.38C6.12749 12.5028 6.19886 12.6149 6.2899 12.71L11.2899 17.71C11.3829 17.8037 11.4935 17.8781 11.6153 17.9289C11.7372 17.9797 11.8679 18.0058 11.9999 18.0058C12.1319 18.0058 12.2626 17.9797 12.3845 17.9289C12.5063 17.8781 12.6169 17.8037 12.7099 17.71C12.8036 17.617 12.878 17.5064 12.9288 17.3846C12.9796 17.2627 13.0057 17.132 13.0057 17C13.0057 16.868 12.9796 16.7373 12.9288 16.6154C12.878 16.4936 12.8036 16.383 12.7099 16.29L9.4099 13H16.9999C17.2651 13 17.5195 12.8946 17.707 12.7071C17.8945 12.5196 17.9999 12.2652 17.9999 12C17.9999 11.7348 17.8945 11.4804 17.707 11.2929C17.5195 11.1054 17.2651 11 16.9999 11Z" fill="white"/>
        </svg>
    </button>

    <div id="ImageGalery" class="rounded-lg shadow-xl max-w-4xl w-full overflow-hidden relative h-auto lg:h-auto flex flex-col items-center justify-center z-[10000]" style="width: auto; touch-action: pan-y;">
      <!-- Botón cerrar -->
      <button id="close-gallery-popup" type="button" class="cursor-pointer absolute top-4 right-4 flex items-center justify-center w-10 h-10 rounded-full bg-[rgba(33,33,33,0.95)] text-white z-[10001] group hover:bg-[#000] hover:scale-110 transition-all duration-200" >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="transition-transform duration-200 ease-in-out">
            <path d="M6.4 19L5 17.6L10.6 12L5 6.4L6.4 5L12 10.6L17.6 5L19 6.4L13.4 12L19 17.6L17.6 19L12 13.4L6.4 19Z" class="fill-white"/>
          </svg>
      </button>
      
      <!-- Contenedor multimedia principal -->
      <div class="flex flex-col items-center justify-center w-auto h-auto p-2">
        <!-- Contenedor para imagen o video -->
        <div id="gallery-media-container" class="relative w-full h-full">
          <!-- Imagen -->
          <img id="gallery-main-image" src="https://inspiring-delight-e03825eb6a.media.strapiapp.com/Cardiovit_AT_102_G2_25_6f83a50577.webp" alt="Imagen galería" class="w-full h-full object-contain rounded-lg hidden"/>
          
          <!-- Video con playsinline para móviles -->
          <video 
            id="gallery-main-video" 
            controls 
            playsinline
            webkit-playsinline
            class="w-full h-full object-contain rounded-lg hidden"
            style="background: #FFF; padding: 60px; box-sizing: border-box;">
            Tu navegador no soporta la reproducción de video.
          </video>
        </div>

        <div class="lg:hidden w-full mt-4">
          <div id="popupMediaButtonsMobile" class="flex flex-row items-center gap-2 left-0 bottom-0 w-full z-20 px-2 py-2 justify-between bg-transparent relative">
            <ShareButtons classNames="flex flex-row items-center gap-2 w-full justify-between" />

            <div class="absolute left-1/2 -translate-x-1/2 bottom-3 z-30 pointer-events-none">
              <span
                id="popup-mobile-gallery-counter"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-[var(--color-text-default)] bg-[#F3FFFD] px-4 py-1 text-center text-[var(--color-text-default)] text-[16px] font-normal leading-6 tracking-[0.5px]"
              >
                1 / 0
              </span>
            </div>

            <button
              type="button"
              data-zoom-button
              aria-pressed="false"
              title="Activar zoom"
              class="w-10 h-10 flex items-center justify-center rounded cursor-pointer border border-[#212121] bg-transparent text-[#212121] transition-colors duration-200"
            >
              <svg class="zoom-icon-inactive w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M14.9999 9.9999H11.9999V6.9999C11.9999 6.73469 11.8945 6.48033 11.707 6.2928C11.5195 6.10526 11.2651 5.9999 10.9999 5.9999C10.7347 5.9999 10.4803 6.10526 10.2928 6.2928C10.1053 6.48033 9.9999 6.73469 9.9999 6.9999V9.9999H6.9999C6.73469 9.9999 6.48033 10.1053 6.2928 10.2928C6.10526 10.4803 5.9999 10.7347 5.9999 10.9999C5.9999 11.2651 6.10526 11.5195 6.2928 11.707C6.48033 11.8945 6.73469 11.9999 6.9999 11.9999H9.9999V14.9999C9.9999 15.2651 10.1053 15.5195 10.2928 15.707C10.4803 15.8945 10.7347 15.9999 10.9999 15.9999C11.2651 15.9999 11.5195 15.8945 11.707 15.707C11.8945 15.5195 11.9999 15.2651 11.9999 14.9999V11.9999H14.9999C15.2651 11.9999 15.5195 11.8945 15.707 11.707C15.8945 11.5195 15.9999 11.2651 15.9999 10.9999C15.9999 10.7347 15.8945 10.4803 15.707 10.2928C15.5195 10.1053 15.2651 9.9999 14.9999 9.9999ZM21.7099 20.2899L17.9999 16.6099C19.44 14.8143 20.1374 12.5352 19.9487 10.2412C19.76 7.94721 18.6996 5.81269 16.9854 4.27655C15.2713 2.74041 13.0337 1.91941 10.7328 1.98237C8.43194 2.04534 6.24263 2.98747 4.61505 4.61505C2.98747 6.24263 2.04534 8.43194 1.98237 10.7328C1.91941 13.0337 2.74041 15.2713 4.27655 16.9854C5.81269 18.6996 7.94721 19.76 10.2412 19.9487C12.5352 20.1374 14.8143 19.44 16.6099 17.9999L20.2899 21.6799C20.3829 21.7736 20.4935 21.848 20.6153 21.8988C20.7372 21.9496 20.8679 21.9757 20.9999 21.9757C21.1319 21.9757 21.2626 21.9496 21.3845 21.8988C21.5063 21.848 21.6169 21.7736 21.7099 21.6799C21.8901 21.4934 21.9909 21.2442 21.9909 20.9849C21.9909 20.7256 21.8901 20.4764 21.7099 20.2899ZM10.9999 17.9999C9.61544 17.9999 8.26206 17.5894 7.11091 16.8202C5.95977 16.051 5.06256 14.9578 4.53275 13.6787C4.00293 12.3996 3.86431 10.9921 4.13441 9.63427C4.4045 8.27641 5.07119 7.02912 6.05016 6.05016C7.02912 5.07119 8.27641 4.4045 9.63427 4.13441C10.9921 3.86431 12.3996 4.00293 13.6787 4.53275C14.9578 5.06256 16.051 5.95977 16.8202 7.11091C17.5894 8.26206 17.9999 9.61544 17.9999 10.9999C17.9999 12.8564 17.2624 14.6369 15.9497 15.9497C14.6369 17.2624 12.8564 17.9999 10.9999 17.9999Z" fill="#212121"/>
              </svg>
              <svg class="zoom-icon-active hidden w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21.71 20.29L18 16.61C19.4401 14.8144 20.1375 12.5353 19.9488 10.2413C19.7601 7.94733 18.6997 5.81281 16.9855 4.27667C15.2714 2.74053 13.0338 1.91954 10.7329 1.9825C8.43207 2.04546 6.24275 2.98759 4.61517 4.61517C2.98759 6.24275 2.04546 8.43207 1.9825 10.7329C1.91954 13.0338 2.74053 15.2714 4.27667 16.9855C5.81281 18.6997 7.94733 19.7601 10.2413 19.9488C12.5353 20.1375 14.8144 19.4401 16.61 18L20.29 21.68C20.383 21.7738 20.4936 21.8482 20.6154 21.8989C20.7373 21.9497 20.868 21.9758 21 21.9758C21.132 21.9758 21.2627 21.9497 21.3846 21.8989C21.5065 21.8482 21.6171 21.7738 21.71 21.68C21.8903 21.4936 21.991 21.2444 21.991 20.985C21.991 20.7257 21.8903 20.4765 21.71 20.29ZM11 18C9.61556 18 8.26218 17.5895 7.11103 16.8203C5.95989 16.0511 5.06268 14.9579 4.53287 13.6788C4.00306 12.3997 3.86443 10.9923 4.13453 9.63439C4.40463 8.27653 5.07131 7.02925 6.05028 6.05028C7.02925 5.07131 8.27653 4.40463 9.63439 4.13453C10.9923 3.86443 12.3997 4.00306 13.6788 4.53287C14.9579 5.06268 16.0511 5.95989 16.8203 7.11103C17.5895 8.26218 18 9.61556 18 11C18 12.8565 17.2625 14.637 15.9498 15.9498C14.637 17.2625 12.8565 18 11 18ZM15 10H7.00003C6.73481 10 6.48046 10.1054 6.29292 10.2929C6.10538 10.4805 6.00003 10.7348 6.00003 11C6.00003 11.2652 6.10538 11.5196 6.29292 11.7071C6.48046 11.8947 6.73481 12 7.00003 12H15C15.2652 12 15.5196 11.8947 15.7071 11.7071C15.8947 11.5196 16 11.2652 16 11C16 10.7348 15.8947 10.4805 15.7071 10.2929C15.5196 10.1054 15.2652 10 15 10Z" fill="white"/>
              </svg>
            </button>
          </div>
        </div>
        
        <span id="gallery-counter" class="absolute bottom-4 left-4 px-4 py-2 rounded-full bg-[rgba(0,0,0,0.75)] text-white font-medium text-[16px] z-[10001] backdrop-blur-sm" >
        </span>
      </div>
    </div>
    
    <button id="gallery-next" class="cursor-pointer group relative right-0 -translate-y-1/2 h-14 px-4 py-2 rounded-full bg-[#212121] text-white flex items-center justify-center z-[10001] ml-8 hover:bg-[#333]" aria-label="Siguiente">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="transition-transform duration-200 ease-in-out group-hover:scale-110">
            <path d="M17.92 11.62C17.8724 11.4973 17.801 11.3851 17.71 11.29L12.71 6.29C12.6168 6.19676 12.5061 6.1228 12.3842 6.07234C12.2624 6.02188 12.1319 5.99591 12 5.99591C11.7337 5.99591 11.4783 6.1017 11.29 6.29C11.1968 6.38324 11.1228 6.49393 11.0723 6.61575C11.0219 6.73758 10.9959 6.86814 10.9959 7C10.9959 7.2663 11.1017 7.5217 11.29 7.71L14.59 11H7C6.73478 11 6.48043 11.1054 6.29289 11.2929C6.10536 11.4804 6 11.7348 6 12C6 12.2652 6.10536 12.5196 6.29289 12.7071C6.48043 12.8946 6.73478 13 7 13H14.59L11.29 16.29C11.1963 16.383 11.1219 16.4936 11.0711 16.6154C11.0203 16.7373 10.9942 16.868 10.9942 17C10.9942 17.132 11.0203 17.2627 11.0711 17.3846C11.1219 17.5064 11.1963 17.617 11.29 17.71C11.383 17.8037 11.4936 17.8781 11.6154 17.9289C11.7373 17.9797 11.868 18.0058 12 18.0058C12.132 18.0058 12.2627 17.9797 12.3846 17.9289C12.5064 17.8781 12.617 17.8037 12.71 17.71L17.71 12.71C17.801 12.6149 17.8724 12.5028 17.92 12.38C18.02 12.1365 18.02 11.8635 17.92 11.62Z" fill="white"/>
        </svg>
    </button>
  </div>
</div>

<script is:inline>
    // Variables globales
    let isManualFullscreen = false;
    let videoElement = null;
    
    // Funciones globales para el fullscreen manual
    function enterManualFullscreen() {
      if (!videoElement) {
        videoElement = document.getElementById('gallery-main-video');
        if (!videoElement) return;
      }
      
      isManualFullscreen = true;
      
      // Guardar estado original
      videoElement.dataset.originalParent = videoElement.parentNode.id;
      videoElement.dataset.originalStyles = JSON.stringify({
        position: videoElement.style.position,
        width: videoElement.style.width,
        height: videoElement.style.height,
        top: videoElement.style.top,
        left: videoElement.style.left,
        zIndex: videoElement.style.zIndex,
        padding: videoElement.style.padding,
        background: videoElement.style.background
      });
      
      // Aplicar estilos de pantalla completa MANUAL
      videoElement.style.position = 'fixed';
      videoElement.style.top = '0';
      videoElement.style.left = '0';
      videoElement.style.width = '100vw';
      videoElement.style.height = '100vh';
      videoElement.style.zIndex = '99999';
      videoElement.style.padding = '0';
      videoElement.style.background = '#000';
      videoElement.style.margin = '0';
      videoElement.style.border = 'none';
      
      // Ocultar TODOS los elementos del popup
      document.querySelectorAll('#gallery-popup-overlay > *').forEach(el => {
        if (el !== videoElement) {
          el.style.display = 'none';
          el.style.visibility = 'hidden';
          el.style.opacity = '0';
        }
      });
      
      // Ocultar controles específicos
      ['#gallery-prev', '#gallery-next', '#close-gallery-popup', '#gallery-counter', '#gallery-blurred-background'].forEach(selector => {
        const el = document.querySelector(selector);
        if (el) el.style.display = 'none';
      });
      
      // Agregar clase para CSS
      document.body.classList.add('video-fullscreen-manual');
      videoElement.classList.add('manual-fullscreen-active');
      
      console.log('Fullscreen manual ACTIVADO');
    }
    
    function exitManualFullscreen() {
      if (!videoElement) {
        videoElement = document.getElementById('gallery-main-video');
        if (!videoElement) return;
      }
      
      isManualFullscreen = false;
      
      // Restaurar estilos originales
      if (videoElement.dataset.originalStyles) {
        const originalStyles = JSON.parse(videoElement.dataset.originalStyles);
        Object.keys(originalStyles).forEach(key => {
          videoElement.style[key] = originalStyles[key];
        });
      } else {
        // Valores por defecto
        videoElement.style.position = '';
        videoElement.style.top = '';
        videoElement.style.left = '';
        videoElement.style.width = '';
        videoElement.style.height = '';
        videoElement.style.zIndex = '';
        videoElement.style.padding = '60px';
        videoElement.style.background = '#FFF';
        videoElement.style.margin = '0';
        videoElement.style.border = 'none';
      }
      
      // Mostrar TODOS los elementos del popup
      document.querySelectorAll('#gallery-popup-overlay > *').forEach(el => {
        el.style.display = '';
        el.style.visibility = '';
        el.style.opacity = '';
      });
      
      // Mostrar controles específicos
      ['#gallery-prev', '#gallery-next', '#close-gallery-popup', '#gallery-counter', '#gallery-blurred-background'].forEach(selector => {
        const el = document.querySelector(selector);
        if (el) el.style.display = '';
      });
      
      // Remover clases
      document.body.classList.remove('video-fullscreen-manual');
      videoElement.classList.remove('manual-fullscreen-active');
      
      console.log('Fullscreen manual DESACTIVADO');
    }
    
    function toggleManualFullscreen() {
      if (!videoElement) {
        videoElement = document.getElementById('gallery-main-video');
        if (!videoElement) return;
      }
      
      if (!isManualFullscreen) {
        enterManualFullscreen();
      } else {
        exitManualFullscreen();
      }
    }

    function setPopupZoomButtonState(active) {
      const button = document.querySelector('#popupMediaButtonsMobile [data-zoom-button]');
      if (!button) return;
      button.setAttribute('aria-pressed', String(active));
      const activeIcon = button.querySelector('.zoom-icon-active');
      const inactiveIcon = button.querySelector('.zoom-icon-inactive');
      if (activeIcon) activeIcon.classList.toggle('hidden', !active);
      if (inactiveIcon) inactiveIcon.classList.toggle('hidden', active);
      button.classList.toggle('bg-[#006764]', active);
      button.classList.toggle('bg-transparent', !active);
      button.classList.toggle('text-white', active);
      button.classList.toggle('text-[#212121]', !active);
    }
    
    // Hacer funciones globales
    window.exitManualFullscreen = exitManualFullscreen;
    window.enterManualFullscreen = enterManualFullscreen;
    window.toggleManualFullscreen = toggleManualFullscreen;
    
    document.addEventListener('DOMContentLoaded', function() {
      const closeBtn = document.getElementById('close-gallery-popup');
      const overlay = document.getElementById('gallery-popup-overlay');
      videoElement = document.getElementById('gallery-main-video');
      
      // 1. DETECTAR CLICK EN BOTÓN DE PANTALLA COMPLETA DEL VIDEO
      videoElement?.addEventListener('click', function(e) {
        // Verificar si el clic fue en el botón de pantalla completa
        const fullscreenBtn = e.target.closest('.fullscreen-button, [aria-label*="full"], [title*="full"]');
        if (fullscreenBtn || e.target.classList.contains('fullscreen-button')) {
          console.log('Botón de pantalla completa clickeado');
          e.preventDefault();
          e.stopPropagation();
          
          // Forzar fullscreen MANUALMENTE
          toggleManualFullscreen();
        }
      });
      
      // 2. DETECTAR EL EVENTO nativo de fullscreen del video
      videoElement?.addEventListener('webkitbeginfullscreen', function() {
        console.log('iOS comenzó fullscreen nativo');
        // En iOS, podemos intentar manejar esto
        setTimeout(toggleManualFullscreen, 100);
      });
      
      videoElement?.addEventListener('webkitendfullscreen', function() {
        console.log('iOS terminó fullscreen nativo');
        setTimeout(exitManualFullscreen, 100);
      });
      
      // 3. ESCUCHAR TECLA ESC PARA SALIR
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && isManualFullscreen) {
          exitManualFullscreen();
        }
      });
      
      // 4. ESCUCHAR CLICK EN VIDEO PARA SALIR (doble-tap en móvil)
      videoElement?.addEventListener('dblclick', function() {
        if (isManualFullscreen) {
          exitManualFullscreen();
        }
      });
      
      // 5. DETECTAR ROTACIÓN EN MÓVILES
      window.addEventListener('orientationchange', function() {
        if (isManualFullscreen) {
          // Re-aplicar estilos para nueva orientación
          videoElement.style.width = '100vw';
          videoElement.style.height = '100vh';
        }
      });
      
      // 6. CERRAR POPUP (también sale de fullscreen)
      function closePopup() {
        if (overlay) {
          if (isManualFullscreen) {
            exitManualFullscreen();
          }
          setPopupZoomButtonState(false);
          
          overlay.classList.add('hidden');
          document.body.classList.remove('popup-open');
          document.body.style.overflow = '';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.width = '';
          
          if (videoElement) {
            videoElement.pause();
            videoElement.currentTime = 0;
          }
          
          document.documentElement.style.paddingRight = '';
        }
      }
      
      closeBtn?.addEventListener('click', closePopup);
      
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
          closePopup();
        }
      });
      
      overlay?.addEventListener('click', function(e) {
        if (e.target === overlay || e.target.id === 'gallery-blurred-background') {
          closePopup();
        }
      });
    });

    function openGalleryPopup(mediaItems, indexMedia = 0) {
      const overlay = document.getElementById('gallery-popup-overlay');
      const imageElement = document.getElementById('gallery-main-image');
      videoElement = document.getElementById('gallery-main-video');
      const prevBtn = document.getElementById('gallery-prev');
      const nextBtn = document.getElementById('gallery-next');
      const counter = document.getElementById('gallery-counter');
      const mobileCounter = document.getElementById('popup-mobile-gallery-counter');
      const swipeContainer = document.getElementById('gallery-media-container');
      let current = indexMedia;
      let touchStartX = 0;
      let touchStartY = 0;
      let touchEndX = 0;
      let touchEndY = 0;
      
      function goPrev() {
        if (mediaItems.length === 0) return;
        if (isManualFullscreen) exitManualFullscreen();
        videoElement.pause();
        videoElement.currentTime = 0;
        current = current === 0 ? mediaItems.length - 1 : current - 1;
        updateMedia();
      }

      function goNext() {
        if (mediaItems.length === 0) return;
        if (isManualFullscreen) exitManualFullscreen();
        videoElement.pause();
        videoElement.currentTime = 0;
        current = current === mediaItems.length - 1 ? 0 : current + 1;
        updateMedia();
      }

      function handleTouchStart(event) {
        const touch = event.touches[0];
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
        touchEndX = touchStartX;
        touchEndY = touchStartY;
      }

      function handleTouchMove(event) {
        const touch = event.touches[0];
        touchEndX = touch.clientX;
        touchEndY = touch.clientY;
      }

      function handleTouchEnd() {
        const dx = touchEndX - touchStartX;
        const dy = touchEndY - touchStartY;
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          if (dx > 0) {
            goPrev();
          } else {
            goNext();
          }
        }
      }
      function isVideoUrl(url) {
        if (!url) return false;
        const videoExtensions = ['.mp4', '.webm', '.ogg', '.mov', '.avi', '.mkv'];
        const urlLower = typeof url === 'string' ? url.toLowerCase() : '';
        return videoExtensions.some(ext => urlLower.includes(ext));
      }

      function updateMedia() {
        if (!mediaItems.length || !imageElement || !videoElement || !counter || !prevBtn || !nextBtn) return;

        const currentItem = mediaItems[current];
        if (!currentItem) return;

        const isVideo = isVideoUrl(currentItem);

        imageElement.classList.add('hidden');
        videoElement.classList.add('hidden');

        if (isVideo) {
          videoElement.src = currentItem;
          videoElement.classList.remove('hidden');
          // Configurar estilos iniciales
          videoElement.style.position = '';
          videoElement.style.top = '';
          videoElement.style.left = '';
          videoElement.style.width = '';
          videoElement.style.height = '';
          videoElement.style.zIndex = '';
          videoElement.style.padding = '60px';
          videoElement.style.background = '#FFF';
          videoElement.style.margin = '0';
          videoElement.style.border = 'none';
        } else {
          
          imageElement.alt = 'Imagen galería';imageElement.src = currentItem;
          imageElement.classList.remove('hidden');
        }

        const label = (current + 1) + ' / ' + mediaItems.length;
        if (counter) counter.textContent = label;
        if (mobileCounter) mobileCounter.textContent = label;
      }

      prevBtn.replaceWith(prevBtn.cloneNode(true));
      nextBtn.replaceWith(nextBtn.cloneNode(true));
      
      const newPrevBtn = document.getElementById('gallery-prev');
      const newNextBtn = document.getElementById('gallery-next');
      
      newPrevBtn.addEventListener('click', function() {
        goPrev();
      });
      
      newNextBtn.addEventListener('click', function() {
        goNext();
      });

      if (swipeContainer && window.matchMedia('(max-width: 1024px)').matches) {
        swipeContainer.addEventListener('touchstart', handleTouchStart, { passive: true });
        swipeContainer.addEventListener('touchmove', handleTouchMove, { passive: true });
        swipeContainer.addEventListener('touchend', handleTouchEnd, { passive: true });
      }
      
      updateMedia();
      
      if (overlay) {
        overlay.classList.remove('hidden');
        setPopupZoomButtonState(true);
        
        const zoomButton = document.querySelector('#popupMediaButtonsMobile [data-zoom-button]');
        if (zoomButton) {
          // Remover listeners anteriores para evitar duplicados
          const newZoomButton = zoomButton.cloneNode(true);
          zoomButton.parentNode.replaceChild(newZoomButton, zoomButton);
          
          // Función para cerrar el popup con btn -zoom
          const closePopupFn = function() {
            if (overlay) {
              if (isManualFullscreen) {
                exitManualFullscreen();
              }
              setPopupZoomButtonState(false);
              
              overlay.classList.add('hidden');
              document.body.classList.remove('popup-open');
              document.body.style.overflow = '';
              document.body.style.position = '';
              document.body.style.top = '';
              document.body.style.width = '';
              
              if (videoElement) {
                videoElement.pause();
                videoElement.currentTime = 0;
              }
              
              document.documentElement.style.paddingRight = '';
            }
          };
          
          newZoomButton.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            closePopupFn();
          });
        }
        
        document.body.style.overflow = 'hidden';
        document.body.style.position = 'fixed';
        document.body.style.top = `-${window.scrollY}px`;
        document.body.style.width = '100%';
        document.body.classList.add('popup-open');
        
        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        if (scrollbarWidth > 0) {
          document.documentElement.style.paddingRight = `${scrollbarWidth}px`;
        }
      }
    }

    window.openGalleryPopup = openGalleryPopup;
</script>

