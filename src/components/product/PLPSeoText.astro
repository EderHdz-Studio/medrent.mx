---
interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

{description && (
  <section class="max-w-7xl mx-auto px-4 py-8">
    <div class="max-w-5xl">
      <h2 class="font-lato text-[14px] font-bold uppercase text-[var(--color-secondary)]">
        {title || "MEDRENT"}
      </h2>
      <p class="mt-2 font-lato text-[16px] font-normal leading-[24px] text-[var(--color-text-default)]">
        {description}
      </p>
    </div>
  </section>
)}
