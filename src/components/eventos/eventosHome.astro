---
// import { buildImageUrl } from '@lib/utils.js';
import dayjs from 'dayjs';
import 'dayjs/locale/es';

// Configurar dayjs en español
dayjs.locale('es');

const { dataEventos } = Astro.props;
---
<section class="w-full pt-4 pb-4 px-4 gap-4 md:pt-6 md:pb-6 md:px-6 md:gap-6 lg:pt-8 lg:pb-8 lg:px-8 lg:gap-6 xl:pt-8 xl:pb-8 xl:px-8 xl:gap-6 2xl:pt-8 2xl:pb-8 2xl:px-8 2xl:gap-6">
  <!-- Encabezado -->
  <div class="max-w-7xl mx-auto mb-8 text-center p-8 pb-0">
    <h3 class="text-[#8C0032] uppercase font-kallisto font-light text-[14px] md:text-[14px] mb-2">Eventos</h3>
    <h2 class="font-normal text-[28px] md:text-[28px] text-[#212121] mb-4">
      Nuestra tecnología, presente en los congresos líderes
    </h2>
  </div>

  <!-- Slider -->
  <div class="max-w-7xl mx-auto">
    <div id="eventos-slider" class="relative overflow-hidden">
      <div id="slides" class="relative transition-opacity duration-700">
        
        {dataEventos?.Eventos?.map((evento: any, index: number) => {
          // Formatear fechas
          const fechaInicio = dayjs(evento.FechaInicio);
          const fechaFin = dayjs(evento.FechaFin);
          
          let fechaTexto = '';
          if (fechaInicio.isSame(fechaFin, 'day')) {
            fechaTexto = fechaInicio.format('D [de] MMMM YYYY');
          } else if (fechaInicio.isSame(fechaFin, 'month')) {
            fechaTexto = `${fechaInicio.format('D')} y ${fechaFin.format('D [de] MMMM YYYY')}`;
          } else {
            fechaTexto = `${fechaInicio.format('D [de] MMMM YYYY')} al ${fechaFin.format('D [de] MMMM YYYY')}`;
          }
          
          return (
            <div class={`flex flex-col md:flex-row items-center gap-2 md:gap-8 fade-slide ${index === 0 ? 'active-slide' : ''}`}>
              <div class="w-full md:w-1/2">
                <img 
                  src={buildImageUrl(evento.Imagen?.url, '/images/eventos/default.webp')} 
                  alt={evento.Nombre || 'Evento'} 
                  class="rounded-[16px] w-full h-auto max-h-[600px] object-cover" 
                />
              </div>
              <div class="w-full md:w-1/2 text-[#212121] p-0 lg:px-16 flex flex-col">
                <h4 class="text-[#8C0032] uppercase font-kallisto text-sm mb-1">{evento.Tipo || ''}</h4>
                <h3 class="text-[28px] lg:text-[36px] font-bold mb-1">{evento.Nombre || ''}</h3>
                <h4 class="text-[28px] lg:text-[36px] font-normal mb-4">{evento.Evento || ''}</h4>
                <div class="flex items-center gap-2 mb-2 font-[16px]">
                  <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 21.5C11.656 21.5 11.336 21.323 11.153 21.032L7.19504 14.727C6.98904 14.4 6.79204 14.065 6.61604 13.722C5.34904 11.239 4.01504 7.58802 7.04804 4.55302C8.35804 3.24202 10.116 2.52002 12 2.52002C13.883 2.52002 15.642 3.24202 16.952 4.55202C20.002 7.60402 18.638 11.288 17.347 13.793C17.195 14.089 17.024 14.379 16.847 14.662L12.847 21.032C12.664 21.323 12.344 21.5 12 21.5ZM12 4.52002C10.65 4.52002 9.39404 5.03302 8.46204 5.96602C6.81104 7.61902 6.79104 9.66702 8.39704 12.812C8.54504 13.103 8.71404 13.386 8.88804 13.663L12 18.62L15.152 13.599C15.298 13.365 15.442 13.124 15.568 12.877C17.209 9.69502 17.199 7.62802 15.538 5.96602C14.605 5.03302 13.35 4.52002 12 4.52002Z" fill="#5A4043"/>
                    <path d="M12 12.5C10.346 12.5 9 11.154 9 9.5C9 7.846 10.346 6.5 12 6.5C13.654 6.5 15 7.846 15 9.5C15 11.154 13.654 12.5 12 12.5ZM12 8.5C11.449 8.5 11 8.949 11 9.5C11 10.051 11.449 10.5 12 10.5C12.551 10.5 13 10.051 13 9.5C13 8.949 12.551 8.5 12 8.5Z" fill="#5A4043"/>
                    <path d="M17 19.5H7V21.5H17V19.5Z" fill="#5A4043"/>
                  </svg>
                  <span class="text-[#5A4043]">{evento.TextoUbicacion || 'Ubicación por confirmar'}</span>
                </div>
                <div class="flex items-center gap-2 mb-6">
                  <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17 4.5V2.5H15V4.5H9V2.5H7V4.5H3V21.5H21V4.5H17ZM7 6.5V8.5H9V6.5H15V8.5H17V6.5H19V10.5H5V6.5H7ZM5 19.5V12.5H19V19.5H5Z" fill="#5A4043"/>
                  </svg>
                  <span class="text-[#5A4043]">{fechaTexto}</span>
                </div>

                <a href={evento.LinkUbicacion || '/eventos'} class="inline-flex items-center justify-center w-full md:w-fit bg-[#212121] text-white font-kallisto text-sm rounded hover:bg-[#333] transition" style="padding:12px 16px;gap:4px;">
                  Saber más
                  <svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13.44 5.465C13.3638 5.28174 13.2182 5.13611 13.035 5.06C12.9448 5.02157 12.848 5.00118 12.75 5H5.24995C5.05104 5 4.86028 5.07902 4.71962 5.21967C4.57897 5.36032 4.49995 5.55109 4.49995 5.75C4.49995 5.94891 4.57897 6.13968 4.71962 6.28033C4.86028 6.42098 5.05104 6.5 5.24995 6.5H10.9425L4.71745 12.7175C4.64716 12.7872 4.59136 12.8702 4.55329 12.9616C4.51521 13.053 4.49561 13.151 4.49561 13.25C4.49561 13.349 4.51521 13.447 4.55329 13.5384C4.59136 13.6298 4.64716 13.7128 4.71745 13.7825C4.78718 13.8528 4.87013 13.9086 4.96152 13.9467C5.05292 13.9847 5.15095 14.0043 5.24995 14.0043C5.34896 14.0043 5.44699 13.9847 5.53839 13.9467C5.62978 13.9086 5.71273 13.8528 5.78245 13.7825L12 7.5575V13.25C12 13.4489 12.079 13.6397 12.2196 13.7803C12.3603 13.921 12.551 14 12.75 14C12.9489 14 13.1396 13.921 13.2803 13.7803C13.4209 13.6397 13.5 13.4489 13.5 13.25V5.75C13.4988 5.65199 13.4784 5.55517 13.44 5.465Z" fill="white"/>
                  </svg>
                </a>

                {/* Controles solo en desktop/tablet */}
                  { dataEventos?.Eventos?.length > 1 && (
                <div class="hidden md:flex items-center gap-[24px] mt-8">
                  <div class="botones-glider flex justify-start gap-4 w-full md:w-auto">
                    <button aria-label="Anterior"  class="prevBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-black border border-black cursor-pointer transition hover:bg-black">
                      <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                        <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="#FFF"/>
                      </svg>
                    </button>
                    <label class="eventos-label text-black text-center font-kallisto text-[16px] font-light tracking-[2.5px]">1/{dataEventos?.Eventos?.length || 0}</label>
                    <button aria-label="Siguiente" class=" nextBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-black border border-black cursor-pointer transition hover:bg-black">
                      <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                        <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="#FFF"/>
                      </svg>
                    </button>
                  </div>
                </div>
                ) }
              </div>
            </div>
          );
        })}

       
        {/* Controles solo en mobile (debajo del slider) */}
        { dataEventos?.Eventos?.length > 1 && (
          <div class="flex md:hidden justify-center items-center gap-[24px] mt-12">
            <div class="botones-glider flex justify-center gap-4 w-full md:w-auto">
              <button aria-label="Anterior" class="prevBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-black border border-black cursor-pointer transition hover:bg-black">
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="#FFF"/>
                </svg>
              </button>
              <label  class="eventos-label text-black text-center font-kallisto text-[16px] font-light tracking-[2.5px]">1/{dataEventos?.Eventos?.length || 0}</label>
              <button aria-label="Siguiente" class="nextBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-black border border-black cursor-pointer transition hover:bg-black">
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="#FFF"/>
                </svg>
              </button>
            </div>
          </div>
        ) }

      </div>
    </div>
  </div>
</section>

<style>
  .fade-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
    z-index: 0;
  }

  .fade-slide.active-slide {
    opacity: 1;
    z-index: 10;
    position: relative;
  }
</style>


<script is:inline>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.fade-slide');
  const indicators = document.querySelectorAll('.indicator-dot');
  const prevBtns = document.querySelectorAll('.prevBtn');
  const nextBtns = document.querySelectorAll('.nextBtn');
  const eventosLabels = document.querySelectorAll('.eventos-label');

  function updateLabel() {
    eventosLabels.forEach(label => {
      label.textContent = `${currentSlide + 1}/${slides.length}`;
    });
  }

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('active-slide', i === index);
    });
    indicators.forEach((dot, i) => {
      if (i === index) {
        dot.classList.remove('bg-[#CCCCCC]');
        dot.classList.add('bg-[#8C0032]');
      } else {
        dot.classList.remove('bg-[#8C0032]');
        dot.classList.add('bg-[#CCCCCC]');
      }
    });
    updateLabel();
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    showSlide(currentSlide);
  }

  function prevSlide() {
    currentSlide = (currentSlide - 1 + slides.length) % slides.length;
    showSlide(currentSlide);
  }

  // Event listeners
  prevBtns.forEach(btn => btn.addEventListener('click', prevSlide));
  nextBtns.forEach(btn => btn.addEventListener('click', nextSlide));
  indicators.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentSlide = index;
      showSlide(currentSlide);
    });
  });

  // Initialize
  showSlide(currentSlide);
</script>
  