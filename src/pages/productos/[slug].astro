---
export const prerender = true;

Astro.response.headers.set("Cache-Control", "public, max-age=60");

import { getProducts, getProductBySlug } from "@server/api/products";
import { getPromotionSlides } from "@server/api/promotions";
import Layout from "@layouts/Layout.astro";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import ProductSlider from '@components/sections/ProductSlider.astro';
import FichaTecnica from '@components/product/TechnicalSheet.astro';
import ShareButtons from '@components/product/ShareButtons.astro';
import GalleryPopup from '@components/product/GalleryPopUp.astro';
import PopUpSolicitarCotizacion from '@components/popup/popUpSolicitarCotizacion.astro';
import ButtonPDPSticky from "@components/buttonPDPSticky.astro";
import ImageResponsive from "@components/media/ImageResponsive.astro";
import Newsletter from "@components/FormNewsletter.astro";
import EspecialidadesSlider from "@components/sections/EspecialidadesSlider.astro";
import PromotionSlider from "@components/sections/PromotionSlider.astro";
import { getHomeEspecialidadesForSlider } from "@lib/homeEspecialidades";
import { isUsableBrandSlug } from "@lib/brandSlug";
import ProductVariants from '@components/product/ProductVariants.astro';
import { getSiteConfig } from "@server/siteConfig";
import { getLocaleMeta, localizePath } from "@lib/locale";
const siteConfig = await getSiteConfig();

export async function getStaticPaths() {
  const products = await getProducts();

  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing product slug");
}

const product = await getProductBySlug(slug);

if (!product) {
  return Astro.redirect("/404");
}

const especialidadesSliderItems = getHomeEspecialidadesForSlider();
const promotionsData = await getPromotionSlides();

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const currentPathname = Astro.originPathname ?? Astro.url.pathname;
const localeMeta = getLocaleMeta(currentPathname);
const canonicalUrl = new URL(currentPathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = siteConfig?.favicon512x512?.url;
const heroImageUrl =
  Array.isArray(product.gallery) && product.gallery.length > 0
    ? product.gallery[0]
    : logoUrl;

const productId = `${baseUrl}/entity/product/${product.slug}#id`;
const offerId = `${baseUrl}/entity/offer/${product.slug}#offer`;
const homeUrl = new URL(localizePath("/", currentPathname), Astro.site).toString();
const productsUrl = new URL(localizePath("/productos", currentPathname), Astro.site).toString();
const brandPath = product.brand?.slug
  ? localizePath(`/nuestras-marcas/${product.brand.slug}`, currentPathname)
  : "";
const brandUrl = brandPath ? new URL(brandPath, Astro.site).toString() : "";
const item_variant  = product?.relatedProducts?.length + ' Canales, ' + product?.variants?.length + ' Derivaciones';
const firstVariant = Array.isArray((product as any)?.variants)
  ? (product as any).variants[0]
  : undefined;
const ratingValue =
  firstVariant?.ratingValue ??
  firstVariant?.rating ??
  firstVariant?.aggregateRating?.ratingValue;
const reviewCount =
  firstVariant?.reviewCount ??
  firstVariant?.reviews ??
  firstVariant?.aggregateRating?.reviewCount;

const pdpGraph: any[] = [
  {
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: `${product.name} | Equipo médico especializado | MedRent`,
    description:
      product.description ||
      `${product.name} | Equipo médico especializado de MedRent.`,
    isPartOf: { "@id": `${baseUrl}/#website` },
    about: { "@id": `${baseUrl}/#organization` },
    inLanguage: localeMeta.htmlLang,
    breadcrumb: { "@id": breadcrumbId },
    mainEntity: { "@id": productId },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: heroImageUrl,
    },
  },
  {
    "@type": ["Product", "MedicalDevice"],
    "@id": productId,
    name: product.name,
    description: product.description,
    image: heroImageUrl ? [heroImageUrl] : undefined,
    category: ["Medical Device"],
    brand:
      product.brand && isUsableBrandSlug(product.brand.slug)
        ? { "@type": "Brand", "@id": `${brandUrl}#brand` }
        : undefined,
    datePublished: product.createdAt,
    offers: { "@id": offerId },
  },
  {
    "@type": "Offer",
    "@id": offerId,
    url: canonicalUrl,
    availability: "https://schema.org/InStock",
    description: "Cotizacion disponible bajo solicitud a traves de contacto comercial.",
    businessFunction: "https://schema.org/Sell",
    eligibleCustomerType: "https://schema.org/BusinessCustomer",
    seller: { "@id": `${baseUrl}/#organization` },
  },
];

if (ratingValue && reviewCount) {
  pdpGraph.push({
    "@type": "AggregateRating",
    "@id": `${productId}#aggregateRating`,
    ratingValue,
    reviewCount,
  });
}

const pdpJsonLd = {
  "@context": "https://schema.org",
  "@graph": pdpGraph,
};

---
<Layout
  title={`${product.name} | Equipo médico especializado | MedRent`}
  description={product.description || `${product.name} | Equipo médico especializado de MedRent.`}
  keywords={`${product.name}; equipo médico; MedRent`}
  ogType="product"
  pageType="product"
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      items={[
        { name: 'Inicio', url: homeUrl },
        { name: 'Productos', url: productsUrl },
        { name: product.name, url: canonicalUrl },
      ]}
      id={breadcrumbId}
    />
    <script type="application/ld+json" set:html={JSON.stringify(pdpJsonLd)}></script>
  </Fragment>
  <Breadcrumb
    textColor="text-black"
    items={[
      { name: "INICIO", href: localizePath("/", currentPathname) },
      { name: "PRODUCTOS", href: localizePath("/productos", currentPathname) },
      { name: product.name.toUpperCase() }
    ]}
  />
  
  <!-- Contenido Principal del Producto -->
  <main class="max-w-7xl mx-auto px-4 py-8">
    <section class="max-w-7xl mx-auto py-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
        <!-- =========================
          GALERÍA
        ========================== -->
        <!-- Galería de imágenes mobile tipo Slide (solo mobile) -->
        <div class="flex flex-col lg:flex-row-reverse gap-4 lg:sticky lg:top-32 self-start items-center lg:items-start sm:hidden">
          <div class="w-full relative">
            {product.isNew && (
              <div class="badge-launch-mobile">
                LANZAMIENTO
                <span class="badge-launch-mobile-tail" aria-hidden="true"></span>
              </div>
            )}
            <div id="glider-slideimagenesProducto" class="w-full px-0 mobile-gallery-slider overflow-x-auto scroll-smooth" data-lenis-prevent data-gallery-images={JSON.stringify(product.gallery)}>
              <ul class="flex snap-x snap-mandatory">
                {product.gallery && product.gallery.map((item, index) => {
                  const isImage = /\.(jpg|jpeg|png|webp|gif|svg)$/i.test(item);
                  const isVideo = /\.(mp4|webm|ogg)$/i.test(item);
                  return (
                    <li class="w-full shrink-0 snap-start px-0">
                      <div class="w-full aspect-square rounded-[16px] bg-white overflow-hidden relative">
                        {isImage ? (
                          <ImageResponsive
                            src={item}
                            alt={product.name || "Imagen del producto"}
                            class="w-full h-full object-contain transition-all duration-500 cursor-pointer"
                            loading={index === 0 ? "eager" : "lazy"}
                            decoding="async"
                            fetchpriority={index === 0 ? "high" : "auto"}
                            id="main-image-mobile"
                            sizes="100vw"
                          />
                        ) : isVideo ? (
                          <video
                            src={item || '/images/Productos/default.webp'}
                            controls
                            class="w-full h-full object-contain transition-all duration-500 cursor-pointer"
                            id="main-image-mobile"
                            data-type="video"
                          />
                        ) : null}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>

          <div id="mediaButtonsMobile" class="flex flex-row items-center gap-2 left-0 bottom-0 w-full z-20 px-2 py-2 justify-between bg-transparent relative">
            <!-- Contenedor btns share -->
            <ShareButtons classNames="flex flex-row items-center gap-2 w-full justify-between" />

            <div class="absolute left-1/2 -translate-x-1/2 bottom-3 z-30 pointer-events-none">
              <span
                id="mobile-gallery-counter"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-[var(--color-text-default)] bg-[#F3FFFD] px-4 py-1 text-center text-[var(--color-text-default)] text-[16px] font-normal leading-6 tracking-[0.5px]"
              >
                1 / {product?.gallery?.length ?? 0}
              </span>
            </div>

            <button
              type="button"
              data-zoom-button
              aria-pressed="false"
              title="Activar zoom"
              class="w-10 h-10 flex items-center justify-center rounded cursor-pointer border border-[#212121] bg-transparent text-[#212121] transition-colors duration-200"
            >
                <svg class="zoom-icon-inactive w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14.9999 9.9999H11.9999V6.9999C11.9999 6.73469 11.8945 6.48033 11.707 6.2928C11.5195 6.10526 11.2651 5.9999 10.9999 5.9999C10.7347 5.9999 10.4803 6.10526 10.2928 6.2928C10.1053 6.48033 9.9999 6.73469 9.9999 6.9999V9.9999H6.9999C6.73469 9.9999 6.48033 10.1053 6.2928 10.2928C6.10526 10.4803 5.9999 10.7347 5.9999 10.9999C5.9999 11.2651 6.10526 11.5195 6.2928 11.707C6.48033 11.8945 6.73469 11.9999 6.9999 11.9999H9.9999V14.9999C9.9999 15.2651 10.1053 15.5195 10.2928 15.707C10.4803 15.8945 10.7347 15.9999 10.9999 15.9999C11.2651 15.9999 11.5195 15.8945 11.707 15.707C11.8945 15.5195 11.9999 15.2651 11.9999 14.9999V11.9999H14.9999C15.2651 11.9999 15.5195 11.8945 15.707 11.707C15.8945 11.5195 15.9999 11.2651 15.9999 10.9999C15.9999 10.7347 15.8945 10.4803 15.707 10.2928C15.5195 10.1053 15.2651 9.9999 14.9999 9.9999ZM21.7099 20.2899L17.9999 16.6099C19.44 14.8143 20.1374 12.5352 19.9487 10.2412C19.76 7.94721 18.6996 5.81269 16.9854 4.27655C15.2713 2.74041 13.0337 1.91941 10.7328 1.98237C8.43194 2.04534 6.24263 2.98747 4.61505 4.61505C2.98747 6.24263 2.04534 8.43194 1.98237 10.7328C1.91941 13.0337 2.74041 15.2713 4.27655 16.9854C5.81269 18.6996 7.94721 19.76 10.2412 19.9487C12.5352 20.1374 14.8143 19.44 16.6099 17.9999L20.2899 21.6799C20.3829 21.7736 20.4935 21.848 20.6153 21.8988C20.7372 21.9496 20.8679 21.9757 20.9999 21.9757C21.1319 21.9757 21.2626 21.9496 21.3845 21.8988C21.5063 21.848 21.6169 21.7736 21.7099 21.6799C21.8901 21.4934 21.9909 21.2442 21.9909 20.9849C21.9909 20.7256 21.8901 20.4764 21.7099 20.2899ZM10.9999 17.9999C9.61544 17.9999 8.26206 17.5894 7.11091 16.8202C5.95977 16.051 5.06256 14.9578 4.53275 13.6787C4.00293 12.3996 3.86431 10.9921 4.13441 9.63427C4.4045 8.27641 5.07119 7.02912 6.05016 6.05016C7.02912 5.07119 8.27641 4.4045 9.63427 4.13441C10.9921 3.86431 12.3996 4.00293 13.6787 4.53275C14.9578 5.06256 16.051 5.95977 16.8202 7.11091C17.5894 8.26206 17.9999 9.61544 17.9999 10.9999C17.9999 12.8564 17.2624 14.6369 15.9497 15.9497C14.6369 17.2624 12.8564 17.9999 10.9999 17.9999Z" fill="#212121"/>
                </svg>
                <svg class="zoom-icon-active hidden w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21.71 20.29L18 16.61C19.4401 14.8144 20.1375 12.5353 19.9488 10.2413C19.7601 7.94733 18.6997 5.81281 16.9855 4.27667C15.2714 2.74053 13.0338 1.91954 10.7329 1.9825C8.43207 2.04546 6.24275 2.98759 4.61517 4.61517C2.98759 6.24275 2.04546 8.43207 1.9825 10.7329C1.91954 13.0338 2.74053 15.2714 4.27667 16.9855C5.81281 18.6997 7.94733 19.7601 10.2413 19.9488C12.5353 20.1375 14.8144 19.4401 16.61 18L20.29 21.68C20.383 21.7738 20.4936 21.8482 20.6154 21.8989C20.7373 21.9497 20.868 21.9758 21 21.9758C21.132 21.9758 21.2627 21.9497 21.3846 21.8989C21.5065 21.8482 21.6171 21.7738 21.71 21.68C21.8903 21.4936 21.991 21.2444 21.991 20.985C21.991 20.7257 21.8903 20.4765 21.71 20.29ZM11 18C9.61556 18 8.26218 17.5895 7.11103 16.8203C5.95989 16.0511 5.06268 14.9579 4.53287 13.6788C4.00306 12.3997 3.86443 10.9923 4.13453 9.63439C4.40463 8.27653 5.07131 7.02925 6.05028 6.05028C7.02925 5.07131 8.27653 4.40463 9.63439 4.13453C10.9923 3.86443 12.3997 4.00306 13.6788 4.53287C14.9579 5.06268 16.0511 5.95989 16.8203 7.11103C17.5895 8.26218 18 9.61556 18 11C18 12.8565 17.2625 14.637 15.9498 15.9498C14.637 17.2625 12.8565 18 11 18ZM15 10H7.00003C6.73481 10 6.48046 10.1054 6.29292 10.2929C6.10538 10.4805 6.00003 10.7348 6.00003 11C6.00003 11.2652 6.10538 11.5196 6.29292 11.7071C6.48046 11.8947 6.73481 12 7.00003 12H15C15.2652 12 15.5196 11.8947 15.7071 11.7071C15.8947 11.5196 16 11.2652 16 11C16 10.7348 15.8947 10.4805 15.7071 10.2929C15.5196 10.1054 15.2652 10 15 10Z" fill="white"/>
                </svg>
            </button>
          </div>
        </div>

        <!-- Galería de Imágenes (solo tablet/desktop) -->
        <div id="galleryProducto" class="flex flex-col lg:flex-row-reverse gap-4 lg:sticky lg:top-32 self-start items-center lg:items-start hidden sm:flex">

          <!-- Imagen Principal -->  
          <div class="flex-1 aspect-squar bg-white rounded-lg overflow-hidden relative">
            {product.isNew && (
              <div class="absolute top-3 left-3 bg-[var(--color-primary)] text-white text-[11px] font-semibold px-3 py-1 rounded-[2px] z-20 w-fit">
                LANZAMIENTO
                <span class="absolute -bottom-2 right-2 w-0 h-0 border-l-[8px] border-l-transparent border-t-[8px] border-t-[var(--color-primary)]"></span>
              </div>    
            )}
            <div id="main-media-container" style="min-height: 400px; justify-content: center; display: flex; align-items: center; margin-bottom: 16px;">
              {product.gallery.length > 0 ? (
                <ImageResponsive
                  src={product.gallery[0]}
                  alt={product.name}
                  class="w-full h-full object-contain max-h-[600px] rounded-lg"
                  id="main-image-desktop"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  sizes="(min-width: 1024px) 50vw, 100vw"
                />
              ) : (
                <div class="text-gray-400">Sin imagen</div>
              )}
            </div>

            <div id="mediaButtons" class="flex flex-row items-center gap-2 left-0 bottom-0 w-full z-20 px-2 py-2 justify-between bg-transparent">
              <!-- Contenedor btns share -->
              <ShareButtons classNames="flex flex-row items-center gap-2 w-full justify-between" />
                
              <div class="w-10 h-10">
                <button
                  type="button"
                  data-zoom-button
                  aria-pressed="false"
                  title="Activar zoom"
                  class="w-10 h-10 flex absolute z-10 items-center justify-center rounded cursor-pointer border border-[#212121] bg-transparent text-[#212121] transition-colors duration-200"
                >
                  <svg class="zoom-icon-inactive w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M14.9999 9.9999H11.9999V6.9999C11.9999 6.73469 11.8945 6.48033 11.707 6.2928C11.5195 6.10526 11.2651 5.9999 10.9999 5.9999C10.7347 5.9999 10.4803 6.10526 10.2928 6.2928C10.1053 6.48033 9.9999 6.73469 9.9999 6.9999V9.9999H6.9999C6.73469 9.9999 6.48033 10.1053 6.2928 10.2928C6.10526 10.4803 5.9999 10.7347 5.9999 10.9999C5.9999 11.2651 6.10526 11.5195 6.2928 11.707C6.48033 11.8945 6.73469 11.9999 6.9999 11.9999H9.9999V14.9999C9.9999 15.2651 10.1053 15.5195 10.2928 15.707C10.4803 15.8945 10.7347 15.9999 10.9999 15.9999C11.2651 15.9999 11.5195 15.8945 11.707 15.707C11.8945 15.5195 11.9999 15.2651 11.9999 14.9999V11.9999H14.9999C15.2651 11.9999 15.5195 11.8945 15.707 11.707C15.8945 11.5195 15.9999 11.2651 15.9999 10.9999C15.9999 10.7347 15.8945 10.4803 15.707 10.2928C15.5195 10.1053 15.2651 9.9999 14.9999 9.9999ZM21.7099 20.2899L17.9999 16.6099C19.44 14.8143 20.1374 12.5352 19.9487 10.2412C19.76 7.94721 18.6996 5.81269 16.9854 4.27655C15.2713 2.74041 13.0337 1.91941 10.7328 1.98237C8.43194 2.04534 6.24263 2.98747 4.61505 4.61505C2.98747 6.24263 2.04534 8.43194 1.98237 10.7328C1.91941 13.0337 2.74041 15.2713 4.27655 16.9854C5.81269 18.6996 7.94721 19.76 10.2412 19.9487C12.5352 20.1374 14.8143 19.44 16.6099 17.9999L20.2899 21.6799C20.3829 21.7736 20.4935 21.848 20.6153 21.8988C20.7372 21.9496 20.8679 21.9757 20.9999 21.9757C21.1319 21.9757 21.2626 21.9496 21.3845 21.8988C21.5063 21.848 21.6169 21.7736 21.7099 21.6799C21.8901 21.4934 21.9909 21.2442 21.9909 20.9849C21.9909 20.7256 21.8901 20.4764 21.7099 20.2899ZM10.9999 17.9999C9.61544 17.9999 8.26206 17.5894 7.11091 16.8202C5.95977 16.051 5.06256 14.9578 4.53275 13.6787C4.00293 12.3996 3.86431 10.9921 4.13441 9.63427C4.4045 8.27641 5.07119 7.02912 6.05016 6.05016C7.02912 5.07119 8.27641 4.4045 9.63427 4.13441C10.9921 3.86431 12.3996 4.00293 13.6787 4.53275C14.9578 5.06256 16.051 5.95977 16.8202 7.11091C17.5894 8.26206 17.9999 9.61544 17.9999 10.9999C17.9999 12.8564 17.2624 14.6369 15.9497 15.9497C14.6369 17.2624 12.8564 17.9999 10.9999 17.9999Z" fill="#212121"/>
                  </svg>
                  <svg class="zoom-icon-active hidden w-6 h-6" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M21.71 20.29L18 16.61C19.4401 14.8144 20.1375 12.5353 19.9488 10.2413C19.7601 7.94733 18.6997 5.81281 16.9855 4.27667C15.2714 2.74053 13.0338 1.91954 10.7329 1.9825C8.43207 2.04546 6.24275 2.98759 4.61517 4.61517C2.98759 6.24275 2.04546 8.43207 1.9825 10.7329C1.91954 13.0338 2.74053 15.2714 4.27667 16.9855C5.81281 18.6997 7.94733 19.7601 10.2413 19.9488C12.5353 20.1375 14.8144 19.4401 16.61 18L20.29 21.68C20.383 21.7738 20.4936 21.8482 20.6154 21.8989C20.7373 21.9497 20.868 21.9758 21 21.9758C21.132 21.9758 21.2627 21.9497 21.3846 21.8989C21.5065 21.8482 21.6171 21.7738 21.71 21.68C21.8903 21.4936 21.991 21.2444 21.991 20.985C21.991 20.7257 21.8903 20.4765 21.71 20.29ZM11 18C9.61556 18 8.26218 17.5895 7.11103 16.8203C5.95989 16.0511 5.06268 14.9579 4.53287 13.6788C4.00306 12.3997 3.86443 10.9923 4.13453 9.63439C4.40463 8.27653 5.07131 7.02925 6.05028 6.05028C7.02925 5.07131 8.27653 4.40463 9.63439 4.13453C10.9923 3.86443 12.3997 4.00306 13.6788 4.53287C14.9579 5.06268 16.0511 5.95989 16.8203 7.11103C17.5895 8.26218 18 9.61556 18 11C18 12.8565 17.2625 14.637 15.9498 15.9498C14.637 17.2625 12.8565 18 11 18ZM15 10H7.00003C6.73481 10 6.48046 10.1054 6.29292 10.2929C6.10538 10.4805 6.00003 10.7348 6.00003 11C6.00003 11.2652 6.10538 11.5196 6.29292 11.7071C6.48046 11.8947 6.73481 12 7.00003 12H15C15.2652 12 15.5196 11.8947 15.7071 11.7071C15.8947 11.5196 16 11.2652 16 11C16 10.7348 15.8947 10.4805 15.7071 10.2929C15.5196 10.1054 15.2652 10 15 10Z" fill="white"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Miniaturas debajo de la imagen principal (tablet/desktop: 6 máx, overlay en la última) -->
          {product?.gallery && product.gallery.length > 1 && (
            <div class="relative w-full lg:w-24 flex-shrink-0 hidden sm:block py-6 lg:py-0">
                <div class="flex flex-row lg:flex-col gap-3 w-full lg:w-24 max-h-[420px] lg:max-h-fit overflow-y-auto justify-center" id="thumbnails-scroll" style="scrollbar-width: none; -ms-overflow-style: none; justify-content: center;">
                <style>
                    #thumbnails-scroll::-webkit-scrollbar { display: none; }
                </style>
                {(() => {
                  const total = product.gallery.length;
                  const maxThumbnails = 6;
                    return product.gallery.slice(0, maxThumbnails).map((imagen, index) => {
                      const isImage = /\.(jpg|jpeg|png|webp|gif|svg)$/i.test(imagen);
                      const isVideo = /\.(mp4|webm|ogg)$/i.test(imagen);
                      // Si es la última visible y hay más, muestra el overlay '+N'
                      if (index === maxThumbnails - 1 && total > maxThumbnails) {
                      return (
                        <div class="relative w-20 h-20 btnVerPopUpImagenes" data-imagenes={JSON.stringify(product.gallery)}>
                          <button
                            class="w-20 h-20 bg-white rounded overflow-hidden transition-colors cursor-pointer border border-[var(--color-secondary-light)] hover:border-[var(--color-primary)]"
                            style="min-height:80px; max-height:80px;"
                            data-gallery-popup="true"
                            data-start-index={index}
                            type="button"
                          >
