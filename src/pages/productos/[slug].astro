<script is:inline>
  // Botón Copiar URL (compartir)
  document.addEventListener('DOMContentLoaded', function() {
      // Desktop
      const copyBtnDesktop = document.getElementById('copy-url-btn');
      if (copyBtnDesktop) {
          copyBtnDesktop.addEventListener('click', async function(e) {
              e.preventDefault();
              try {
                  await navigator.clipboard.writeText(window.location.href);
                  const prevBg = copyBtnDesktop.style.backgroundColor;
                  copyBtnDesktop.style.backgroundColor = '#B60D45';
                  setTimeout(() => { copyBtnDesktop.style.backgroundColor = prevBg; }, 500);
              } catch (err) {
                  alert('No se pudo copiar la URL');
              }
          });
      }
      // Mobile
      const copyBtnMobile = document.getElementById('copy-url-btn-mobile');
      if (copyBtnMobile) {
          copyBtnMobile.addEventListener('click', async function(e) {
              e.preventDefault();
              try {
                  await navigator.clipboard.writeText(window.location.href);
                  const prevBg = copyBtnMobile.style.backgroundColor;
                  copyBtnMobile.style.backgroundColor = '#B60D45';
                  setTimeout(() => { copyBtnMobile.style.backgroundColor = prevBg; }, 500);
              } catch (err) {
                  alert('No se pudo copiar la URL');
              }
          });
      }
  });
</script>

<!-- BTN SHARE -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.relative').forEach(container => {
      const toggleBtn = container.querySelector('.share-toggle');
      const closeBtn = container.querySelector('.share-close');
      const actions = container.querySelector('.share-actions');
      const tooltip = container.querySelector('.copy-tooltip');
      const copyBtn = container.querySelector('.copy-url');
      
      const mediaButtons = container.closest('#mediaButtonsMobile, #mediaButtons');
      const galleryCounter = mediaButtons?.querySelector('#mobile-gallery-counter');
      
      if (!toggleBtn) return;
      
      const url = encodeURIComponent(window.location.href);
      
      const facebook = container.querySelector('.share-facebook');
      const whatsapp = container.querySelector('.share-whatsapp');
      const twitter = container.querySelector('.share-twitter');
      const linkedin = container.querySelector('.share-linkedin');
      
      if (facebook) facebook.href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
      if (whatsapp) whatsapp.href = `https://wa.me/?text=${url}`;
      if (twitter) twitter.href = `https://twitter.com/intent/tweet?url=${url}`;
      if (linkedin) linkedin.href = `https://www.linkedin.com/shareArticle?mini=true&url=${url}`;
      
      // Estado inicial: actions ocultos y NO clickeables
      actions.style.pointerEvents = 'none';
      
      toggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleBtn.classList.add('opacity-0', 'scale-90', 'pointer-events-none');
        actions.classList.remove('opacity-0', 'scale-95');
        actions.classList.add('opacity-100', 'scale-100');
        actions.style.pointerEvents = 'auto'; // Permitir clicks cuando está visible
        if (galleryCounter) galleryCounter.style.opacity = '0';
      });
      
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleBtn.classList.remove('opacity-0', 'scale-90', 'pointer-events-none');
        actions.classList.add('opacity-0', 'scale-95');
        actions.classList.remove('opacity-100', 'scale-100');
        actions.style.pointerEvents = 'none'; // Deshabilitar clicks cuando está oculto
        if (galleryCounter) galleryCounter.style.opacity = '1';
      });
      
      copyBtn?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        tooltip.classList.remove('opacity-0');
        tooltip.classList.add('opacity-100');
        setTimeout(() => {
          tooltip.classList.add('opacity-0');
          tooltip.classList.remove('opacity-100');
        }, 1500);
      });
    });
  });
</script>

<!-- BTN ZOOM -->
<script is:inline>
  let zoomActive = false;
  let currentMainImage = null;

  function getZoomButtons() {
    return Array.from(document.querySelectorAll('[data-zoom-button]'));
  }

  function updateZoomButtonState(button, active) {
    button.setAttribute('aria-pressed', String(active));
    button.classList.toggle('bg-[var(--color-primary)]', active);
    button.classList.toggle('bg-transparent', !active);
    button.classList.toggle('text-white', active);
    button.classList.toggle('text-[#212121]', !active);

    const activeIcon = button.querySelector('.zoom-icon-active');
    const inactiveIcon = button.querySelector('.zoom-icon-inactive');
    if (activeIcon) activeIcon.classList.toggle('hidden', !active);
    if (inactiveIcon) inactiveIcon.classList.toggle('hidden', active);
  }

  function isTouchGalleryScreen() {
    return window.matchMedia('(max-width: 1023px)').matches;
  }

  function getMobileGalleryImages() {
    const slider = document.getElementById('glider-slideimagenesProducto');
    if (!slider) return [];
    try {
      return JSON.parse(slider.dataset.galleryImages || '[]');
    } catch (error) {
      return [];
    }
  }

  function getCurrentMobileImageIndex() {
    const slider = document.getElementById('glider-slideimagenesProducto');
    const images = getMobileGalleryImages();
    if (!slider || !images.length) return 0;
    const width = slider.clientWidth || 1;
    const index = Math.round(slider.scrollLeft / width);
    return Math.min(Math.max(index, 0), images.length - 1);
  }

  function initZoom() {
    const zoomButtons = getZoomButtons();
    const mainImage = document.getElementById('main-image-desktop');
    if (!zoomButtons.length) return;

    currentMainImage?.removeEventListener('mousemove', handleMouseMove);
    currentMainImage?.removeEventListener('mouseleave', handleMouseLeave);

    if (mainImage) {
      currentMainImage = mainImage;
      currentMainImage.style.cursor = zoomActive ? 'zoom-in' : 'default';
      currentMainImage.style.transform = 'scale(1)';
      currentMainImage.style.transformOrigin = 'center';
      currentMainImage.style.transition = 'transform 0.2s ease';
    } else {
      currentMainImage = null;
    }

    zoomButtons.forEach((button) => {
      button.removeEventListener('click', handleZoomClick);
      button.addEventListener('click', handleZoomClick);
      updateZoomButtonState(button, zoomActive);
    });

    if (currentMainImage) {
      currentMainImage.addEventListener('mousemove', handleMouseMove);
      currentMainImage.addEventListener('mouseleave', handleMouseLeave);
    }
  }

  function handleZoomClick(event) {
    event.preventDefault();

    if (isTouchGalleryScreen()) {
      const images = getMobileGalleryImages();
      const index = getCurrentMobileImageIndex();
      if (Array.isArray(images) && images.length && typeof window.openGalleryPopup === 'function') {
        window.openGalleryPopup(images, index);
      }
      return;
    }

    zoomActive = !zoomActive;
    currentMainImage.style.cursor = zoomActive ? 'zoom-in' : 'default';
    if (!zoomActive) {
      currentMainImage.style.transform = 'scale(1)';
      currentMainImage.style.transformOrigin = 'center';
    }

    getZoomButtons().forEach((button) => updateZoomButtonState(button, zoomActive));
  }

  function handleMouseMove(event) {
    if (!zoomActive || !currentMainImage) return;
    const rect = currentMainImage.getBoundingClientRect();
    const x = ((event.clientX - rect.left) / rect.width) * 100;
    const y = ((event.clientY - rect.top) / rect.height) * 100;
    currentMainImage.style.transformOrigin = `${x}% ${y}%`;
    currentMainImage.style.transform = 'scale(2)';
  }

  function handleMouseLeave() {
    if (zoomActive && currentMainImage) {
      currentMainImage.style.transform = 'scale(1)';
    }
  }

  document.addEventListener('DOMContentLoaded', initZoom);
  window.reinitZoom = initZoom;
</script>

<!-- Slider mobile -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Slider mobile
    const slider = document.getElementById('glider-slideimagenesProducto');
    const counter = document.getElementById('mobile-gallery-counter');
    if (slider && counter) {
      const slides = slider.querySelectorAll('li');
      const total = slides.length;
      if (total) {
        let rafId = 0, snapTimer = 0;
        const updateCounter = () => {
          const width = slider.clientWidth || 1;
          const index = Math.min(total - 1, Math.max(0, Math.round(slider.scrollLeft / width)));
          counter.textContent = `${index + 1} / ${total}`;
          return { width, index };
        };
        const onScroll = () => {
          if (rafId) return;
          rafId = requestAnimationFrame(() => {
            const { width, index } = updateCounter();
            if (snapTimer) clearTimeout(snapTimer);
            snapTimer = setTimeout(() => slider.scrollTo({ left: index * width, behavior: 'smooth' }), 80);
            rafId = 0;
          });
        };
        slider.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', updateCounter);
        updateCounter();
      }
    }

    // Miniaturas desktop - cambiar imagen principal
    const thumbnails = document.querySelectorAll('[data-thumbnail]:not([data-gallery-popup])');
    const mainMediaContainer = document.getElementById('main-media-container');
    
    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', function() {
        const newSrc = this.dataset.thumbnail;
        const type = this.dataset.type;
        if (mainMediaContainer && newSrc) {
          if (type === 'image') {
            mainMediaContainer.innerHTML = `<img src='${newSrc}' alt='' class='w-full h-full object-contain max-h-[600px] rounded-lg' id='main-image-desktop' data-type='image' />`;
          } else if (type === 'video') {
            mainMediaContainer.innerHTML = `<video src='${newSrc}' controls class='w-full h-full object-contain max-h-[600px] rounded-lg' id='main-image-desktop' data-type='video'></video>`;
          }
          if (window.reinitZoom) window.reinitZoom();
          
          document.querySelectorAll('[data-thumbnail]').forEach(t => {
            t.className = 'w-20 h-20 bg-white rounded overflow-hidden transition-colors cursor-pointer border border-[var(--color-secondary-light)] hover:border-[var(--color-primary)]';
          });
          this.className = 'w-20 h-20 bg-white rounded overflow-hidden transition-colors cursor-pointer border-3 border-[var(--color-primary)]';
        }
      });
    });

    // Popup galería
    const popupBtn = document.querySelector('[data-gallery-popup="true"]');
    if (popupBtn) {
      popupBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        const container = this.closest('.btnVerPopUpImagenes');
        const images = container?.dataset.imagenes ? JSON.parse(container.dataset.imagenes) : [];
        if (window.openGalleryPopup) {
          window.openGalleryPopup(images, 5);
        }
      });
    }
  });
</script>

<!-- Pop up -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const openBtn = document.getElementById('open-event-popup');
    
    if (openBtn) {
      openBtn.addEventListener('click', function(e) {
        e.preventDefault();
        // Disparar un evento personalizado que escuche el popup
        document.dispatchEvent(new CustomEvent('open-event-popup'));
      });
    }
  });
</script>

