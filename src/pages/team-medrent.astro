---
/**
 * Ruta corta compartida en redes / enlaces legacy.
 * - `prerender: true` solo emite HTML con meta refresh (no 301 HTTP).
 * - SSR devuelve 301 real y registra la ruta en `.vercel/output/config.json` → `_render`.
 * `vercel.json` redirects no se fusionan con el Build Output API de este adapter.
 */
export const prerender = false;

import { localizeRedirect } from "@lib/locale";

return Astro.redirect(localizeRedirect("/blog/autor/team-medrent", Astro.originPathname ?? Astro.url.pathname), 301);
---
