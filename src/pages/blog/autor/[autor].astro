---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import { strapiFetch } from "@server/strapiClient";
import ArticleCard from '@components/blog/articleCard.astro';
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { getSiteConfig } from "@server/siteConfig";
const siteConfig = await getSiteConfig();
import { buildClassificationTagByArticleKeyMap } from '@lib/blog/classification';
import {
  type NormalizedBlogArticle,
  type NormalizedWriter,
  normalizeBlogArticleFromApi,
  normalizeWriterFromApi,
  isBlogArticleListed,
} from "@lib/strapi/blogArticle";

const TEAM_MEDRENT_SLUG = "team-medrent";

/** Copy hero perfil colectivo — Wireframes Medrent (node 526:2818). */
const TEAM_FIGMA_INTRO_P1 =
  "Los artículos de este blog son elaborados por el equipo de Medrent, un grupo multidisciplinario especializado en tecnología médica y diagnóstico.";
const TEAM_FIGMA_INTRO_P2 =
  "Contamos con el respaldo y la colaboración de médicos reconocidos en la industria de la salud, quienes aportan su experiencia clínica para garantizar la precisión y relevancia de cada publicación.";

const autorParam = Astro.params.autor?.trim();
if (!autorParam) {
  return Astro.redirect("/404");
}

let articlesResponse: { data?: unknown[] } = { data: [] };
try {
  articlesResponse = await strapiFetch(
    "/blog-articles?populate[heroImage]=true&populate[speciality]=true&populate[writer][populate]=*&sort=publishedAt:desc&pagination[pageSize]=2000",
  );
} catch {
  try {
    articlesResponse = await strapiFetch(
      "/blog-articles?populate=*&sort=publishedAt:desc&pagination[pageSize]=2000",
    );
  } catch {
    /** Sin CMS, el perfil colectivo sigue siendo una URL válida; otros autores no se pueden resolver. */
    if (autorParam !== TEAM_MEDRENT_SLUG) {
      return Astro.redirect("/404");
    }
    articlesResponse = { data: [] };
  }
}

const raw = Array.isArray(articlesResponse.data) ? articlesResponse.data : [];
const articles: NormalizedBlogArticle[] = raw
  .map((row) => normalizeBlogArticleFromApi(row))
  .filter((a): a is NormalizedBlogArticle => a != null)
  .filter(isBlogArticleListed);

let author: {
  slug: string;
  fullName?: string;
  shortDescription?: string;
  longDescription?: unknown;
  heroImage?: { url?: string };
  speciality?: string;
  articles: NormalizedBlogArticle[];
};

if (autorParam === TEAM_MEDRENT_SLUG) {
  /**
   * En Strapi suele existir un Writer con slug `team-medrent` (histórico: getStaticPaths agrupaba por ese slug).
   * Además, en plantillas el fallback sin escritor enlaza a esta misma URL.
   * Hay que unir ambos conjuntos; si solo filtráramos "sin slug", desaparecerían los artículos del autor CMS.
   */
  const withTeamSlug = articles.filter((a) => a.writer?.slug === TEAM_MEDRENT_SLUG);
  const withoutWriterSlug = articles.filter((a) => {
    const s = a.writer?.slug;
    return typeof s !== "string" || s.trim().length === 0;
  });
  const mergedByArticleSlug = new Map<string, NormalizedBlogArticle>();
  let noSlugIdx = 0;
  for (const a of [...withTeamSlug, ...withoutWriterSlug]) {
    const key =
      typeof a.slug === "string" && a.slug.length > 0 ? a.slug : `__ns_${noSlugIdx++}`;
    mergedByArticleSlug.set(key, a);
  }
  const teamArticles = Array.from(mergedByArticleSlug.values());

  const w: NormalizedWriter | undefined = withTeamSlug[0]?.writer;
  author = {
    slug: TEAM_MEDRENT_SLUG,
    fullName: w?.fullName || "Team Medrent",
    shortDescription:
      w?.shortDescription ||
      `${TEAM_FIGMA_INTRO_P1} ${TEAM_FIGMA_INTRO_P2}`,
    longDescription: w?.longDescription ?? [],
    heroImage: w?.heroImage,
    speciality: (w?.speciality && w.speciality.trim()) || "BACKOFFICE",
    articles: teamArticles,
  };
} else {
  // BUSCAR AUTOR PRIMERO EN ARTÍCULOS
  const forSlug = articles.filter((a) => a.writer?.slug === autorParam);
  
  if (forSlug.length > 0) {
    // El autor tiene artículos
    const w: NormalizedWriter | undefined = forSlug[0].writer;
    author = {
      slug: autorParam,
      fullName: w?.fullName,
      shortDescription: w?.shortDescription,
      longDescription: w?.longDescription,
      heroImage: w?.heroImage,
      speciality: w?.speciality,
      articles: forSlug,
    };
  } else {
    // EL AUTOR NO TIENE ARTÍCULOS - Buscar en endpoint /writers
    try {
      const writerRes = await strapiFetch(
        `/writers?filters[slug][$eq]=${encodeURIComponent(autorParam)}&populate=*`
      );
      const rows = writerRes?.data;
      const rawWriter = Array.isArray(rows) && rows[0] ? rows[0] : null;
      const nw = normalizeWriterFromApi(rawWriter);
      
      if (nw) {
        // Autor encontrado en Strapi, pero sin artículos
        author = {
          slug: autorParam,
          fullName: nw.fullName,
          shortDescription: nw.shortDescription,
          longDescription: nw.longDescription,
          heroImage: nw.heroImage,
          speciality: nw.speciality,
          articles: [], // Array vacío - sin artículos
        };
      } else {
        // No existe el autor en Strapi
        return Astro.redirect("/404");
      }
    } catch {
      return Astro.redirect("/404");
    }
  }
}

function articleDateMs(a: NormalizedBlogArticle) {
  return new Date(a.publishedAt || a.createdAt || 0).getTime();
}

const requestUrl = new URL(Astro.request.url);
const sortParam = requestUrl.searchParams.get("sort") || "published_desc";
const authorsListPage = Math.max(
  1,
  parseInt(requestUrl.searchParams.get("authorsPage") || "1", 10) || 1,
);

let displayArticles = [...author.articles];
if (sortParam === "published_asc") {
  displayArticles.sort((a, b) => articleDateMs(a) - articleDateMs(b));
} else if (sortParam === "title_asc") {
  displayArticles.sort((a, b) =>
    (a.title || "").localeCompare(b.title || "", "es", { sensitivity: "base" }),
  );
} else {
  displayArticles.sort((a, b) => articleDateMs(b) - articleDateMs(a));
}

type OtherAuthor = {
  slug: string;
  fullName?: string;
  heroImage?: { url?: string };
  speciality?: string;
};
const otherBySlug = new Map<string, OtherAuthor>();
for (const a of articles) {
  const w = a.writer;
  const s = w?.slug;
  if (typeof s !== "string" || !s.trim() || s === TEAM_MEDRENT_SLUG) continue;
  if (s === autorParam) continue;
  if (!otherBySlug.has(s)) {
    otherBySlug.set(s, {
      slug: s,
      fullName: w?.fullName,
      heroImage: w?.heroImage,
      speciality: w?.speciality,
    });
  }
}
const otherAuthorsAll = Array.from(otherBySlug.values()).sort((x, y) =>
  (x.fullName || x.slug).localeCompare(y.fullName || y.slug, "es", {
    sensitivity: "base",
  }),
);
const AUTHORS_PER_PAGE = 7;
const authorsTotalPages = Math.max(1, Math.ceil(otherAuthorsAll.length / AUTHORS_PER_PAGE));
const authorsPageSafe = Math.min(authorsListPage, authorsTotalPages);
const otherAuthorsSlice = otherAuthorsAll.slice(
  (authorsPageSafe - 1) * AUTHORS_PER_PAGE,
  authorsPageSafe * AUTHORS_PER_PAGE,
);

function withQuery(overrides: Record<string, string | null>) {
  const u = new URL(Astro.request.url);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === "") u.searchParams.delete(k);
    else u.searchParams.set(k, v);
  }
  const q = u.searchParams.toString();
  return q ? `${u.pathname}?${q}` : u.pathname;
}

let classificationTagByArticleKey = new Map<string, string>();
try {
  const clsRes = await strapiFetch(
    "/article-classifications?pagination[pageSize]=100&sort=tag:asc&populate[articles]=true",
  );
  if (Array.isArray(clsRes?.data)) {
    classificationTagByArticleKey = buildClassificationTagByArticleKeyMap(clsRes.data);
  }
} catch {
  try {
    const clsRes = await strapiFetch(
      "/article-classifications?pagination[pageSize]=100&sort=tag:asc",
    );
    if (Array.isArray(clsRes?.data)) {
      classificationTagByArticleKey = buildClassificationTagByArticleKeyMap(clsRes.data);
    }
  } catch {
    classificationTagByArticleKey = new Map();
  }
}

const authorName = author.fullName || "Autor";
const breadcrumbItems = [
  { name: "INICIO", href: "/" },
  { name: "BLOG", href: "/blog" },
  { name: "AUTOR" },
];

function pickMediaUrl(m?: { url?: string }): string | undefined {
  const u = m?.url;
  return typeof u === "string" && u.trim().length > 0 ? u : undefined;
}

/** Imagen del CMS (hero/cover del Writer o avatar); sin inventar assets locales. */
let authorPortraitUrl: string | undefined;
if (autorParam === TEAM_MEDRENT_SLUG) {
  for (const a of author.articles) {
    const w = a.writer;
    if (!w) continue;
    authorPortraitUrl = pickMediaUrl(w.heroImage) || pickMediaUrl(w.avatar);
    if (authorPortraitUrl) break;
  }
} else {
  const w = author.articles[0]?.writer;
  authorPortraitUrl = pickMediaUrl(w?.heroImage) || pickMediaUrl(w?.avatar);
}

/**
 * Misma entrada que en el admin (`api::writer.writer`): a veces la relación
 * writer dentro de `blog-articles` no trae todos los medios; el listado `/writers` sí.
 */
if (!authorPortraitUrl) {
  try {
    const wRes = await strapiFetch(
      `/writers?filters[slug][$eq]=${encodeURIComponent(autorParam)}&populate=*`,
    );
    const rows = wRes?.data;
    const rawWriter = Array.isArray(rows) && rows[0] ? rows[0] : null;
    const nw = normalizeWriterFromApi(rawWriter);
    if (nw) {
      authorPortraitUrl = pickMediaUrl(nw.heroImage) || pickMediaUrl(nw.avatar);
    }
  } catch {
    /** Endpoint no público o UID distinto en el proyecto. */
  }
}

const useTealIsotypeHero = !authorPortraitUrl;
const showTeamFigmaIntro =
  autorParam === TEAM_MEDRENT_SLUG &&
  (!Array.isArray(author.longDescription) || author.longDescription.length === 0);

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
/** Misma ruta que `Layout.astro` (origen actual del documento; evita URL absoluta rota en preview). */
const heroBrandLogoSrc = siteConfig?.favicon512x512?.url;
const logoUrl = `${baseUrl}${heroBrandLogoSrc}`;
const authorHeroImageUrl = authorPortraitUrl || logoUrl;
const authorSlug = author.slug;
const personId = `${baseUrl}/blog/autor/${authorSlug}#person`;
const postlistId = `${canonicalUrl}#postlist`;

/** Paginación en cliente (mismo criterio que PLP de productos). */
const AUTHOR_GRID_PAGE_SIZE = 9;
const totalAuthorArticles = displayArticles.length;
const initialAuthorArticlesShown = Math.min(AUTHOR_GRID_PAGE_SIZE, totalAuthorArticles);

let todosEscritores: any[] = [];

try {
  const response = await strapiFetch('/writers?populate[avatar]=true');
  todosEscritores = Array.isArray(response?.data) ? response.data : [];
  // console.log('Escritores cargados:', todosEscritores.length);
  // console.log('Primer escritor:', todosEscritores[0]);
} catch (error) {
  // console.error('Error fetching writers:', error);
  todosEscritores = [];
}
---

<Layout
  title={`${authorName} | Autor en Blog MedRent`}
  description={author?.shortDescription || "Perfil de autor del Blog MedRent con artículos de tecnología médica."}
  keywords={`${authorName}; blog MedRent; tecnología médica`}
  pageType="blog"
  ogImage={authorHeroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      id={breadcrumbId}
      items={[
        { name: "Inicio", url: `${baseUrl}/` },
        { name: "Blog", url: `${baseUrl}/blog` },
        { name: authorName, url: canonicalUrl },
      ]}
    />
    <script type="application/ld+json" set:html={
      (() => {
        const list = displayArticles;
        const slice = list.slice(0, 10);
        const itemListElement = slice.map((a, index) => {
          const postUrl = a?.slug ? `${baseUrl}/blog/${a.slug}` : canonicalUrl;
          return {
            "@type": "ListItem",
            position: index + 1,
            url: postUrl,
            item: {
              "@type": "BlogPosting",
              "@id": `${postUrl}#post`,
              headline: a?.title || "Blog MedRent",
              datePublished: a?.publishedAt || a?.createdAt,
            },
          };
        });

        return JSON.stringify({
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "WebPage",
              "@id": `${canonicalUrl}#webpage`,
              url: canonicalUrl,
              name: `${authorName} | Autor en Blog MedRent`,
              description:
                author?.shortDescription ||
                "Perfil de autor del Blog MedRent con artículos de tecnología médica.",
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": `${baseUrl}/#organization` },
              inLanguage: "es-MX",
              breadcrumb: { "@id": breadcrumbId },
              mainEntity: { "@id": personId },
              primaryImageOfPage: {
                "@type": "ImageObject",
                url: authorHeroImageUrl,
              },
            },
            {
              "@type": "Person",
              "@id": personId,
              name: authorName,
              description: author?.shortDescription,
              image: authorPortraitUrl
                ? {
                    "@type": "ImageObject",
                    url: authorPortraitUrl,
                  }
                : undefined,
              url: canonicalUrl,
              worksFor: { "@id": `${baseUrl}/#organization` },
            },
            {
              "@type": "ProfilePage",
              "@id": `${canonicalUrl}#profile`,
              url: canonicalUrl,
              name: `${authorName} — Autor`,
              description: author?.shortDescription,
              isPartOf: { "@id": `${baseUrl}/#website` },
              publisher: { "@id": `${baseUrl}/#organization` },
              inLanguage: "es-MX",
              breadcrumb: { "@id": breadcrumbId },
              mainEntity: { "@id": personId },
            },
            {
              "@type": "ItemList",
              "@id": postlistId,
              name: `Artículos de ${authorName}`,
              itemListOrder:
                "https://schema.org/ItemListOrderDescending",
              numberOfItems: displayArticles.length,
              itemListElement,
            },
          ],
        });
      })()
    }></script>
  </Fragment>

  <Fragment slot="metas">
  </Fragment>

  <section class="heroAutor relative mx-auto w-full max-w-[1280px] bg-[var(--color-secondary-light)] rounded-b-[24px]">
    <div class="containerHero flex w-full flex-col items-stretch gap-6 px-4 pb-10 pt-20 sm:px-6 md:flex-row md:items-center md:gap-6 md:px-8 md:py-16 lg:px-8">
      <div class="breadcrumb-fixed-wrapper pointer-events-auto absolute left-0 top-0 z-30 w-full max-w-7xl px-4 sm:px-6 md:px-8">
        <Breadcrumb textColor="text-dark" surface="light" items={breadcrumbItems} />
      </div>

      <div class="flex w-full flex-[1] flex-col items-start gap-2 px-0 py-6 text-left md:px-8 md:py-6">
        {author.speciality ? (
          <p class="font-lato text-[14px] font-medium leading-5 tracking-[0.1px] text-[var(--color-primary)] uppercase">
            {author.speciality}
          </p>
        ) : null}
        <h1 class="font-lato text-[32px] font-bold leading-10 text-[var(--color-text-default)]">
          {authorName}
        </h1>
        {showTeamFigmaIntro ? (
          <div class="mt-2 max-w-prose space-y-4 font-lato text-[16px] leading-6 tracking-[0.5px] text-[var(--color-text-default)]">
            <p class="mb-0 font-bold">{TEAM_FIGMA_INTRO_P1}</p>
            <p class="mb-0">{TEAM_FIGMA_INTRO_P2}</p>
          </div>
        ) : (
          <>
            {autorParam !== TEAM_MEDRENT_SLUG && author.shortDescription ? (
              <p class="mt-2 max-w-prose font-lato text-[16px] font-normal leading-6 tracking-[0.5px] text-[var(--color-green-dark)]">
                {author.shortDescription}
              </p>
            ) : null}
            {Array.isArray(author.longDescription) && author.longDescription.length > 0 ? (
              <div class="mt-4 max-w-prose space-y-3 font-lato text-[16px] font-normal leading-6 tracking-[0.5px] text-[var(--color-text-default)]">
                <BlocksRenderer content={author.longDescription} />
              </div>
            ) : null}
          </>
        )}
      </div>

      <div class="flex w-full flex-[1] justify-center md:mt-0">
        {useTealIsotypeHero ? (
          <div class="flex min-h-[280px] w-full max-w-[560px] items-center justify-center rounded-[24px] bg-[var(--color-primary)] px-8 py-10 md:min-h-[364px]">
            <img
              src={heroBrandLogoSrc}
              alt="MedRent"
              width={200}
              height={200}
              class="h-auto w-full max-h-[200px] max-w-[220px] object-contain object-center brightness-0 invert"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        ) : (
          <div class="w-full max-w-[560px] overflow-hidden rounded-[24px] shadow-md">
            <img
              src={authorPortraitUrl!}
              alt={authorName}
              width={512}
              height={364}
              class="h-auto max-h-[364px] w-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )}
      </div>
    </div>
  </section>

  <main class="mx-auto w-full max-w-[1280px] px-4 py-6 sm:px-6 md:px-8 md:py-8">
    <section class="flex w-full max-w-[1216px] flex-col gap-6">
      <div class="flex flex-col items-stretch justify-end gap-4 pt-6 sm:flex-row sm:items-end sm:justify-between">
        <div class="flex min-w-0 flex-col gap-1">
          <h2 class="font-lato text-[32px] font-bold leading-10 text-[var(--color-text-default)]">
            {author.articles.length}{" "}
            {author.articles.length === 1 ? "Artículo" : "Artículos"}
          </h2>
          {author.articles.length > 0 ? (
            <p
              id="autor-articles-count-top"
              class="font-lato text-[16px] font-normal leading-6 tracking-[0.5px] text-[var(--color-text-default)]"
            >
              Mostrando {initialAuthorArticlesShown} de {totalAuthorArticles}
            </p>
          ) : null}
        </div>
        <form method="get" class="flex shrink-0 items-center gap-2 rounded-lg border border-solid border-[#171d1c] px-4 py-2 font-lato">
          <input type="hidden" name="authorsPage" value="1" aria-hidden="true" />
          <label for="blog-autor-sort" class="whitespace-nowrap text-[16px] leading-6 tracking-[0.5px] text-[var(--color-text-default)]">
            Ordenar por:
          </label>
          <select
            id="blog-autor-sort"
            name="sort"
            class="cursor-pointer border-0 bg-transparent pr-6 text-[16px] leading-6 tracking-[0.5px] text-[var(--color-text-default)] focus:outline-none focus:ring-0"
            onchange="this.form.submit()"
          >
            <option value="published_desc" selected={sortParam === "published_desc"}>Más recientes</option>
            <option value="published_asc" selected={sortParam === "published_asc"}>Más antiguos</option>
            <option value="title_asc" selected={sortParam === "title_asc"}>Título (A–Z)</option>
          </select>
        </form>
      </div>

    {author.articles.length > 0 ? (
      <>
        <div
          id="autor-articulos-grid"
          class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3"
        >
          {displayArticles.map((articulo, idx) => (
            <div
              data-autor-articulo
              class:list={[idx >= AUTHOR_GRID_PAGE_SIZE ? "hidden" : ""]}
            >
              <ArticleCard article={articulo} tagByArticleKey={classificationTagByArticleKey} />
            </div>
          ))}
        </div>
        <div class="flex flex-col items-center gap-2 pt-2">
          <button
            type="button"
            id="btn-autor-load-more-articles"
            class:list={[
              "medrent-btn-primary inline-flex cursor-pointer items-center gap-2 border-0 text-base font-bold leading-6 tracking-[0.5px]",
              totalAuthorArticles <= AUTHOR_GRID_PAGE_SIZE ? "hidden" : "",
            ]}
          >
            Ver más artículos
            <span class="text-lg leading-none" aria-hidden="true">+</span>
          </button>
          <p
            id="autor-articles-count-bottom"
            class="text-center font-lato text-[16px] font-normal leading-6 tracking-[0.5px] text-[var(--color-text-default)]"
          >
            Mostrando {initialAuthorArticlesShown} de {totalAuthorArticles} artículos
          </p>
        </div>
      </>
    ) : (
      <div class="flex w-full flex-col items-center gap-6">
        <div class="flex w-full flex-col items-center justify-center rounded-[24px] bg-[var(--color-secondary-light)] px-4 py-12 backdrop-blur-[6px] md:px-12">
          <svg xmlns="http://www.w3.org/2000/svg" width="59" height="59" viewBox="0 0 59 59" fill="none" class="mb-4">
