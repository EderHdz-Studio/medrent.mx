  <script
    is:inline
    define:vars={{
      totalAuthorArticles,
      authorGridPageSize: AUTHOR_GRID_PAGE_SIZE,
    }}
  >
    (() => {
      const pageSize = authorGridPageSize;
      const items = Array.from(document.querySelectorAll("[data-autor-articulo]"));
      if (items.length === 0) return;

      const btn = document.getElementById("btn-autor-load-more-articles");
      const bottom = document.getElementById("autor-articles-count-bottom");
      const top = document.getElementById("autor-articles-count-top");
      let visible = Math.min(pageSize, items.length);

      function sync() {
        items.forEach((el, i) => {
          el.classList.toggle("hidden", i >= visible);
        });
        const shown = Math.min(visible, items.length);
        const short = `Mostrando ${shown} de ${totalAuthorArticles}`;
        if (top) top.textContent = short;
        if (bottom) bottom.textContent = `${short} artículos`;
        if (btn) {
          const done = visible >= items.length;
          btn.hidden = done;
          btn.classList.toggle("hidden", done);
        }
      }

      btn?.addEventListener("click", () => {
        visible = Math.min(visible + pageSize, items.length);
        sync();
      });

      sync();
    })();
  </script>
</Layout>


<script is:inline>
  // Glider de autores
  let currentAutorSlide = 0;
  const autorSlides = document.querySelectorAll('#gliderTrack .glider-slide');
  const autorPrevBtns = document.querySelectorAll('.prevBtnAutor');
  const autorNextBtns = document.querySelectorAll('.nextBtnAutor');
  const autorLabels = document.querySelectorAll('.autores-label');
  const autorTrack = document.getElementById('gliderTrack');

  function updateAutorLabel() {
    autorLabels.forEach(label => {
      if (label) {
        label.textContent = `${currentAutorSlide + 1}/${autorSlides.length}`;
      }
    });
  }

  function scrollToSlide(index) {
    if (autorTrack && autorSlides[index]) {
      const slide = autorSlides[index];
      const scrollPosition = slide.offsetLeft;
      autorTrack.scrollTo({
        left: scrollPosition,
        behavior: 'smooth'
      });
    }
  }

  function nextAutorSlide() {
    if (autorSlides.length > 0) {
      currentAutorSlide = (currentAutorSlide + 1) % autorSlides.length;
      scrollToSlide(currentAutorSlide);
      updateAutorLabel();
    }
  }

  function prevAutorSlide() {
    if (autorSlides.length > 0) {
      currentAutorSlide = (currentAutorSlide - 1 + autorSlides.length) % autorSlides.length;
      scrollToSlide(currentAutorSlide);
      updateAutorLabel();
    }
  }

  // Detectar scroll manual para actualizar el índice
  function handleScroll() {
    if (autorTrack && autorSlides.length > 0) {
      const scrollLeft = autorTrack.scrollLeft;
      let closestIndex = 0;
      let closestDistance = Infinity;
      
      autorSlides.forEach((slide, idx) => {
        const slideLeft = slide.offsetLeft;
        const distance = Math.abs(scrollLeft - slideLeft);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = idx;
        }
      });
      
      if (currentAutorSlide !== closestIndex) {
        currentAutorSlide = closestIndex;
        updateAutorLabel();
      }
    }
  }

  if (autorSlides.length > 0) {
    autorPrevBtns.forEach(btn => btn.addEventListener('click', prevAutorSlide));
    autorNextBtns.forEach(btn => btn.addEventListener('click', nextAutorSlide));
    
    if (autorTrack) {
      autorTrack.addEventListener('scroll', handleScroll);
    }
    
    updateAutorLabel();
  }
</script>