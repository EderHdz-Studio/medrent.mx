---
import Layout from '@layouts/Layout.astro';
import ArticleCard from '@components/blog/articleCard.astro';
import { formatDate } from '../../lib/utils.js';
import { strapiFetch } from "@server/strapiClient";

let articulosActivos = [];
let categorias = [];

try {
  // 1. Usar strapiFetch DIRECTAMENTE como función (no strapiFetch.find)
  const articulosAPI = await strapiFetch('/blog-articules-api?populate=*');

    console.log('📊 Total artículos después del slice(4):', articulosActivos.slice(4).length);
  // 2. LOG IMPORTANTE - Ver la estructura
  console.log('✅ API Response completa:', articulosAPI);
  
  // 3. Verificar que data existe y es un array
  if (articulosAPI.data && Array.isArray(articulosAPI.data)) {
    // 4. Filtrar activos
    articulosActivos = articulosAPI.data.filter(articulo => articulo.isActive === true);
    
    articulosActivos.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

    console.log(`✅ Total artículos activos: ${articulosActivos.length}`);
    
    // 5. LOG IMPORTANTE - Ver el primer artículo completo
    if (articulosActivos.length > 0) {
      console.log('✅ Primer artículo (estructura completa):', articulosActivos[0]);
    } else {
      console.log('⚠️ No hay artículos activos');
    }
  } else {
    console.error('❌ La API no devolvió un array en data:', articulosAPI);
  }
  
} catch (error) {
  console.error('❌ Error cargando artículos:', error);
  articulosActivos = [];
}

