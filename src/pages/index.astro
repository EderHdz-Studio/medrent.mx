---
export const prerender = false;
import { strapiFetch } from "@server/strapiClient";
import Layout from '../layouts/Layout.astro';
import BrandSlider from '@components/sections/BrandSlider.astro';
import PromotionSlider from '@components/sections/PromotionSlider.astro';
import SlideArticles from '@components/blog/slideArticles.astro';
import Eventos from '../components/eventosHome.astro';
import BaseForm from "@components/forms/BaseForm.astro";
import FormField from "@components/forms/FormField.astro";
import PhoneField from "@components/forms/PhoneField.astro";
import SelectField from "@components/forms/SelectField.astro";
import CheckboxField from "@components/forms/CheckboxField.astro";
import SubmitButton from "@components/forms/SubmitButton.astro";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import ImageResponsive from "@components/media/ImageResponsive.astro";
import { fetchBlogSliderData } from "@lib/blog/blogSliderData";
import { getSiteConfig } from "@server/siteConfig";
const siteConfig = await getSiteConfig();

let articulosRelacionados: any[] = [];
let promotionsData = [];
let classificationTagByArticleKey = new Map<string, string>();

let brandsData = [];
let marcasData = [];
try {
    const response = await strapiFetch("/categories?populate=*");
    marcasData = response?.data || [];
} catch (error) {
    console.error('Error fetching categories:', error);
    marcasData = [];
}

const marcas = marcasData.map((category) => {
    const attrs = category.attributes || category;
    return {
        slug: attrs.slug || category.slug,
        name: attrs.name || category.name,
        isActive: attrs.isActive ?? category.isActive ?? true,
        figure: attrs.figure?.url || category.figure?.url || '',
    };
});


try {
  const [brandsResp, promotionsResp] = await Promise.all([
    strapiFetch("/brands?populate=*"),
    strapiFetch("/promo-sliders?populate[desktopImage]=true&populate[mobileImage]=true&sort=displayOrder:asc"),
  ]);
  brandsData = Array.isArray(brandsResp?.data) ? brandsResp.data : [];
  promotionsData = Array.isArray(promotionsResp?.data) ? promotionsResp.data : [];
} catch (e) {
  console.error("Error cargando marcas o promociones:", e);
  brandsData = [];
  promotionsData = [];
}

try {
  const blogSlider = await fetchBlogSliderData();
  articulosRelacionados = blogSlider.articulos;
  classificationTagByArticleKey = blogSlider.tagByArticleKey;
} catch (e) {
  console.error("Error blog slider (home):", e);
  articulosRelacionados = [];
  classificationTagByArticleKey = new Map();
}


let dataEventos = null;
try {
    const response = await strapiFetch("/events-page?populate[events][populate]=image&populate=heroImage");
    dataEventos = response.data;
} catch (error) {
    console.error('Error fetching events:', error);
    dataEventos = {
        events: [],
        title: 'Eventos médicos',
        description: 'Mantente actualizado con los últimos avances...'
    };
}

const dataHome = {}

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.originPathname ?? Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = siteConfig?.favicon512x512?.url;
---

<Layout
  title="MedRent México | Tecnología médica y financiamiento sin enganche"
  description="Equipos médicos para neurodiagnóstico, neuromodulación, rehabilitación y ultrasonido con soporte y asesoría. Agenda tu demo."
  keywords="equipo médico México; financiamiento equipo médico; neurodiagnóstico; neuromodulación; rehabilitación; ultrasonido"
  ogImage={logoUrl}
>

    <Fragment slot="head">
        <BreadcrumbSchema
            id={breadcrumbId}
            items={[
                { name: "Inicio", url: `${baseUrl}/` },
            ]}
        />
        <script type="application/ld+json" set:html={
            JSON.stringify({
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "WebPage",
                        "@id": `${canonicalUrl}#webpage`,
                        url: canonicalUrl,
                        name:
                            "MedRent México | Tecnología médica y financiamiento sin enganche",
                        description:
                            "Equipos médicos para neurodiagnóstico, neuromodulación, rehabilitación y ultrasonido con soporte y asesoría. Agenda tu demo.",
                        isPartOf: { "@id": `${baseUrl}/#website` },
                        about: { "@id": `${baseUrl}/#organization` },
                        inLanguage: "es-MX",
                        breadcrumb: { "@id": breadcrumbId },
                        primaryImageOfPage: {
                            "@type": "ImageObject",
                            url: logoUrl,
                        },
                    },
                ],
            })
        }></script>
    </Fragment>

    <!-- Sección de contacto -->
    <section class="max-w-7xl mx-auto flex flex-col md:grid md:grid-cols-2">
        <!-- Columna 1: Encabezado -->
       <div class="medrentForm space-y-4 bg-[var(--color-primary)] rounded-3xl p-8 md:p-0">
            <h2 class="mb-6 text-white font-bold text-[28px] leading-9 md:text-[45px] md:leading-[52px]">
                {dataHome.TituloContacto || '¡Financia tu equipo médico hoy sin enganche!'}
            </h2>
            
            <p class="text-[#D8E5E3] font-normal text-base leading-6 tracking-[0.5px] mb-6">
                {dataHome.DescripcionContacto ? (
                <BlocksRenderer content={dataHome.DescripcionContacto} />
                ) : (
                <span class="font-light">Adquiere la tecnología del futuro sin barreras.</span>
                )}
            </p>

            <div class="flex flex-col gap-6">
                <!-- Primera fila: icono + teléfono -->
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-3 rounded-full bg-white p-3">
