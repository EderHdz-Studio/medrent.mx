2B993E"/>
                        </svg>
                    </div>
                    <a 
                        id="btnWhatsapp" 
                        href={`https://wa.me/${siteConfig?.whatsappNumber}`} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-[var(--color-secondary)] underline"
                    >
                        {(() => {
                            const num = siteConfig?.whatsappNumber;
                            return `+52 ${num.slice(2, 4)} ${num.slice(4, 6)} ${num.slice(6, 8)} ${num.slice(8)}`;
                        })()}
                    </a>
                </div>

                <!-- Segunda fila: icono + email -->
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-3 rounded-full bg-white p-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M4 20C3.45 20 2.97917 19.8042 2.5875 19.4125C2.19583 19.0208 2 18.55 2 18V6C2 5.45 2.19583 4.97917 2.5875 4.5875C2.97917 4.19583 3.45 4 4 4H20C20.55 4 21.0208 4.19583 21.4125 4.5875C21.8042 4.97917 22 5.45 22 6V18C22 18.55 21.8042 19.0208 21.4125 19.4125C21.0208 19.8042 20.55 20 20 20H4ZM12 13L4 8V18H20V8L12 13ZM12 11L20 6H4L12 11ZM4 8V6V18V8Z" fill="#006764"/>
                        </svg>
                    </div>
                    <a 
                        href={`https://mail.google.com/mail/?extsrc=mailto&url=mailto%3A${siteConfig?.email || ''}`} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-[var(--color-secondary)] underline"
                    >
                        {siteConfig?.email}
                    </a>
                </div>
            </div>
        </div>

        <div class="medrentForm1 form-container px-0 py-8 md:pb-16 md:pt-[100px] md:px-0 lg:pt-[100px] lg:pb-6 bg-[var(--color-secondary-light)]">
            <BaseForm
                id="form-home"
                class="space-y-6 flex flex-col gap-6"
                >
                <FormField
                    label="Nombre completo"
                    name="name"
                    placeholder="Ej: Dra. Carolina Ávila"
                />

                <FormField
                    label="Correo electrónico"
                    name="email"
                    type="email"
                    placeholder="Ej: carolina.avila@hospitalneuro.mx"
                />
                
                <PhoneField />

                <SelectField
                    label="Especialidad médica"
                    name="specialty"
                    options={["Neurocirugía y ORL", "Neurofisiología", "Medicina del sueño", "Neuromodulación", "Rehabilitación", "Neurovascular", "Otra"]}
                />

                <CheckboxField
                    id="aviso"
                    label="He leído y acepto el"
                    link="/aviso-de-privacidad"
                />

                <SubmitButton text="Agenda tu DEMO" />
            </BaseForm>
        </div>

        <script type="module">
            document.addEventListener("DOMContentLoaded", () => {
                const formId = "form-home";
                const form = document.getElementById(formId);
                if (!form) return;

                let mounted = false;
                const mountValidation = async () => {
                    if (mounted) return;
                    mounted = true;
                    const { initForm } = await import("/scripts/formValidator.js");
                    initForm(formId);
                };

                const onFirstInteraction = () => {
                    form.removeEventListener("focusin", onFirstInteraction);
                    form.removeEventListener("input", onFirstInteraction);
                    mountValidation().catch(() => {});
                };

                form.addEventListener("focusin", onFirstInteraction, { once: true });
                form.addEventListener("input", onFirstInteraction, { once: true });
            });
        </script>
    </section>

    <!--  Sección mosaico de categorías-->
    <section class="max-w-7xl mx-auto py-6 px-4 md:px-6 lg:px-8">
        <div class="text-center p-6 w-full"> 
