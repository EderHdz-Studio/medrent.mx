                            hover:bg-[#F5FAF9] 
                            hover:shadow-[0_9px_24px_8px_rgba(0,103,100,0.40)]"
                        key={marca.slug}
                    >
                        <div class="flex items-center justify-center p-4">
                            <ImageResponsive
                                src={marca.figure}
                                alt={marca.name}
                                width={84}
                                height={84}
