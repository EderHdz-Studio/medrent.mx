---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumb from "@components/navigation/Breadcrumb.astro";
import PLPLayout from "@components/product/PLPLayout.astro";
import PLPProductsSection from "@components/product/PLPProductsSection.astro";
import SidebarFilters from "@components/product/SidebarFilters.astro";
import { getSiteConfig } from "@server/siteConfig";
const siteConfig = await getSiteConfig();

import { getProducts } from "@server/api/products";
import { getBrandLandingBySlug, getBrands } from "@server/api/brands";
import { getCategories } from "@server/api/categories";
import { getAllSubcategories } from "@server/api/subcategories";
import { formatSlugAsTitle } from "@lib/utils.js";
import { isUsableBrandSlug } from "@lib/brandSlug";
import { localizeRedirect } from "@lib/locale";
import { strapiFetch } from "@server/strapiClient";

const { brand, interestitial } = Astro.params;

let heroPLP: any = {};
try {
    const response = await strapiFetch("/plp?populate=*");
    const sliderHero = response?.data || {};
    heroPLP = Array.isArray(sliderHero) ? sliderHero[0] || {} : sliderHero;
} catch (error) {
    console.error('Error fetching slider hero:', error);
    heroPLP = {};
}

if (!isUsableBrandSlug(brand) || !interestitial) {
  return Astro.redirect(localizeRedirect("/nuestras-marcas", Astro.originPathname ?? Astro.url.pathname), 301);
}

const brandData = await getBrandLandingBySlug(brand);
const interestitialCard = brandData?.interestitialCard?.find((card) => card.slug === interestitial);

if (!brandData || !interestitialCard) {
  return Astro.redirect(localizeRedirect(`/nuestras-marcas/${brand}`, Astro.originPathname ?? Astro.url.pathname), 302);
}

const url = new URL(Astro.request.url);

const parseFilterParam = (key: string) => {
  const values = url.searchParams
    .getAll(key)
    .flatMap((value) => value.split(","))
    .map((value) => value.trim())
    .filter(Boolean);
  return [...new Set(values)];
};

const brandQuery = parseFilterParam("brand");
const categoryQuery = parseFilterParam("category");
const subcategoryQuery = parseFilterParam("subcategory");

if (!brandQuery.includes(brand)) {
  brandQuery.push(brand);
}

const cardProductSlugs = Array.isArray(interestitialCard.products)
  ? interestitialCard.products.map((product) => product.slug).filter(Boolean)
  : [];

const products = interestitialCard.allProducts || cardProductSlugs.length > 0
  ? await getProducts({
      slugs: interestitialCard.allProducts ? undefined : cardProductSlugs,
      brands: brandQuery,
      categories: categoryQuery,
      subcategories: subcategoryQuery,
    })
  : [];


 

  
const brandsData = await getBrands();
const categoriesData = await getCategories();
const subcategoriesData = await getAllSubcategories();
const brandName = brandData.name || formatSlugAsTitle(brand);
const plpHeadingTitle = interestitialCard.name || formatSlugAsTitle(interestitial);
const fallbackPageTitle = `${plpHeadingTitle} | ${brandName} | MedRent`;
const fallbackPageDescription =
  interestitialCard.description ||
  `Descubre productos y soluciones de ${brandName} para ${plpHeadingTitle} con soporte especializado de MedRent.`;
const pageTitle = plpHeadingTitle || fallbackPageTitle;
const pageDescription = interestitialCard.description || fallbackPageDescription;
const pageKeywords = `${brandName}; ${plpHeadingTitle}; equipo médico; MedRent`;

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const currentPathname = Astro.originPathname ?? Astro.url.pathname;
const canonicalUrl = new URL(currentPathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = brandData.logoUrl || siteConfig?.favicon512x512?.url;
const mediaUrl = (value: any) => {
  if (typeof value === "string") return value;
  if (typeof value?.url === "string") return value.url;
  if (typeof value?.data?.attributes?.url === "string") return value.data.attributes.url;
  if (typeof value?.data?.url === "string") return value.data.url;
  return "";
};
const fallbackHeroImageUrl = "/temp/HeroPLP.png";
const heroImageDesktop = mediaUrl(heroPLP.heroImageDesktop) || fallbackHeroImageUrl;
const heroImageMobile = mediaUrl(heroPLP.heroImageMobile) || heroImageDesktop;
const heroImageUrl = new URL(heroImageDesktop, baseUrl).toString();
const openGraphImageUrl = new URL("/OG_Default_Medrent.jpeg", baseUrl).toString();

const brandUrl = `${baseUrl}/nuestras-marcas/${brand}`;
const brandId = `${brandUrl}#brand`;
const seoPlpDescription = fallbackPageDescription;
const seoPlpTitle = brandName;
const seoText = "";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  ogImage={openGraphImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      items={[
        { name: "Inicio", url: `${baseUrl}/` },
        { name: "Marcas", url: `${baseUrl}/nuestras-marcas` },
        { name: brandName, url: brandUrl },
        { name: plpHeadingTitle, url: canonicalUrl },
      ]}
      id={breadcrumbId}
    />
    <script type="application/ld+json" set:html={
      (() => {
        const list = Array.isArray(products) ? products.slice(0, 12) : [];
        const itemListId = `${canonicalUrl}#itemlist`;
        const itemListElement = list.map((p, index) => {
          const pdpUrl = p?.slug ? `${baseUrl}/productos/${p.slug}` : canonicalUrl;
          const imageUrl = Array.isArray(p?.gallery) ? p.gallery[0] : undefined;
          return {
            "@type": "ListItem",
            position: index + 1,
            item: {
              "@type": ["MedicalDevice", "Product"],
              "@id": `${pdpUrl}#product`,
              name: p?.name || "Producto",
              url: pdpUrl,
              image: imageUrl ? [imageUrl] : undefined,
            },
            url: pdpUrl,
          };
        });

        return JSON.stringify({
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "WebPage",
              "@id": `${canonicalUrl}#webpage`,
              url: canonicalUrl,
              name: pageTitle,
              description: pageDescription,
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": brandId },
              inLanguage: "es-MX",
              breadcrumb: { "@id": breadcrumbId },
              mainEntity: { "@id": itemListId },
              primaryImageOfPage: { "@type": "ImageObject", url: heroImageUrl },
            },
            {
              "@type": "Brand",
              "@id": brandId,
              name: brandName,
              url: brandUrl,
              image: logoUrl ? [logoUrl] : undefined,
            },
            {
              "@type": "CollectionPage",
              "@id": itemListId,
              url: canonicalUrl,
              name: pageTitle,
              description: pageDescription,
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": brandId },
              inLanguage: "es-MX",
              mainEntity: { "@id": itemListId },
            },
            {
              "@type": "ItemList",
              "@id": itemListId,
              name: `${plpHeadingTitle} - productos`,
              itemListOrder: "https://schema.org/ItemListOrderAscending",
              itemListElement,
            },
          ],
        });
      })()
    }></script>
  </Fragment>

  <section class="relative w-full h-[140px] overflow-hidden">
    <div class="absolute inset-0 heroproductos">
      <Breadcrumb
        textColor="text-white"
        items={[
          { name: "INICIO", href: "/" },
          { name: "MARCAS", href: "/nuestras-marcas" },
          { name: brandName, href: `/nuestras-marcas/${brand}` },
          { name: plpHeadingTitle },
        ]}
      />

      <picture>
        <source media="(max-width: 767px)" srcset={heroImageMobile} />
        <img
          src={heroImageDesktop}
          alt={`${brandName} - ${plpHeadingTitle}`}
          class="w-full h-full object-cover rounded-b-[24px]"
        />
      </picture>

    </div>
  </section>

  <PLPLayout
    title={plpHeadingTitle}
    productCount={products.length}
    seoTitle={seoPlpTitle}
    seoDescription={seoPlpDescription}
    seoText={seoText}
  >
    <Fragment slot="filters">
      <SidebarFilters
        brands={brandsData}
        categories={categoriesData}
        subcategories={subcategoriesData}
      />
    </Fragment>

    <PLPProductsSection products={products} />
  </PLPLayout>

  <script is:inline define:vars={{ products, listName: plpHeadingTitle }}>
    setTimeout(() => {
      window.view_item_list(products, listName)
    }, 2000);
  </script>
</Layout>
