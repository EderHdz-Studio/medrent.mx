                e.preventDefault();
                openEventPopup({
                    img: this.getAttribute('data-img') || '',
                    title: this.getAttribute('data-title') || 'Evento MedRent',
                    description: this.getAttribute('data-description') || 'Descripción del evento'
                });
            });
        });
        
        if (closePopupBtn) closePopupBtn.addEventListener('click', closeEventPopup);
        if (popupOverlay) {
            popupOverlay.addEventListener('click', (e) => {
                if (e.target === popupOverlay) closeEventPopup();
            });
        }
        
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && popupOverlay && !popupOverlay.classList.contains('hidden')) {
                closeEventPopup();
            }
        });
        
        // INICIALIZACIÓN DEL CALENDARIO Y FILTROS
        
        // Inicializar el calendario con la fecha actual del cliente
        const fechaActualCliente = dayjs();
        const mesActualKey = fechaActualCliente.format('YYYY-MM');
        
        // Primero, configurar el estado inicial de los meses
        // Solo los meses con eventos deben estar abiertos
        document.querySelectorAll('.eventos-month-section[data-month]').forEach((monthSection) => {
            const month = monthSection.getAttribute('data-month');
            const monthContent = month
                ? monthSection.querySelector(`[data-month-content="${month}"]`)
                : null;
            const parentDiv = monthSection as HTMLElement;
            const hasEventDays = monthSection.hasAttribute('data-event-days');
            
            if (monthContent && hasEventDays) {
                // Mes con eventos: abierto por defecto
                parentDiv.classList.add('open');
                monthContent.classList.remove('month-hidden', 'hidden');
            } else if (monthContent) {
                // Mes sin eventos: cerrado por defecto (solo .month-hidden; no usar Tailwind hidden)
                parentDiv.classList.remove('open');
                monthContent.classList.add('month-hidden');
            }
        });
        
        // Calendario: mes del cliente; luego se alinea al mes de la lista más próximo al ancla (scroll)
        currentCalendarMonth = dayjs(`${mesActualKey}-01`);
        lastScrollSyncedMonthKey = mesActualKey;
        actualizarCalendario(mesActualKey);
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                trySyncEventosCalendarioConMesEnLista();
            });
        });

        // Configurar toggles de meses
        document.querySelectorAll('[data-month-toggle]').forEach(toggle => {
            const monthKey = toggle.getAttribute('data-month-toggle');
            const parentDiv = toggle.closest('.eventos-month-section');
            const content = parentDiv?.querySelector(`[data-month-content="${monthKey}"]`) ?? null;
            if (content && parentDiv && monthKey) {
                toggle.addEventListener('click', (e) => {
                    e.preventDefault();
                    parentDiv.classList.toggle('open');
                    if (content.classList.contains('month-hidden')) {
                        content.classList.remove('month-hidden', 'hidden');
                        currentCalendarMonth = dayjs(`${monthKey}-01`);
                        lastScrollSyncedMonthKey = monthKey;
                        suppressScrollCalendarSyncUntil = performance.now() + 400;
                        actualizarCalendario(monthKey);
                    } else {
                        content.classList.add('month-hidden');
                    }
                });
            }
        });
        
        // FILTROS (patrón PLP: data-filter, URL con pushState, título Filtros (n))
        function renderFilterOptions() {
            const filtersContainer = document.getElementById('event-filters');
            if (!filtersContainer) return;
            const events = Array.from(document.querySelectorAll('article[data-event-type]')) as HTMLElement[];

            const tiposUnicos = Array.from(new Set(events.map(e => (e.dataset.eventType || 'otro').toLowerCase()))).sort();
            const especialidadesUnicas = Array.from(new Set(events.map(e => (e.dataset.eventSpecialty || 'general').toLowerCase()))).sort();

            const tipoContainer = document.getElementById('filter-event-type');
            const especialidadContainer = document.getElementById('filter-specialty');

            if (tipoContainer) {
                tipoContainer.innerHTML = tiposUnicos.map((tipo) => `
                    <label class="flex items-center mt-2 cursor-pointer">
                        <input type="checkbox" data-filter="eventType" value="${tipo}" class="mr-2 accent-[var(--color-primary)]" />
                        <span class="text-sm capitalize">${tipo}</span>
                    </label>
                `).join('');
            }
            if (especialidadContainer) {
                especialidadContainer.innerHTML = especialidadesUnicas.map((espec) => `
                    <label class="flex items-center mt-2 cursor-pointer">
                        <input type="checkbox" data-filter="specialty" value="${espec}" class="mr-2 accent-[var(--color-primary)]" />
                        <span class="text-sm capitalize">${espec}</span>
                    </label>
                `).join('');
            }

            setEventFiltersFromUrl();
            applyFilters();
        }

        function applyFilters() {
            const selectedTipos = Array.from(
                document.querySelectorAll('input[data-filter="eventType"]:checked')
            ).map((el: Element) => (el as HTMLInputElement).value.toLowerCase());
            const selectedEspecialidades = Array.from(
                document.querySelectorAll('input[data-filter="specialty"]:checked')
            ).map((el: Element) => (el as HTMLInputElement).value.toLowerCase());

            const events = Array.from(document.querySelectorAll('article[data-event-type]')) as HTMLElement[];
            let activeCard: HTMLElement | null = null;

            events.forEach((card) => {
                const type = (card.dataset.eventType || '').toLowerCase();
                const specialty = (card.dataset.eventSpecialty || '').toLowerCase();
                const matchType = selectedTipos.length === 0 || selectedTipos.includes(type);
                const matchSpecialty = selectedEspecialidades.length === 0 || selectedEspecialidades.includes(specialty);
                const visible = matchType && matchSpecialty;

                card.style.display = visible ? '' : 'none';
                if (visible && !activeCard) activeCard = card;
                card.classList.toggle('filtered-selected', false);
            });

            // Mostrar/ocultar meses según filtrado
            const monthSections = Array.from(
                document.querySelectorAll('.eventos-month-section[data-month]')
            ) as HTMLElement[];
            let firstVisibleMonth: string | null = null;
            
            monthSections.forEach(monthSection => {
                const month = monthSection.dataset.month;
                if (!month) return;
                const cards = Array.from(monthSection.querySelectorAll('article[data-start-date]')) as HTMLElement[];
                const hasVisible = cards.some((c) => (c.style.display !== 'none'));
                const monthContent = monthSection.querySelector(`[data-month-content="${month}"]`) as HTMLElement | null;
                const hasEventDays = monthSection.hasAttribute('data-event-days');
                
                // El mes siempre se muestra, pero el contenido se oculta/muestra según filtros
                monthSection.style.display = '';
                
                if (monthContent) {
                    if (hasVisible) {
                        // Hay eventos visibles: mostrar contenido
                        if (!monthSection.classList.contains('open')) {
                            monthSection.classList.add('open');
                        }
                        monthContent.classList.remove('month-hidden', 'hidden');
                        if (!firstVisibleMonth) firstVisibleMonth = month;
                    } else {
                        // No hay eventos visibles: ocultar contenido pero mantener el header
                        monthContent.classList.add('month-hidden');
                        monthSection.classList.remove('open');
                    }
                }
            });

            if (!isFirstLoad && activeCard) {
                const selectedCard = activeCard as HTMLElement;
                selectedCard.classList.add('filtered-selected');
                const date = selectedCard.dataset.startDate;
                if (date) {
                    scrollToEventByDate(date);
                } else {
                    selectedCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            // Actualizar el calendario con el primer mes visible o el mes actual
            if (!isFirstLoad) {
                if (firstVisibleMonth) {
                    lastScrollSyncedMonthKey = firstVisibleMonth;
                    currentCalendarMonth = dayjs(`${firstVisibleMonth}-01`);
                    actualizarCalendario(firstVisibleMonth);
                } else {
                    const fechaActual = dayjs().format('YYYY-MM');
                    lastScrollSyncedMonthKey = fechaActual;
                    currentCalendarMonth = dayjs(`${fechaActual}-01`);
                    actualizarCalendario(fechaActual);
                }
            }

            updateEventsFiltersTitle();
            isFirstLoad = false;
        }

        document.addEventListener('change', (e) => {
            const t = e.target;
            if (!(t instanceof HTMLInputElement)) return;
            if (!t.matches('#event-filters input[data-filter]')) return;
            if (suppressFilterChange) return;
            updateEventsFiltersTitle();
            updateEventsFilterUrl();
            applyFilters();
        });

        document.getElementById('clear-filters')?.addEventListener('click', (e) => {
            e.preventDefault();
            runWithSuppressFilterChange(() => {
                document.querySelectorAll('#event-filters input[data-filter]').forEach((input) => {
                    if (input instanceof HTMLInputElement) input.checked = false;
                });
            });
            updateEventsFiltersTitle();
            updateEventsFilterUrl();
            applyFilters();
        });

        window.addEventListener('popstate', () => {
            setEventFiltersFromUrl();
            applyFilters();
        });

        renderFilterOptions();

        // Dropdown toggles de filtros
        const toggleEventType = document.getElementById('toggle-event-type');
        const dropdownEventType = document.getElementById('dropdown-event-type');
        const toggleSpecialty = document.getElementById('toggle-specialty');
        const dropdownSpecialty = document.getElementById('dropdown-specialty');

        const closeAllDropdowns = () => {
            if (dropdownEventType) dropdownEventType.classList.add('hidden');
            if (dropdownSpecialty) dropdownSpecialty.classList.add('hidden');
            if (toggleEventType) toggleEventType.classList.remove('open');
            if (toggleSpecialty) toggleSpecialty.classList.remove('open');
        };

        toggleEventType?.addEventListener('click', (e) => {
            e.stopPropagation();
            if (dropdownEventType && toggleEventType) {
                const isHidden = dropdownEventType.classList.contains('hidden');
                if (isHidden) {
                    dropdownEventType.classList.remove('hidden');
                    toggleEventType.classList.add('open');
                } else {
                    dropdownEventType.classList.add('hidden');
                    toggleEventType.classList.remove('open');
                }
            }
        });

        toggleSpecialty?.addEventListener('click', (e) => {
            e.stopPropagation();
            if (dropdownSpecialty && toggleSpecialty) {
                const isHidden = dropdownSpecialty.classList.contains('hidden');
                if (isHidden) {
                    dropdownSpecialty.classList.remove('hidden');
                    toggleSpecialty.classList.add('open');
                } else {
                    dropdownSpecialty.classList.add('hidden');
                    toggleSpecialty.classList.remove('open');
                }
            }
        });

        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            const isFilterArea = target.closest('#event-filters') || 
                                target.closest('#toggle-event-type') || 
                                target.closest('#toggle-specialty') ||
                                target.closest('.filter-dropdown');
            
            if (!isFilterArea) {
                closeAllDropdowns();
            }
        });

        // Botones de navegación del calendario
        const prevMonthBtn = document.getElementById('prev-month-btn');
        const nextMonthBtn = document.getElementById('next-month-btn');

        function cambiarMes(direccion: string) {
            suppressScrollCalendarSyncUntil = performance.now() + 700;
            if (direccion === 'prev') {
                currentCalendarMonth = currentCalendarMonth.subtract(1, 'month');
            } else {
                currentCalendarMonth = currentCalendarMonth.add(1, 'month');
            }
            const mesKey = currentCalendarMonth.format('YYYY-MM');
            lastScrollSyncedMonthKey = mesKey;
            actualizarCalendario(mesKey);
            
            const mesActualElement = document.getElementById('mes-actual');
            if (mesActualElement) {
                const nombreMes = currentCalendarMonth.format('MMMM YYYY');
                mesActualElement.textContent = nombreMes.charAt(0).toUpperCase() + nombreMes.slice(1).toLowerCase();
            }
            
            const seccionMes = document.querySelector(`[data-month="${mesKey}"]`);
            if (seccionMes) {
                const headerHeight = getLayoutHeaderOffsetPx();
                const rect = seccionMes.getBoundingClientRect();
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                const offsetPosition = rect.top + scrollTop - headerHeight - 30;
                window.scrollTo({ top: Math.max(0, offsetPosition), behavior: 'smooth' });
            }
        }
        
        if (prevMonthBtn) prevMonthBtn.addEventListener('click', () => cambiarMes('prev'));
        if (nextMonthBtn) nextMonthBtn.addEventListener('click', () => cambiarMes('next'));

        let scrollListaRaf = 0;
        window.addEventListener(
            'scroll',
            () => {
                if (scrollListaRaf) return;
                scrollListaRaf = requestAnimationFrame(() => {
                    scrollListaRaf = 0;
                    trySyncEventosCalendarioConMesEnLista();
                });
            },
            { passive: true }
        );
    });

    // función scroll de la card con calendario
    function scrollToEventByDate(date: string) {
        const monthKey = date.substring(0, 7);
        const monthToggle = document.querySelector(`[data-month-toggle="${monthKey}"]`) as HTMLElement;
        const monthContent = document.querySelector(`[data-month-content="${monthKey}"]`) as HTMLElement;
        const parentDiv = monthToggle?.closest('.eventos-month-section') as HTMLElement;

        if (monthToggle && monthContent && parentDiv && monthContent.classList.contains('month-hidden')) {
            parentDiv.classList.add('open');
            monthContent.classList.remove('month-hidden', 'hidden');
            lastScrollSyncedMonthKey = monthKey;
            currentCalendarMonth = dayjs(`${monthKey}-01`);
            suppressScrollCalendarSyncUntil = performance.now() + 500;
            actualizarCalendario(monthKey);
            setTimeout(() => {
                scrollToSpecificEvent(date);
            }, 350);
        } else {
            scrollToSpecificEvent(date);
        }
    }

    function scrollToSpecificEvent(date: string) {
        const eventos = document.querySelectorAll('article[data-start-date]');
        let eventoEncontrado: HTMLElement | null = null;
        for (let evento of eventos) {
            const startDate = evento.getAttribute('data-start-date');
            const endDate = evento.getAttribute('data-end-date');
            if (startDate && endDate && date >= startDate && date <= endDate) {
                eventoEncontrado = evento as HTMLElement;
                break;
            }
        }
        if (eventoEncontrado) {
            const el = eventoEncontrado;
            const headerHeight = getLayoutHeaderOffsetPx();
            const rect = el.getBoundingClientRect();
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const offsetPosition = rect.top + scrollTop - headerHeight - 30;
            window.scrollTo({ top: Math.max(0, offsetPosition), behavior: 'smooth' });
            el.style.transition = 'border 0.3s ease';
            el.style.border = '3px solid var(--color-primary)';
            el.style.outlineOffset = '2px';
            setTimeout(() => {
                el.style.border = '';
            }, 2000);
        }
    }

    window.scrollToEventByDate = scrollToEventByDate;
</script>


<style>
  .events-container {
    overflow: hidden;
    transition: all 0.3s ease;
    opacity: 1;
  }
  
  .events-container.month-hidden {
    max-height: 0 !important;
    opacity: 0;
    padding: 0;
    margin: 0 !important;
    visibility: hidden;
  }

  /* Mismo hover que FAQ PDP (productos/[slug].astro .faq-hover-fill-effect) */
  .eventos-month-hover-fill {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #edf2f0;
    transform: scaleY(0);
    transform-origin: bottom center;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 1;
    border-radius: 2px;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .eventos-month-toggle-label.group:hover .eventos-month-hover-fill {
      transform: scaleY(1);
    }
  }
  
  [data-month-toggle] svg {
    transition: transform 0.3s ease;
  }
  
  .open [data-month-toggle] svg,
  [data-month-toggle] svg.rotated {
    transform: rotate(180deg);
  }

  #toggle-event-type.open .icon-chevron,
  #toggle-specialty.open .icon-chevron {
    transform: rotate(180deg);
  }

  article[data-event-type].filtered-selected {
    border-color: #006764 !important;
    box-shadow: 0 0 0 3px rgba(0, 103, 100, 0.15);
  }

  /* Columna izquierda: sticky + altura ≈ viewport; reservar hueco para CTA fijo #BtnWhatsappDemo (Layout) */
  .eventos-plp-filters-scroll {
    scroll-padding-bottom: 32px;
  }

  @media (min-width: 1024px) {
    .eventos-plp-filters-scroll {
      --plp-sticky-top: 109px;
      /*
        CTA inferior fijo (#BtnWhatsappDemo, ~78–96px + sombra) con z-50 tapa el sidebar (z-25).
        Sin esta reserva, el max-height del panel llega al borde del viewport y los filtros quedan ocultos detrás del CTA.
      */
      --plp-sticky-bottom-safe: calc(100px + env(safe-area-inset-bottom, 0px));
      /* -webkit-sticky: mismo nodo no debe mezclar overflow con el aside (ver markup) */
      position: -webkit-sticky;
      position: sticky;
      top: var(--plp-sticky-top);
      z-index: 25;
      align-self: start;
      width: 100%;
      min-height: 0;
      max-height: calc(100svh - var(--plp-sticky-top) - var(--plp-sticky-bottom-safe));
      max-height: calc(100dvh - var(--plp-sticky-top) - var(--plp-sticky-bottom-safe));
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
      padding-right: 4px;
      padding-bottom: 32px;
    }
  }

  /* WebKit: thumb/track transparentes hasta hover (máx. altura sin barra visual fija) */
  @media (min-width: 1024px) {
    .eventos-plp-filters-scroll::-webkit-scrollbar {
      width: 8px;
    }
    .eventos-plp-filters-scroll::-webkit-scrollbar-thumb {
      background: transparent;
      border-radius: 999px;
    }
    .eventos-plp-filters-scroll::-webkit-scrollbar-track {
      background: transparent;
      border-radius: 999px;
    }
  }

  @media (min-width: 1024px) and (hover: hover) and (pointer: fine) {
    .eventos-plp-filters-scroll:hover::-webkit-scrollbar-thumb {
      background: var(--color-primary);
    }
    .eventos-plp-filters-scroll:hover::-webkit-scrollbar-track {
      background: rgba(0, 103, 100, 0.14);
    }
  }

  /* Touch / coarse pointer: barra siempre visible para UX de arrastre */
  @media (min-width: 1024px) and (not (hover: hover)), (min-width: 1024px) and (pointer: coarse) {
    .eventos-plp-filters-scroll::-webkit-scrollbar-thumb {
      background: var(--color-primary);
    }
    .eventos-plp-filters-scroll::-webkit-scrollbar-track {
      background: rgba(0, 103, 100, 0.14);
    }
  }

  /* Firefox */
  @media (min-width: 1024px) {
    .eventos-plp-filters-scroll {
      scrollbar-width: thin;
      scrollbar-color: transparent transparent;
    }
  }
  @media (min-width: 1024px) and (hover: hover) and (pointer: fine) {
    .eventos-plp-filters-scroll:hover {
      scrollbar-color: var(--color-primary) rgba(0, 103, 100, 0.14);
    }
  }
  @media (min-width: 1024px) and (not (hover: hover)), (min-width: 1024px) and (pointer: coarse) {
    .eventos-plp-filters-scroll {
      scrollbar-color: var(--color-primary) rgba(0, 103, 100, 0.14);
    }
  }
</style>