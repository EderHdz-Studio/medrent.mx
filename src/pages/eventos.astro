.5765 50.3802 53.7593 50.6798 53.8842C50.9794 54.009 51.3007 54.0732 51.6252 54.0732C51.9497 54.0732 52.271 54.009 52.5706 53.8842C52.8702 53.7593 53.1421 53.5765 53.3706 53.346C53.8285 52.8854 54.0855 52.2624 54.0855 51.6129C54.0855 50.9635 53.8285 50.3404 53.3706 49.8798ZM12.2917 19.6667C12.2969 19.1657 12.4551 18.6783 12.7451 18.2697C13.0351 17.861 13.443 17.5508 13.9142 17.3805L23.5755 27.0418H12.2917V19.6667ZM14.75 46.7085C14.0981 46.7085 13.4728 46.4495 13.0117 45.9885C12.5507 45.5275 12.2917 44.9022 12.2917 44.2502V31.9585H28.4922L43.2422 46.7085H14.75Z" fill="#006764"/></svg>
                        <p class="text-[#006764] font-bold text-base md:text-lg lg:text-xl text-center">Este mes no cuenta con eventos programados</p>
                        <p class="text-gray-600 text-xs md:text-sm text-center">Consulta otros meses para conocer nuestras próximas actividades académicas y clínicas.</p>
                    </div>`;
                }
            }
        }
        
        document.querySelectorAll('.event-popup-btn').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                openEventPopup({
                    img: this.getAttribute('data-img') || '',
                    title: this.getAttribute('data-title') || 'Evento MedRent',
                    description: this.getAttribute('data-description') || 'Descripción del evento'
                });
            });
        });
        
        if (closePopupBtn) closePopupBtn.addEventListener('click', closeEventPopup);
        if (popupOverlay) {
            popupOverlay.addEventListener('click', (e) => {
                if (e.target === popupOverlay) closeEventPopup();
            });
        }
        
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && popupOverlay && !popupOverlay.classList.contains('hidden')) {
                closeEventPopup();
            }
        });
        
        // CALENDARIO
        function generarCalendario(fechaBase) {
            const fecha = dayjs(fechaBase);
            const startOfMonth = fecha.startOf('month');
            const startOfWeek = startOfMonth.startOf('week');
            const calendarDays = [];
            let currentDay = startOfWeek;
            for (let i = 0; i < 42; i++) {
                calendarDays.push({
                    day: currentDay.date(),
                    isCurrentMonth: currentDay.month() === fecha.month(),
                    isToday: currentDay.isSame(dayjs(), 'day'),
                    fullDate: currentDay.format('YYYY-MM-DD')
                });
                currentDay = currentDay.add(1, 'day');
            }
            return {
                dias: calendarDays,
                nombreMes: (() => {
                    const raw = fecha.format('MMMM YYYY');
                    return raw.charAt(0).toUpperCase() + raw.slice(1).toLowerCase();
                })()
            };
        }
        
        function actualizarCalendario(mesKey) {
            const calendario = generarCalendario(mesKey + '-01');
            const mesActualElement = document.getElementById('mes-actual');
            const calendarioDiasContainer = document.querySelector('#calendario-dinamico .grid.grid-cols-7.gap-1');
            const seccionMes = document.querySelector(`[data-month="${mesKey}"]`);
            let diasConEventos = [];
            if (seccionMes) {
                const eventDaysAttr = seccionMes.getAttribute('data-event-days');
                if (eventDaysAttr) {
                    try { diasConEventos = JSON.parse(eventDaysAttr); } catch (e) {}
                }
            }
            if (mesActualElement) mesActualElement.textContent = calendario.nombreMes;
            if (calendarioDiasContainer) {
                calendarioDiasContainer.innerHTML = calendario.dias.map(dayInfo => {
                    const hasEvent = dayInfo.isCurrentMonth && diasConEventos.includes(dayInfo.day);
                    const fechaCompleta = `${mesKey}-${String(dayInfo.day).padStart(2, '0')}`;
                    let clases = `flex justify-center items-center w-10 h-10 rounded-full text-sm font-medium mx-auto `;
                    if (dayInfo.isToday) {
                        clases += "border-3 border-[#006764] bg-transparent text-[#006764]";
                    } else if (hasEvent) {
                        clases += "bg-[#006764] text-white cursor-pointer hover:opacity-80";
                    } else if (dayInfo.isCurrentMonth) {
                        clases += "text-gray-700 hover:bg-gray-100 cursor-pointer";
                    } else {
                        clases += "text-gray-300 cursor-default";
                    }
                    if (dayInfo.isCurrentMonth) {
                        return `<div class="${clases}" data-fecha="${fechaCompleta}" onclick="window.scrollToEventByDate('${fechaCompleta}')">${dayInfo.day}</div>`;
                    } else {
                        return `<div class="${clases}" data-fecha="${fechaCompleta}">${dayInfo.day}</div>`;
                    }
                }).join('');
            }
        }
        
        let mesInicial = dayjs().format('YYYY-MM');
        actualizarCalendario(mesInicial);
    
        document.querySelectorAll('[data-month-toggle]').forEach(toggle => {
            const monthKey = toggle.getAttribute('data-month-toggle');
            const content = document.querySelector(`[data-month-content="${monthKey}"]`);
            const parentDiv = toggle.closest('.space-y-6');
            if (content && parentDiv) {
                content.classList.remove('hidden');
                content.classList.add('events-container');
                content.classList.add('month-hidden');
                toggle.addEventListener('click', (e) => {
                    e.preventDefault();
                    parentDiv.classList.toggle('open');
                    if (content.classList.contains('month-hidden')) {
                        const mesKey = monthKey;
                        actualizarCalendario(mesKey);
                        const calendarioSection = document.querySelector('#calendario-dinamico');
                        if (calendarioSection) {
                            const header = document.querySelector('header');
                            const headerHeight = header ? header.offsetHeight : 100;
                            const rect = calendarioSection.getBoundingClientRect();
                            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                            const offsetPosition = rect.top + scrollTop - headerHeight - 20;
                            window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
                        }
                        content.classList.remove('month-hidden');
                        void content.offsetHeight;
                    } else {
                        content.classList.add('month-hidden');
                    }
                });
            }
        });
        
        const prevMonthBtn = document.querySelector('#calendario-dinamico .flex.gap-8 button:first-child');
        const nextMonthBtn = document.querySelector('#calendario-dinamico .flex.gap-8 button:last-child');
        let currentCalendarMonth = dayjs(mesInicial + '-01');
        
        function cambiarMes(direccion) {
            if (direccion === 'prev') {
                currentCalendarMonth = currentCalendarMonth.subtract(1, 'month');
            } else {
                currentCalendarMonth = currentCalendarMonth.add(1, 'month');
            }
            const mesKey = currentCalendarMonth.format('YYYY-MM');
            actualizarCalendario(mesKey);
            const mesActualElement = document.getElementById('mes-actual');
            if (mesActualElement) {
                const nombreMes = currentCalendarMonth.format('MMMM YYYY');
                mesActualElement.textContent = nombreMes.charAt(0).toUpperCase() + nombreMes.slice(1).toLowerCase();
            }
            const seccionMes = document.querySelector(`[data-month="${mesKey}"]`);
            if (seccionMes) {
                const header = document.querySelector('header');
                const headerHeight = header ? header.offsetHeight : 100;
                const rect = seccionMes.getBoundingClientRect();
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                const offsetPosition = rect.top + scrollTop - headerHeight - 30;
                window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
        }
        
        if (prevMonthBtn) prevMonthBtn.addEventListener('click', () => cambiarMes('prev'));
        if (nextMonthBtn) nextMonthBtn.addEventListener('click', () => cambiarMes('next'));
    }); // Cierra el DOMContentLoaded

    // función scroll de la card con calendario (FUERA del DOMContentLoaded)
    function scrollToEventByDate(date) {
        const eventos = document.querySelectorAll('article[data-start-date]');
        let eventoEncontrado = null;
        for (let evento of eventos) {
            const startDate = evento.getAttribute('data-start-date');
            const endDate = evento.getAttribute('data-end-date');
            if (date >= startDate && date <= endDate) {
                eventoEncontrado = evento;
                break;
            }
        }
        if (eventoEncontrado) {
            const header = document.querySelector('header');
            const headerHeight = header ? header.offsetHeight : 100;
            const rect = eventoEncontrado.getBoundingClientRect();
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const offsetPosition = rect.top + scrollTop - headerHeight - 30;
            window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            eventoEncontrado.style.transition = 'border 0.3s ease';
            eventoEncontrado.style.border = '3px solid var(--color-primary)';
            eventoEncontrado.style.outlineOffset = '2px';
            setTimeout(() => { eventoEncontrado.style.border = ''; }, 2000);
        }
    }

    // Exponer la función globalmente
    window.scrollToEventByDate = scrollToEventByDate;
</script>


<style>
  /* Animaciones para dropdown de meses */
  
  /* Contenedor base - visible por defecto */
  .events-container {
    overflow: hidden;
    transition: all 0.3s ease;
    opacity: 1;
  }
  
  /* Estado oculto - se usa para animar */
  .events-container.month-hidden {
    max-height: 0 !important;
    opacity: 0;
    padding: 0;
    margin: 0;
    visibility: hidden;
  }
  
  /* Rotación de la flecha */
  [data-month-toggle] svg {
    transition: transform 0.3s ease;
  }
  
  .open [data-month-toggle] svg,
  [data-month-toggle] svg.rotated {
    transform: rotate(180deg);
  }
  
  /* Eliminar el hidden de Tailwind que bloquea todo */
  .events-container.hidden {
    display: block !important;
  }
</style>