                                                    const eventoId = `evento-${evento.startDate.split('T')[0]}`;
                                                    
                                                    let fechaTexto = '';
                                                    if (fechaInicio.isSame(fechaFin, 'day')) {
                                                        fechaTexto = fechaInicio.format('D [de] MMMM');
                                                    } else if (fechaInicio.isSame(fechaFin, 'month')) {
                                                        fechaTexto = `Del ${fechaInicio.format('D')} al ${fechaFin.format('D [de] MMMM')}`;
                                                    } else {
                                                        fechaTexto = `Del ${fechaInicio.format('D [de] MMMM')} al ${fechaFin.format('D [de] MMMM')}`;
