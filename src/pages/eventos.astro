---
/** Fecha “actual” en servidor en cada petición (no congelada al build) */
export const prerender = false;

import dayjs from 'dayjs';
import 'dayjs/locale/es';
import Layout from '../layouts/Layout.astro';
import { strapiFetch } from "@server/strapiClient";
import PromotionSlider from '@components/sections/PromotionSlider.astro';
import BaseForm from "@components/forms/BaseForm.astro";
import FormField from "@components/forms/FormField.astro";
import CheckboxField from "@components/forms/CheckboxField.astro";
import SubmitButton from "@components/forms/SubmitButton.astro";
import ImageResponsive from "@components/media/ImageResponsive.astro";
import SlideArticles from '@components/blog/slideArticles.astro';
import { fetchBlogSliderData } from "@lib/blog/blogSliderData";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';

// import SliderPromociones from '../components/sliderPromociones.astro';
// import Code from '@components/js.astro';

let data: any = {};
// let dataPromociones: any[] = [];

try {
  const response = await strapiFetch("/events-page?populate[events][populate]=image&populate=heroImage");  
  data = response.data;
} catch (error) {
  console.error('Error fetching events:', error);
  data = {
    Eventos: [],
    title: 'Eventos médicos',
    description: 'Mantente actualizado con los últimos avances'
  };
}

// try {
//   dataPromociones = await strapi.find('slider-promocions?populate=*');
// } catch (error) {
//   console.warn('slider-promocions endpoint not found, using empty array');
//   dataPromociones = [];
// }


/** Blog: vitrina 9 artículos más nuevos (3 por vista en desktop), misma fuente que home. */
let articulosRelacionados: any[] = [];
let classificationTagByArticleKey = new Map<string, string>();

try {
    const blogSlider = await fetchBlogSliderData();
    articulosRelacionados = blogSlider.articulos;
    classificationTagByArticleKey = blogSlider.tagByArticleKey;
} catch (e) {
    console.error("Error blog slider (eventos):", e);
    articulosRelacionados = [];
    classificationTagByArticleKey = new Map();
}

// Configurar dayjs en español
dayjs.locale('es');

// Obtener fecha actual
const now = dayjs();
const currentMonth = now.format('MMMM YYYY');
const currentMonthTitleCase = currentMonth.charAt(0).toUpperCase() + currentMonth.slice(1).toLowerCase();

// Obtener información del mes actual
const startOfMonth = now.startOf('month');
const endOfMonth = now.endOf('month');
const startOfWeek = startOfMonth.startOf('week'); // Domingo
const endOfWeek = endOfMonth.endOf('week'); // Sábado

// Generar array de días para el calendario (6 semanas x 7 días = 42 días)
const calendarDays = [];
let currentDay = startOfWeek;

for (let i = 0; i < 42; i++) {
    const isCurrentMonth = currentDay.month() === now.month();
    const dayNumber = currentDay.date();
    const isToday = currentDay.isSame(now, 'day');
    
    calendarDays.push({
        day: dayNumber,
        isCurrentMonth,
        isToday,
        fullDate: currentDay.format('YYYY-MM-DD')
    });
    
    currentDay = currentDay.add(1, 'day');
}

// Días con eventos (puedes personalizar esto)
const eventDays = [11, 14];

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
const heroImageUrl = data?.heroImage?.url ?? logoUrl;
---


<Layout
  title="Eventos MedRent | Congresos, talleres y presentaciones médicas"
  description="Explora congresos, talleres y presentaciones donde MedRent comparte innovación y equipos líderes. Filtra por especialidad y fecha."
  keywords="eventos médicos; congresos; talleres; MedRent; tecnología médica"
  ogImage={heroImageUrl}
>
    <!-- <Fragment slot="metas">
        <title>Eventos | MedRent – Eventos médicos y de tecnología</title> -->
        <!-- <meta name="description" content="Mantente actualizado con los últimos avances en tecnología médica. Participamos en congresos, seminarios y eventos especializados donde compartimos conocimientos sobre equipos de diagnóstico cardiovascular y respiratorio." /> --> 
    
        <!-- Open Graph -->
		<!-- <meta property="og:title" content="Eventos | MedRent – Eventos médicos y de tecnología">
		<meta property="og:type" content="website"> 
		<meta property="og:url" content="https://www.medrent.mx/eventos">
		<meta property="og:image" content="https://www.medrent.mx/images/og/home.jpg">
		<meta property="og:image:type" content="image/jpeg">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630"> --> 
        
        <!-- Twitter -->
        <!-- <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content="https://www.medrent.mx/eventos">
        <meta property="twitter:image" content="https://www.medrent.mx/images/og/home.jpg">
        <meta property="twitter:title" content="Eventos | MedRent – Eventos médicos y de tecnología" /> -->
    <!-- </Fragment> -->


        <Fragment slot="head">
            <BreadcrumbSchema
            items={[
                { name: 'Inicio', url: `${baseUrl}/` },
                { name: 'Eventos', url: `${baseUrl}/eventos` },
            ]}
            id={breadcrumbId}
            />
            <script type="application/ld+json" set:html={
              (() => {
                const eventosList = Array.isArray(data?.events) ? data.events : [];
                const slice = eventosList.slice(0, 12);
                const itemListElement = slice.map((evento: any, index: number) => {
                  const startDate = evento?.startDate;
                  const endDate = evento?.endDate;
                  const title =
                    evento?.title || evento?.eventType || `Evento ${index + 1}`;
                  const description = evento?.subtitle || evento?.description || "";
                  const imageUrl = evento?.image?.url;
                  const locationName = evento?.locationLabel || "";
                  return {
                    "@type": "ListItem",
                    position: index + 1,
                    item: {
                      "@type": "Event",
                      "@id": `${canonicalUrl}#event-${index + 1}`,
                      name: title,
                      description,
                      startDate,
                      endDate,
                      eventAttendanceMode:
                        "https://schema.org/OfflineEventAttendanceMode",
                      eventStatus: "https://schema.org/EventScheduled",
                      image: imageUrl ? [imageUrl] : undefined,
                      location: locationName
                        ? {
                            "@type": "Place",
                            name: locationName,
                            url: evento?.locationUrlMaps,
                          }
                        : undefined,
                      organizer: { "@id": `${baseUrl}/#organization` },
                    },
                  };
                });

                return JSON.stringify({
                  "@context": "https://schema.org",
                  "@graph": [
                    {
                      "@type": "WebPage",
                      "@id": `${canonicalUrl}#webpage`,
                      url: canonicalUrl,
                      name:
                        "Eventos MedRent | Congresos, talleres y presentaciones médicas",
                      description:
                        "Explora congresos, talleres y presentaciones donde MedRent comparte innovación y equipos líderes. Filtra por especialidad y fecha.",
                      isPartOf: { "@id": `${baseUrl}/#website` },
                      about: { "@id": `${baseUrl}/#organization` },
                      inLanguage: "es-MX",
                      breadcrumb: { "@id": breadcrumbId },
                      mainEntity: { "@id": `${canonicalUrl}#event-list` },
                      primaryImageOfPage: {
                        "@type": "ImageObject",
                        url: heroImageUrl,
                      },
                    },
                    {
                      "@type": "CollectionPage",
                      "@id": `${canonicalUrl}#event-collection`,
                      url: canonicalUrl,
                      name: "Eventos médicos y de tecnología | MedRent",
                      description:
                        data?.description ||
                        "Eventos médicos, congresos, talleres y presentaciones donde MedRent comparte innovación y equipos líderes.",
                      isPartOf: { "@id": `${baseUrl}/#website` },
                      about: { "@id": `${baseUrl}/#organization` },
                      inLanguage: "es-MX",
                      mainEntity: { "@id": `${canonicalUrl}#event-list` },
                    },
                    {
                      "@type": "ItemList",
                      "@id": `${canonicalUrl}#event-list`,
                      name: "Eventos médicos y de tecnología MedRent",
                      itemListOrder:
                        "https://schema.org/ItemListUnordered",
                      itemListElement,
                    },
                  ],
                });
              })()
            }></script>
        </Fragment>

    <div class="absolute w-full z-2">
        <Breadcrumb
        textColor="text-dark"
        items={[
            { name: "INICIO", href: "/" },
            { name: "EVENTOS" }
        ]}
        />
    </div>

    <!-- Sección de Eventos -->
    <section class="w-full" style="background: linear-gradient(180deg, #D8E5E3 0%, #FFF 50%);">
        <div class="max-w-[1320px] mx-auto px-4 py-4 md:px-6 md:py-6 lg:px-8 lg:py-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 lg:gap-6 items-center mt-8">
                
                <!-- Columna izquierda - Contenido -->
                <div class="lg:pr-8 flex flex-col items-start justify-center gap-2" style="height: -webkit-fill-available;">
                    <p class="text-[14px] font-lato text-[var(--color-primary)] font-bold">EVENTOS</p>
                    <h1 class="text-[28px] font-bold text-[#261819] leading-tight">
                       {data.title ? data.title : "Eventos médicos"}
                    </h1>
                    
                    <p class="text-[16px] leading-[1.6] text-[#5A4043]">
                        {data.description ? data.description : "Conoce los congresos, talleres y presentaciones donde Medrent comparte innovación y equipos líderes en diagnóstico y tratamiento."}
                    </p>
                </div>
                
                <!-- Columna derecha - Imagen -->
                <div class="lg:pl-8">
                    <div class="relative rounded-[24px] overflow-hidden">
                        <ImageResponsive
                          image={data.heroImage}
                          alt="Eventos médicos y de tecnología"
                          class="w-full"
                          sizes="(min-width: 1024px) 50vw, 100vw"
                          loading="eager"
                          decoding="async"
                          fetchpriority="high"
                        />
                    </div>
                </div>  
            </div>
        </div>
    </section>
    
    <!-- Sección Calendario y Eventos (overflow visible para que position:sticky del sidebar funcione con Lenis/grid) -->
    <section class="w-full bg-white py-6 md:py-8 overflow-visible">
        <div class="max-w-[1320px] mx-auto px-0 lg:px-4">
            <!-- items-start: la celda izquierda no copia la altura del listado; el aside usa position:sticky + max-height al viewport (scroll interno). -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                
                <!-- Sticky + scroll en el wrapper de columna (no en aside): sticky+overflow en el mismo nodo rompe sticky en Chrome/Safari; Lenis captura wheel en el contenedor con data-lenis-prevent -->
                <div
                    class="eventos-plp-filters-scroll min-w-0 lg:col-span-1 lg:self-start px-4 md:p-6 lg:min-h-0"
                    data-lenis-prevent
                >
                    <aside class="w-full min-w-0" aria-label="Calendario y filtros de eventos">
                        <div class="text-center font-sans">
                         {/* Contador de eventos */}
                        <div class="text-left mb-2">
                            <span class="text-[var(--Schemes-Primary,#006764)] font-lato text-[14px] font-medium leading-[20px] tracking-[0.1px]">
                                {(() => {
                                    const eventosList = data?.events || [];
                                    const totalEventos = eventosList.length;
                                    return `${totalEventos} ${totalEventos === 1 ? 'EVENTO' : 'EVENTOS'}`;
                                })()}
                            </span>
                        </div>
                        
                        <h2 class="font-lato text-[28px] leading-[36px] text-[#261819] font-medium text-left mb-4">
                            Eventos Medrent{' '}
                            <span id="eventos-medrent-year">{now.year()}</span>
                        </h2>

                        <!-- Por debajo del breakpoint md el calendario no se muestra (lista de eventos y filtros sí) -->
                        <div class="hidden md:block bg-[var(--color-secondary-light)] rounded-2xl p-6" id="calendario-dinamico">
                            <div class="flex justify-between items-center">
                                <span id="mes-actual">
                                    {currentMonthTitleCase}
                                </span>
                                
                                <!-- Agrupa los botones aquí -->
                                <div class="flex gap-8">
                                    <button id="prev-month-btn" type="button" class="text-gray-400 color-[#6D7A78] hover:text-gray-600">&lt;</button>
                                    <button id="next-month-btn" type="button" class="text-gray-400 color-[#6D7A78] hover:text-gray-600">&gt;</button>
                                </div>
                            </div>
                            <div id="calendario-dias" class="mt-4">
                                <!-- Headers de días -->
                                <div class="grid grid-cols-7 mb-3">
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">DOM</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">LUN</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">MAR</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">MIÉ</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">JUE</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">VIE</div>
                                    <div class="text-center text-sm text-gray-500 font-medium py-2">SÁB</div>
                                </div>

                                <!-- Días del calendario generados dinámicamente -->
                                <div id="calendario-grid-dias" class="grid grid-cols-7 gap-1">
                                    {calendarDays.map((dayInfo) => {
                                        const hasEvent = dayInfo.isCurrentMonth && eventDays.includes(dayInfo.day);
                                        return (
                                            <div
                                                class={`flex justify-center items-center w-10 h-10 rounded-full text-sm font-medium  mx-auto
                                                    ${
                                                    dayInfo.isToday
                                                        ? "border-4 border-[#006764] bg-transparent text-[#006764]"
                                                        : hasEvent
                                                        ? "bg-[#006764] text-white"
                                                        : dayInfo.isCurrentMonth 
                                                        ? "text-gray-700 hover:bg-gray-100 cursor-pointer"
                                                        : "text-gray-300"
                                                    }`}
                                            >
                                                {dayInfo.day}
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        </div>
                    </div>

                        <div id="event-filters" class="mt-6 md:p-4 sm:p-0 text-left pb-8 lg:pb-12">
                            <div class="flex justify-between items-center mb-4 pb-2">
                                <h3 id="filters-title" class="font-bold text-[16px] text-[#09303A]">Filtros (0)</h3>
                                <button type="button" id="clear-filters" class="text-sm text-[#006764] hover:underline cursor-pointer transition-opacity">Limpiar</button>
                            </div>

                            <!-- Tipo de evento -->
                            <div class="mb-4">
                                <button id="toggle-event-type" type="button" class="cursor-pointer border-b border-[#E5E9EA] w-full flex justify-between items-center py-2 text-[#09303A] font-medium transition-colors rounded-md">
                                    <span class="text-[14px] font-lato">Tipo de evento</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="icon-chevron transition-transform duration-200">
                                        <path d="M17 9.16994C16.8126 8.98369 16.5592 8.87915 16.295 8.87915C16.0308 8.87915 15.7774 8.98369 15.59 9.16994L12 12.7099L8.46001 9.16994C8.27265 8.98369 8.0192 8.87915 7.75501 8.87915C7.49082 8.87915 7.23737 8.98369 7.05001 9.16994C6.95628 9.26291 6.88189 9.37351 6.83112 9.49537C6.78035 9.61723 6.75421 9.74793 6.75421 9.87994C6.75421 10.012 6.78035 10.1427 6.83112 10.2645C6.88189 10.3864 6.95628 10.497 7.05001 10.5899L11.29 14.8299C11.383 14.9237 11.4936 14.9981 11.6154 15.0488C11.7373 15.0996 11.868 15.1257 12 15.1257C12.132 15.1257 12.2627 15.0996 12.3846 15.0488C12.5064 14.9981 12.617 14.9237 12.71 14.8299L17 10.5899C17.0937 10.497 17.1681 10.3864 17.2189 10.2645C17.2697 10.1427 17.2958 10.012 17.2958 9.87994C17.2958 9.74793 17.2697 9.61723 17.2189 9.49537C17.1681 9.37351 17.0937 9.26291 17 9.16994Z" fill="#006764"/>
                                    </svg>
                                </button>
                                <div id="dropdown-event-type" class="filter-dropdown hidden mt-2 pl-2 space-y-2">
                                    <div id="filter-event-type" class="cursor-pointer grid grid-cols-1 gap-4 mt-4"></div>
                                </div>
                            </div>

                            <!-- Especialidad -->
                            <div class="mb-4">
                                <button id="toggle-specialty" type="button" class="cursor-pointer border-b border-[#E5E9EA] w-full flex justify-between items-center py-2 text-[#09303A] font-medium transition-colors rounded-md">
                                    <span class="text-[14px] font-lato">Especialidad</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="icon-chevron transition-transform duration-200">
                                        <path d="M17 9.16994C16.8126 8.98369 16.5592 8.87915 16.295 8.87915C16.0308 8.87915 15.7774 8.98369 15.59 9.16994L12 12.7099L8.46001 9.16994C8.27265 8.98369 8.0192 8.87915 7.75501 8.87915C7.49082 8.87915 7.23737 8.98369 7.05001 9.16994C6.95628 9.26291 6.88189 9.37351 6.83112 9.49537C6.78035 9.61723 6.75421 9.74793 6.75421 9.87994C6.75421 10.012 6.78035 10.1427 6.83112 10.2645C6.88189 10.3864 6.95628 10.497 7.05001 10.5899L11.29 14.8299C11.383 14.9237 11.4936 14.9981 11.6154 15.0488C11.7373 15.0996 11.868 15.1257 12 15.1257C12.132 15.1257 12.2627 15.0996 12.3846 15.0488C12.5064 14.9981 12.617 14.9237 12.71 14.8299L17 10.5899C17.0937 10.497 17.1681 10.3864 17.2189 10.2645C17.2697 10.1427 17.2958 10.012 17.2958 9.87994C17.2958 9.74793 17.2697 9.61723 17.2189 9.49537C17.1681 9.37351 17.0937 9.26291 17 9.16994Z" fill="#006764"/>
                                    </svg>
                                </button>
                                <div id="dropdown-specialty" class="filter-dropdown hidden mt-2 pl-2 space-y-2">
                                    <div id="filter-specialty" class="cursor-pointer grid grid-cols-1 gap-4 mt-4"></div>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
                
                <!-- Cards de eventos: 2 columnas del grid; lg:pt-8 alinea el título de mes (h3) con "Eventos Medrent {año}" (h2) compensando la fila "N EVENTOS" + mb-2 de la columna izquierda -->
                <div class="min-w-0 lg:col-span-2 px-4 md:p-6">
                    <!-- Sin gap vertical entre meses: los hovers de fila se ven como lista continua (estilo FAQ PDP) -->
                    <div class="flex flex-col gap-0 lg:pt-8">
                        {(() => {
                            // Verificar si hay eventos
                            const eventosList = data?.events || [];
                            
                            if (eventosList.length === 0) {
                                return <p class="text-center text-gray-500">No hay eventos próximos</p>;
                            }
                            
                            // Agrupar eventos por mes
                            const eventosPorMes: any = {};
                            
                            eventosList.forEach((evento: any) => {
                                const fechaInicio = dayjs(evento.startDate);
                                const mesKey = fechaInicio.format('YYYY-MM');
                                const mesNombreRaw = fechaInicio.format('MMMM YYYY');
                                const mesNombre = mesNombreRaw.charAt(0).toUpperCase() + mesNombreRaw.slice(1).toLowerCase();
                                
                                if (!eventosPorMes[mesKey]) {
                                    eventosPorMes[mesKey] = {
                                        nombre: mesNombre,
                                        eventos: [],
                                        diasConEventos: new Set()
                                    };
                                }
                                
                                // Agregar días del evento para el calendario
                                const fechaInicioEvento = dayjs(evento.startDate);
                                const fechaFinEvento = dayjs(evento.endDate);
                                let diaActual = fechaInicioEvento;
                                
                                while (diaActual.isBefore(fechaFinEvento, 'day') || diaActual.isSame(fechaFinEvento, 'day')) {
                                    if (diaActual.format('YYYY-MM') === mesKey) {
                                        eventosPorMes[mesKey].diasConEventos.add(diaActual.date());
                                    }
                                    diaActual = diaActual.add(1, 'day');
                                }
                                
                                eventosPorMes[mesKey].eventos.push(evento);
                            });
                            
                            // Meses por año: siempre el año civil en curso + cualquier año que aparezca en fechas de eventos
                            const yearsSet = new Set([now.year()]);
                            Object.keys(eventosPorMes).forEach((k) => {
                                const y = Number.parseInt(k.slice(0, 4), 10);
                                if (Number.isFinite(y)) yearsSet.add(y);
                            });
                            const sortedYears = [...yearsSet].sort((a, b) => a - b);
                            const allMonths: {
                                key: string;
                                nombre: string;
                                nombreCompleto: string;
                                hasEvents: boolean;
                            }[] = [];
                            sortedYears.forEach((yearNum) => {
                                for (let i = 0; i < 12; i++) {
                                    const monthDate = dayjs(`${yearNum}-${String(i + 1).padStart(2, '0')}-01`);
                                    const key = monthDate.format('YYYY-MM');
                                    allMonths.push({
                                        key,
                                        nombre:
                                            monthDate.format('MMMM').charAt(0).toUpperCase() +
                                            monthDate.format('MMMM').slice(1).toLowerCase(),
                                        nombreCompleto:
                                            monthDate.format('MMMM YYYY').charAt(0).toUpperCase() +
                                            monthDate.format('MMMM YYYY').slice(1).toLowerCase(),
                                        hasEvents: Boolean(eventosPorMes[key]),
                                    });
                                }
                            });
                            
                            // Renderizar todos los meses (con y sin eventos)
                            return allMonths.map((mes) => {
                                const mesData = eventosPorMes[mes.key];
                                const tieneEventos = mes.hasEvents;
                                
                                if (tieneEventos && mesData) {
                                    // Renderizar meses CON eventos
                                    return (
                                        <div class="eventos-month-section flex flex-col gap-0" data-month={mes.key} data-event-days={JSON.stringify([...mesData.diasConEventos])}>
                                            <div
                                                class="eventos-month-toggle-label group relative m-0 cursor-pointer overflow-hidden rounded-[2px] px-2 py-4"
                                                style="border-bottom: 1px solid var(--color-primary);"
                                                data-month-toggle={mes.key}
                                            >
                                                <div class="eventos-month-hover-fill" aria-hidden="true"></div>
                                                <div class="relative z-10 flex items-center justify-between gap-4">
                                                    <h3 class="mb-0 font-lato text-[28px] leading-[36px] font-medium text-[#261819]">
                                                        {mesData.nombre}
                                                    </h3>
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="transition-transform duration-300 group-[.open]:rotate-180">
