<!-- Popup de Evento -->
<div id="event-popup-overlay" class="fixed inset-0 z-50 hidden">
    <!-- Misma capa que PDP (popUpSolicitarCotizacion): backdrop-filter sobre el viewport, sin blur al <main> -->
    <div
        id="event-blurred-background"
        class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-all duration-300"
        aria-hidden="true"
    ></div>

    <!-- Popup Content -->
    <div
        id="PopupContent"
        class="relative z-10 flex items-center justify-center min-h-screen p-4 h-[85%] md:h-[85%] lg:h-auto md:mt-12 overflow-y-auto rounded-2xl pointer-events-none"
    >
        <div class="pointer-events-auto bg-white rounded-lg shadow-xl max-w-4xl w-full overflow-auto relative h-[85%] md:h-[85%] lg:h-auto">
                <!-- Botón cerrar en esquina superior derecha del popup -->
                <button 
                    id="close-event-popup"
                    class="absolute top-0 right-0 flex items-end justify-end text-white text-2xl leading-none bg-[#171D1C] border-none cursor-pointer z-10 px-2 py-1 rounded"
                >
                    ×
                </button>
                
                <!-- Contenido del popup -->
                <div class="flex flex-col lg:flex-row relative">
                    <!-- Imagen izquierda que cubre toda la altura -->
                    <div class="lg:w-1/2 relative">
                        <img
                            id="event-popup-image"
                            src=""
                            alt="Evento"
                            class="w-full h-auto min-h-0 object-contain md:h-64 md:min-h-[500px] md:object-cover lg:h-full lg:min-h-[500px] lg:object-cover"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    
                    <!-- Contenido derecha -->
                    <div class="lg:w-1/2 p-4 lg:p-8">

                        <div class="mb-8 flex flex-col items-start gap-2 flex-1 self-stretch" id="event-popup-text">
