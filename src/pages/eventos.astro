<script>
    import dayjs from 'dayjs';
    import 'dayjs/locale/es';
    let isFirstLoad = true;

    // Extender tipo de Window
    declare global {
        interface Window {
            scrollToEventByDate: (date: string) => void;
        }
    }

    // Configurar dayjs en español
    dayjs.locale('es');

    /** Mismo offset que Layout: espaciador lg h-[109px], móvil h-[50px] */
    function getLayoutHeaderOffsetPx(): number {
        return window.matchMedia('(min-width: 1024px)').matches ? 109 : 50;
    }

    function parseEventFilterUrlValues(params: URLSearchParams, key: string): string[] {
        const raw = params.get(key);
        if (!raw) return [];
        return [...new Set(raw.split(',').map((s) => s.trim()).filter(Boolean))];
    }

    function updateEventsFilterUrl() {
        const params = new URLSearchParams();
        const eventTypes = Array.from(
            document.querySelectorAll('input[data-filter="eventType"]:checked')
        ).map((el) => (el as HTMLInputElement).value);
        const specialties = Array.from(
            document.querySelectorAll('input[data-filter="specialty"]:checked')
        ).map((el) => (el as HTMLInputElement).value);
        if (eventTypes.length) params.set('eventType', eventTypes.join(','));
        if (specialties.length) params.set('specialty', specialties.join(','));
        const qs = params.toString();
        const newUrl = window.location.pathname + (qs ? `?${qs}` : '');
        if (document.documentElement.dataset.eventosClientFilters === '1') {
            window.history.pushState({}, '', newUrl);
        } else {
            window.location.href = newUrl;
        }
    }

    function updateEventsFiltersTitle() {
        const title = document.getElementById('filters-title');
        if (!title) return;
        const n = document.querySelectorAll('#event-filters input[data-filter]:checked').length;
        title.textContent = `Filtros (${n})`;
    }

    /** Evita que `change` dispare applyFilters+URL al setear checkboxes por URL o Limpiar */
    let suppressFilterChange = 0;
    function runWithSuppressFilterChange(fn: () => void) {
        suppressFilterChange++;
        try {
            fn();
        } finally {
            suppressFilterChange--;
        }
    }

    function setEventFiltersFromUrl() {
        runWithSuppressFilterChange(() => {
            const params = new URLSearchParams(window.location.search);
            const types = parseEventFilterUrlValues(params, 'eventType');
            const specs = parseEventFilterUrlValues(params, 'specialty');
            document.querySelectorAll('#event-filters input[data-filter="eventType"]').forEach((input) => {
                if (input instanceof HTMLInputElement) input.checked = types.includes(input.value);
            });
            document.querySelectorAll('#event-filters input[data-filter="specialty"]').forEach((input) => {
                if (input instanceof HTMLInputElement) input.checked = specs.includes(input.value);
            });
            updateEventsFiltersTitle();
        });
    }

    // Función para actualizar calendario
    function actualizarCalendario(mesKey: string) {
        const calendario = generarCalendario(mesKey + '-01');
        const mesActualElement = document.getElementById('mes-actual');
        const calendarioDiasContainer = document.getElementById('calendario-grid-dias');
        const seccionMes = document.querySelector(`[data-month="${mesKey}"]`);
        let diasConEventos: number[] = [];
        if (seccionMes) {
            const eventDaysAttr = seccionMes.getAttribute('data-event-days');
            if (eventDaysAttr) {
                try {
                    const parsed = JSON.parse(eventDaysAttr) as unknown;
                    if (Array.isArray(parsed)) {
                        diasConEventos = parsed.filter((d): d is number => typeof d === 'number');
                    }
                } catch (e) {}
            }
        }
        if (mesActualElement) mesActualElement.textContent = calendario.nombreMes;
        if (calendarioDiasContainer) {
            calendarioDiasContainer.innerHTML = calendario.dias.map((dayInfo: any) => {
                const hasEvent = dayInfo.isCurrentMonth && diasConEventos.includes(dayInfo.day);
                const fechaCompleta = `${mesKey}-${String(dayInfo.day).padStart(2, '0')}`;
                let clases = `flex justify-center items-center w-10 h-10 rounded-full text-sm font-medium mx-auto `;
                if (dayInfo.isToday) {
                    clases += "border-4 border-[#006764] bg-transparent text-[#006764]";
                } else if (hasEvent) {
                    clases += "bg-[#006764] text-white cursor-pointer hover:opacity-80";
                } else if (dayInfo.isCurrentMonth) {
                    clases += "text-gray-700 hover:bg-gray-100 cursor-pointer";
                } else {
                    clases += "text-gray-300 cursor-default";
                }
                if (dayInfo.isCurrentMonth) {
                    return `<div class="${clases}" data-fecha="${fechaCompleta}" onclick="window.scrollToEventByDate('${fechaCompleta}')">${dayInfo.day}</div>`;
                } else {
                    return `<div class="${clases}" data-fecha="${fechaCompleta}">${dayInfo.day}</div>`;
                }
            }).join('');
        }
    }

    // Función para generar calendario
    function generarCalendario(fechaBase: string) {
        const fecha = dayjs(fechaBase);
        const startOfMonth = fecha.startOf('month');
        const startOfWeek = startOfMonth.startOf('week');
        const calendarDays = [];
        let currentDay = startOfWeek;
        for (let i = 0; i < 42; i++) {
            calendarDays.push({
                day: currentDay.date(),
                isCurrentMonth: currentDay.month() === fecha.month(),
                isToday: currentDay.isSame(dayjs(), 'day'),
                fullDate: currentDay.format('YYYY-MM-DD')
            });
            currentDay = currentDay.add(1, 'day');
        }
        return {
            dias: calendarDays,
            nombreMes: (() => {
                const raw = fecha.format('MMMM YYYY');
                return raw.charAt(0).toUpperCase() + raw.slice(1).toLowerCase();
            })()
        };
    }

    /** Navegación del calendario (< >) y alineación con la lista de meses al hacer scroll */
    let currentCalendarMonth = dayjs();
    let lastScrollSyncedMonthKey: string | null = null;
    let suppressScrollCalendarSyncUntil = 0;

    /**
     * Mes que corresponde a lo que el usuario está leyendo en la lista (columna derecha).
     * Último mes cuyo título [data-month-toggle] ya cruzó la línea bajo el header (como un TOC).
     * Evita saltar a abril solo porque el centro del título de marzo quedó “lejos” del ancla
     * mientras aún hay cards de marzo en pantalla (bug de distancia mínima al centro).
     */
    function getEventosMonthKeyClosestToListAnchor(): string | null {
        const sections = Array.from(
            document.querySelectorAll('.eventos-month-section[data-month]'),
        ) as HTMLElement[];
        if (!sections.length) return null;
        const anchorY = getLayoutHeaderOffsetPx() + 56;
        let activeKey: string | null = null;
        for (const section of sections) {
            const key = section.dataset.month;
            if (!key) continue;
            const toggle = section.querySelector('[data-month-toggle]');
            if (!toggle) continue;
            const top = toggle.getBoundingClientRect().top;
            if (top <= anchorY) {
                activeKey = key;
            }
        }
        if (activeKey !== null) return activeKey;
        const first = sections[0]?.dataset.month;
        return first ?? null;
    }

    function trySyncEventosCalendarioConMesEnLista() {
        if (typeof performance !== 'undefined' && performance.now() < suppressScrollCalendarSyncUntil) return;
        const mk = getEventosMonthKeyClosestToListAnchor();
        if (!mk || mk === lastScrollSyncedMonthKey) return;
        lastScrollSyncedMonthKey = mk;
        currentCalendarMonth = dayjs(`${mk}-01`);
        actualizarCalendario(mk);
    }

