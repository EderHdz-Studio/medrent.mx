---
import Layout from "@layouts/Layout.astro";
import { getApplicationsByCategory } from "@server/api/applications";
import { getCategories } from "@server/api/categories";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import PromotionSlider from '@components/sections/PromotionSlider.astro';
import EspecialidadesSlider from "@components/sections/EspecialidadesSlider.astro";
import { getSiteConfig } from "@server/siteConfig";
const siteConfig = await getSiteConfig();

export async function getStaticPaths() {
  const categories = await getCategories();

  return categories.map((c) => ({
    params: { category: c.slug },
  }));
}

const { category } = Astro.params;
const categories = await getCategories();

// Buscar la categoría actual por slug
const especialidad = Array.isArray(categories)
  ? categories.find(item => item.slug === category)
  : null;
const canonical = new URL(Astro.originPathname ?? Astro.url.pathname, Astro.site).toString();

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = canonical;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = siteConfig?.favicon512x512?.url;
---

<Layout
  title={`${especialidad?.name ?? "Especialidad"} | Aplicaciones clínicas y tecnología médica | MedRent`}
  description={especialidad?.heroDescription ?? "Tecnología médica para diagnóstico, terapia y rehabilitación con soporte especializado de MedRent."}
  keywords={`${especialidad?.name ?? "especialidad"}; tecnología médica; equipos médicos; MedRent`}
>
  <style>
    body {
      background: var(--color-secondary-light);
    }
  </style>

  <!-- Breadcrumb Schema dinámico -->
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Inicio', url: `${baseUrl}/` },
      { name: 'Especialidades', url: `${baseUrl}/especialidades` },
      { name: especialidad?.name ?? "", url: canonicalUrl },
    ]}
    id={breadcrumbId}
  />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={
      (() => {
        const subs = Array.isArray(especialidad?.subcategories)
          ? especialidad.subcategories.filter((s) => s?.slug)
          : [];
        const specialtyId = `${canonicalUrl}#specialty`;
        const listId = `${canonicalUrl}#applications`;
        const itemListElement = subs.slice(0, 12).map((s, index) => {
          const subSlug = s?.slug;
          const subUrl = `${baseUrl}/especialidades/${especialidad?.slug ?? ""}/${subSlug}`;
          const subName = s?.name ?? s?.Nombre ?? s?.title ?? "Aplicación";
          return {
            "@type": "ListItem",
            position: index + 1,
            item: {
              "@type": "MedicalSpecialty",
              "@id": `${subUrl}#specialty`,
              name: subName,
              url: subUrl,
            },
            url: subUrl,
          };
        });

        return JSON.stringify({
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "WebPage",
              "@id": `${canonicalUrl}#webpage`,
              url: canonicalUrl,
              name: `${especialidad?.name ?? "Especialidad"} | Aplicaciones clínicas y tecnología médica | MedRent`,
              description:
                especialidad?.heroDescription ||
                "Tecnología médica para diagnóstico, terapia y rehabilitación con soporte especializado de MedRent.",
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": `${baseUrl}/#organization` },
              inLanguage: "es-MX",
              breadcrumb: { "@id": breadcrumbId },
              mainEntity: { "@id": listId },
              primaryImageOfPage: {
                "@type": "ImageObject",
                url: especialidad?.heroImage?.url || logoUrl,
              },
            },
            {
              "@type": "MedicalSpecialty",
              "@id": specialtyId,
              name: especialidad?.name ?? "Especialidad",
              url: canonicalUrl,
              description: especialidad?.heroDescription,
              relevantSpecialty: { "@id": `${baseUrl}/#organization` },
            },
            {
              "@type": "ItemList",
              "@id": listId,
              name: `${especialidad?.name ?? "Especialidad"} — aplicaciones clínicas`,
              itemListOrder: "https://schema.org/ItemListOrderAscending",
              itemListElement,
            },
          ],
        });
      })()
    }></script>
  </Fragment>

  <!-- Sticky Next Specialty -->
  <div id="nextSpecialtySticky" class="fixed  left-0 right-0 z-40 px-0 lg:px-4 mt-[6px] lg:mt-0  
    transition-all duration-500
    opacity-0 translate-y-4 pointer-events-none">
    
    <div class="max-w-7xl mx-auto">

      <div class="relative flex items-center  bg-[var(--color-primary)] from-[var(--color-primary)]  to-[var(--color-primary-dark)]  rounded-b-[24px]  overflow-hidden  shadow-lg  min-h-[72px]">


        <!-- Previous Button -->
         {(() => {
            const items = Array.isArray(categories) ? categories : [];
            const currentIdx = items.findIndex((item) => item.slug === category);
            const prevIdx = currentIdx === 0 ? items.length - 1 : currentIdx - 1;
            const nextIdx = currentIdx === items.length - 1 ? 0 : currentIdx + 1;
     
            const prevItem = items[prevIdx];
            const nextItem = items[nextIdx];
            return (
              <div>
                <a 
                  id="prevSpecialty"
                  href={prevItem ? `/especialidades/${prevItem.slug}` : "#"}
                  class="ml-4 md:ml-8 flex items-center justify-center  py-2 px-4 rounded-full  bg-white/10  hover:bg-white/20  transition  backdrop-blur-sm  text-white cursor-pointer"
                  aria-label="Especialidad anterior"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-2 h-8">
                    <path d="M17 11L9.41 11L12.71 7.71C12.8983 7.5217 13.0041 7.26631 13.0041 7C13.0041 6.7337 12.8983 6.47831 12.71 6.29C12.5217 6.1017 12.2663 5.99591 12 5.99591C11.7337 5.99591 11.4783 6.1017 11.29 6.29L6.29 11.29C6.19896 11.3851 6.1276 11.4973 6.08 11.62C5.97998 11.8635 5.97998 12.1365 6.08 12.38C6.1276 12.5028 6.19896 12.6149 6.29 12.71L11.29 17.71C11.383 17.8037 11.4936 17.8781 11.6154 17.9289C11.7373 17.9797 11.868 18.0058 12 18.0058C12.132 18.0058 12.2627 17.9797 12.3846 17.9289C12.5064 17.8781 12.617 17.8037 12.71 17.71C12.8037 17.617 12.8781 17.5064 12.9289 17.3846C12.9797 17.2627 13.0058 17.132 13.0058 17C13.0058 16.868 12.9797 16.7373 12.9289 16.6154C12.8781 16.4936 12.8037 16.383 12.71 16.29L9.41 13L17 13C17.2652 13 17.5196 12.8946 17.7071 12.7071C17.8946 12.5196 18 12.2652 18 12C18 11.7348 17.8946 11.4804 17.7071 11.2929C17.5196 11.1054 17.2652 11 17 11Z" fill="white"/>
                  </svg>
                </a>
              </div>


              <div class="containerNextSpecialty flex mt-[10px] mb-[10px] mr-4 md:mr-6 ml-4 flex-1 items-center justify-center  w-12  md:w-14 rounded-full  bg-white/10  transition  backdrop-blur-sm  text-white px-4 py-2">
                <div class="w-3/4 md:w-1/2 text-center">
                  <label class="text-[14px]">Siguiente especialidad</label>
                </div>

                <div class="w-1/4 md:w-1/2">
                  <a 
                    id="nextSpecialty" 
                    href={nextItem ? `/especialidades/${nextItem.slug}` : "#"}
                    class="items-center justify-center rounded-full  bg-white  w-full flex h-[32px] cursor-pointer " aria-label="Especialidad anterior">              
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M6.99998 13L14.59 13L11.29 16.29C11.1017 16.4783 10.9959 16.7337 10.9959 17C10.9959 17.2663 11.1017 17.5217 11.29 17.71C11.4783 17.8983 11.7337 18.0041 12 18.0041C12.2663 18.0041 12.5217 17.8983 12.71 17.71L17.71 12.71C17.801 12.6149 17.8724 12.5028 17.92 12.38C18.02 12.1365 18.02 11.8635 17.92 11.62C17.8724 11.4972 17.801 11.3851 17.71 11.29L12.71 6.29C12.617 6.19627 12.5064 6.12188 12.3846 6.07111C12.2627 6.02034 12.132 5.9942 12 5.9942C11.868 5.9942 11.7373 6.02034 11.6154 6.07111C11.4935 6.12188 11.3829 6.19627 11.29 6.29C11.1963 6.38296 11.1219 6.49356 11.0711 6.61542C11.0203 6.73728 10.9942 6.86799 10.9942 7C10.9942 7.13201 11.0203 7.26272 11.0711 7.38458C11.1219 7.50644 11.1963 7.61704 11.29 7.71L14.59 11L6.99998 11C6.73477 11 6.48041 11.1054 6.29287 11.2929C6.10534 11.4804 5.99998 11.7348 5.99998 12C5.99998 12.2652 6.10534 12.5196 6.29287 12.7071C6.48041 12.8946 6.73477 13 6.99998 13Z" fill="#171D1C"/>
                    </svg>
                  </a>
                </div>
              </div>

              <!-- Right Image -->
              <div class="relative h-full w-32 md:w-40 hidden md:block overflow-hidden min-w-[214px]">
                <img 
                  id="nextSpecialtyImage"
                  src={nextItem?.heroImage?.url || "https://balanced-amusement-bd4a404315.media.strapiapp.com/image_14_7aa0fcd37b.webp"}
                  alt={nextItem?.name ? `Siguiente especialidad: ${nextItem.name}` : "Siguiente especialidad"}
                  class="w-full h-[68px] object-cover"
                />
                <!-- Gradient overlay -->
                <div 
                  class="absolute inset-0 
                        bg-gradient-to-l 
                        from-transparent 
                        via-[var(--color-primary)]/60 
                        to-[var(--color-primary)]
                        to-90%"
                ></div>
              </div>
        
            );
          })()}
      </div>
    </div>
  </div>

  <div class="w-full max-w-7xl mx-auto flex flex-col ">
    <!-- Hero Section de la Categoría -->
    <section class="relative w-full h-auto rounded-b-[24px] md:rounded-none">

      <!-- Breadcrumb sobre la imagen -->
      <div class="max-w-[1280px] flex justify-start relative z-2">
        <Breadcrumb
          textColor="text-white"
          items={[
            { name: "INICIO", href: "/" },
            { name: "ESPECIALIDADES", href: "/especialidades" },
            { name: especialidad?.name ?? "" },
          ]}
        />
      </div>

      <!-- Fila 1 -->
      <div class="heroEspeciality flex flex-col w-full h-auto rounded-b-[24px] md:rounded-none lg:flex-row mb-8">
        <!-- Columna: Imagen -->
        <div
          class="w-full h-[262px] min-h-[400px] relative overflow-hidden bg-cover bg-center md:rounded-none lg:rounded-bl-[24px]"
          style={`background-image: url(${especialidad?.heroImage?.url})`}
        >
        </div>

        <!-- Columna: Texto -->
        <div class="w-full h-auto flex flex-col justify-center gap-2 z-10 bg-gradient-to-r from-[#00827F] to-[#007BB6] bg-[lightgray] p-4 sm:p-6 md:p-8 rounded-b-[24px] md:rounded-b-[0_0_24px_24px] lg:rounded-b-none lg:rounded-br-[24px]">
          <h1
            class="w-full bg-gradient-to-r from-[#AFFFFA] to-[#6DCFFF] bg-clip-text text-left font-lato text-[32px] font-bold leading-[40px] text-transparent [filter:drop-shadow(0_8px_10px_rgba(49,48,48,0.04))_drop-shadow(0_20px_24px_rgba(49,48,48,0.1))]"
          >
            {(especialidad?.name || "categoria").toUpperCase()}
          </h1>
          <p class="text-[16px] md:text-[16px] text-left text-white">{especialidad?.heroDescription ?? ""}</p>

          {(() => {
            const items = Array.isArray(categories) ? categories : [];
            const currentIdx = items.findIndex((item) => item.slug === category);
            const prevIdx = currentIdx === 0 ? items.length - 1 : currentIdx - 1;
            const nextIdx = currentIdx === items.length - 1 ? 0 : currentIdx + 1;
            const prevItem = items[prevIdx];
            const nextItem = items[nextIdx];
            return (
              <div class="flex items-center space-x-4 w-full justify-center sm:justify-center md:justify-between lg:justify-start pt-4 md:py-4">
                <a href={prevItem ? `/especialidades/${prevItem.slug}` : "#"} class="w-12 h-12 rounded-full flex items-center justify-center cursor-pointer transition-opacity hover:opacity-80 p-2 bg-white flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M7.825 13L13.425 18.6L12 20L4 12L12 4L13.425 5.4L7.825 11H20V13H7.825Z" fill="var(--color-primary)" />
                  </svg>
                </a>

                <a
                  href={nextItem ? `/especialidades/${nextItem.slug}` : "#"}
                  class="flex items-center justify-center space-x-3 rounded-full cursor-pointer transition-opacity hover:opacity-80 pl-4 py-2 pr-2 bg-white w-full sm:w-full lg:w-auto"
                >
                  <span class="text-[var(--color-primary)] text-sm font-medium whitespace-nowrap">Siguiente especialidad</span>
                  <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M16.175 13H4V11H16.175L10.575 5.4L12 4L20 12L12 20L10.575 18.6L16.175 13Z" fill="var(--color-primary)" />
                    </svg>
                  </div>
                </a>
              </div>
            );
          })()}
        </div>
      </div>

      {especialidad?.subcategories && especialidad.subcategories.filter((aplicacion) => aplicacion.slug).length > 0 && (
        <section class="mb-16 bg-[var(--color-secondary-light)] px-4 sm:px-6 lg:px-8">
          <div class="space-y-4 md:space-y-[25px]">
            {especialidad.subcategories.filter((aplicacion) => aplicacion.slug).map((aplicacion, index) => (
              <div>
              <div
                class:list={[
                  "flex w-full flex-col gap-4 md:flex-row md:gap-6 md:p-6 lg:gap-6 lg:py-6 lg:px-8",
                  index % 2 === 1 ? "md:flex-row-reverse" : "",
                ]}
              >
                {/* Imagen primero en DOM: arriba en mobile, columna en desktop */}
                <div class="relative w-full shrink-0 md:w-1/2 md:min-h-[280px]">
                  <div class="relative aspect-[4/3] w-full overflow-hidden rounded-[24px] md:aspect-auto md:h-full md:min-h-[280px]">
                    <img
                      src={aplicacion?.image?.url}
                      alt={aplicacion.name}
                      class="absolute inset-0 z-0 h-full w-full rounded-[24px] object-cover md:relative md:inset-auto md:min-h-[280px]"
                      loading="lazy"
                      decoding="async"
                    />
                    {/* Mobile: degradado hacia abajo (texto debajo de la imagen) */}
                    <div
                      class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-24 bg-gradient-to-t from-[var(--color-secondary-light)] to-transparent md:hidden"
                      aria-hidden="true"
                    />
                    {/* Desktop: degradado en el borde que toca el texto (alterna izq/der con la fila) */}
                    {index % 2 === 0 ? (
                      <div
                        class="pointer-events-none absolute inset-y-0 right-0 z-[1] hidden w-20 bg-gradient-to-r from-transparent to-[var(--color-secondary-light)] sm:w-24 md:block"
                        aria-hidden="true"
                      />
                    ) : (
                      <div
                        class="pointer-events-none absolute inset-y-0 left-0 z-[1] hidden w-20 bg-gradient-to-r from-[var(--color-secondary-light)] to-transparent sm:w-24 md:block"
                        aria-hidden="true"
                      />
                    )}
                  </div>
                </div>

                {/* Texto sin fondo; hereda surface de la sección */}
                <div class="flex w-full flex-col justify-between gap-2 px-0 py-6 md:w-1/2 md:px-6 md:py-0">
                  <div class="flex flex-col gap-2">
                    <p class="text-[14px] font-medium text-[var(--color-primary)]">APLICACIÓN</p>

                    <h3 class="text-[28px] font-bold leading-tight text-[#261819]">
                      {aplicacion.name}
                    </h3>

                    <p class="text-[var(--color-text-default)] text-[16px] leading-relaxed">
                      {aplicacion.description ?? ""}
                    </p>

                    <div class="text-[16px] leading-relaxed">
                      <span class="font-semibold text-[#212121]">Equipos: </span>
                      {aplicacion.products && aplicacion.products.length > 0 ? (
                        aplicacion.products.map((product, pIdx) => (
                          <span class="inline">
                            <a
                              href={`/productos/${product.slug}`}
                              class="text-[var(--color-primary)] italic underline decoration-1 underline-offset-2 transition-colors hover:text-[var(--color-accent)]"
                            >
                              {product.name}
                            </a>
                            {pIdx < aplicacion.products.length - 1 && (
                              <span class="text-[var(--color-primary)]">, </span>
                            )}
                          </span>
                        ))
                      ) : (
                        <span class="text-[var(--color-primary)] italic">
                          No hay equipos disponibles
                        </span>
                      )}
                    </div>
                  </div>

                  <a
                    href={`/especialidades/${category}/${aplicacion.slug}`}
                    class="mt-2 flex w-full items-center justify-center gap-2 rounded bg-[var(--color-primary)] px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-[var(--color-accent)] md:mt-8 md:w-fit md:justify-start"
                  >
                    Ver productos
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17 17 7M17 7h-6M17 7v6" />
                    </svg>
                  </a>
                </div>
              </div>
              </div>
            ))}
          </div>
        </section>
      )}
    </section>
  </div>

  
  <!-- <h1>{category}</h1>
  <ul>
    {applications.map((app) => (
      <li>
        <a href={`/especialidades/${category}/${app.slug}`}>
          {app.name}
        </a>
      </li>
    ))}
  </ul> -->

  <!-- Slider de promociones -->
  <PromotionSlider />

  <!-- Slider de especialidades -->
  <EspecialidadesSlider />
<script>
const sticky = document.getElementById('nextSpecialtySticky');
const hero = document.querySelector('.heroEspeciality');

if (sticky && hero) {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Hero visible → ocultar sticky
          sticky.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        } else {
          // Hero fuera → mostrar sticky
          sticky.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        }
      });
    },
    {
      threshold: 0
    }
  );

  observer.observe(hero);
}
</script>
</Layout>
