---
export const prerender = true;
import Layout from "@layouts/Layout.astro";
// import { getApplicationsByCategory } from "@server/api/applications";
import { getCategories } from "@server/api/categories";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import JsonLd from "@components/seo/JsonLd.astro";
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import PromotionSlider from '@components/sections/PromotionSlider.astro';
import EspecialidadesSlider from "@components/sections/EspecialidadesSlider.astro";
import SpecialtyApplicationsGrid from "@components/sections/SpecialtyApplicationsGrid.astro";
import { getSiteConfig } from "@server/siteConfig";
import { getLocaleMeta, localizePath } from "@lib/locale";
import { buildSpecialtyCategorySchema } from "@seo/schemas/specialtyCategory";
// import SpecialtyHero from "@components/navigation/SpecialtyHero.astro";
import BannerSlider from '@components/sections/BannerSlider.astro';

const siteConfig = await getSiteConfig();

export async function getStaticPaths() {
  const categories = await getCategories();

  return categories.map((c) => ({
    params: { category: c.slug },
  }));
}

const { category } = Astro.params;
const categories = await getCategories();

// Buscar la categoría actual por slug
const especialidad = Array.isArray(categories)
  ? categories.find(item => item.slug === category)
  : null;
const sliderHero = especialidad?.sliderHero || [];
const currentPathname = Astro.originPathname ?? Astro.url.pathname;
const localeMeta = getLocaleMeta(currentPathname);
const canonical = new URL(currentPathname, Astro.site).toString();

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = canonical;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = siteConfig?.favicon512x512?.url;
const homeUrl = new URL(localizePath("/", currentPathname), Astro.site).toString();
const specialtiesUrl = new URL(localizePath("/especialidades", currentPathname), Astro.site).toString();
---

<Layout
  title={`${especialidad?.name ?? "Especialidad"} | Aplicaciones clínicas y tecnología médica | MedRent`}
  description={especialidad?.heroDescription ?? "Tecnología médica para diagnóstico, terapia y rehabilitación con soporte especializado de MedRent."}
  keywords={`${especialidad?.name ?? "especialidad"}; tecnología médica; equipos médicos; MedRent`}
>
  <style>
    body {
      background: var(--color-secondary-light);
    }
  </style>

  <!-- Breadcrumb Schema dinámico -->
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Inicio', url: homeUrl },
      { name: 'Especialidades', url: specialtiesUrl },
      { name: especialidad?.name ?? "", url: canonicalUrl },
    ]}
    id={breadcrumbId}
  />

  <Fragment slot="head">
    <JsonLd
      data={buildSpecialtyCategorySchema({
        especialidad,
        canonicalUrl,
        baseUrl,
        breadcrumbId,
        logoUrl,
        currentPathname,
        site: Astro.site,
        language: localeMeta.htmlLang,
      })}
    />
  </Fragment>

  <div class="relative mb-8">
    <div class="absolute left-0 top-0 z-30 w-full">
      <div class="mx-auto flex w-full max-w-[1280px] justify-start">
        <Breadcrumb
          surface="light"
          navPosition="inline"
          textColor="text-black"
          items={[
            { name: "INICIO", href: localizePath("/", currentPathname) },
            { name: "ESPECIALIDADES", href: localizePath("/especialidades", currentPathname) },
            { name: especialidad?.name ?? "" },
          ]}
        />
      </div>
    </div>

    <BannerSlider data={sliderHero} />
  </div>
  


  <div class="w-full max-w-7xl mx-auto flex flex-col ">
    <!-- Hero Section de la Categoría -->
    <section class="relative w-full h-auto rounded-b-[24px] md:rounded-none">
      <!-- Fila 1 -->
      <!-- <SpecialtyHero
        category={category}
        categories={categories}
        especialidad={especialidad}
        currentPathname={currentPathname}
      /> -->

      <SpecialtyApplicationsGrid
        applications={especialidad?.subcategories}
        category={category}
        currentPathname={currentPathname}
      />
    </section>
  </div>

  <!-- Slider de promociones -->
  <PromotionSlider />

  <!-- Slider de especialidades -->
  <EspecialidadesSlider />

</Layout>